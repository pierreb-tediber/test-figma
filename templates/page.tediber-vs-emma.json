      "name": "Comparateur W3",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  TB Compare — CRITÈRES TECHNIQUES (titre + gagnant + comparateur complet)\n  Custom Liquid (no schema)\n{%- endcomment -%}\n\n{%- assign section_title = 'CRITÈRES TECHNIQUES' -%}\n{%- assign winner_text = 'Gagnant : Hybride Infinite' -%}\n\n<section class=\"tb-compare-techfull\" role=\"region\" aria-label=\"{{ section_title | escape }}\">\n  <div class=\"tb-compare-techfull__inner\">\n\n    <!-- Header -->\n    <div class=\"tb-compare-tech\" aria-label=\"{{ section_title | escape }}\">\n      <div class=\"tb-compare-tech__inner\">\n        <h2 class=\"tb-compare-tech__title\">{{ section_title }}</h2>\n\n        <div class=\"tb-compare-tech__winner\" aria-label=\"{{ winner_text | escape }}\">\n          <span class=\"tb-compare-tech__medal\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 40 40\" width=\"28\" height=\"28\" focusable=\"false\" aria-hidden=\"true\">\n              <defs>\n                <linearGradient id=\"tbGold\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#f7d47a\"/>\n                  <stop offset=\"0.55\" stop-color=\"#d4a93a\"/>\n                  <stop offset=\"1\" stop-color=\"#f7d47a\"/>\n                </linearGradient>\n              </defs>\n              <path d=\"M13 4h7l-4 10H9L13 4Z\" fill=\"#b24b45\"/>\n              <path d=\"M20 4h7l4 10h-7L20 4Z\" fill=\"#3b6db2\"/>\n              <circle cx=\"20\" cy=\"22\" r=\"10.5\" fill=\"url(#tbGold)\" stroke=\"#c5972f\" stroke-width=\"1.5\"/>\n              <circle cx=\"20\" cy=\"22\" r=\"6.4\" fill=\"none\" stroke=\"#b8861f\" stroke-width=\"1.4\" opacity=\"0.7\"/>\n              <path d=\"M20 16.5l1.7 3.7 4 .5-3 2.7.9 4-3.6-2.1-3.6 2.1.9-4-3-2.7 4-.5L20 16.5Z\" fill=\"#8b6511\" opacity=\"0.9\"/>\n            </svg>\n          </span>\n\n          <span class=\"tb-compare-tech__winner-text\">{{ winner_text }}</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Comparator -->\n    <section class=\"tb-compare-acc\" id=\"comparateur\" role=\"region\" aria-label=\"Comparateur technique\">\n      <div class=\"tb-compare-acc__inner\">\n\n        <!-- ROW 1 -->\n        <div class=\"tb-compare-acc__row\">\n          <div class=\"tb-compare-acc__cards\">\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">31 cm d’épaisseur</div>\n              </div>\n            </div>\n\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">25.8 cm d’épaisseur</div>\n              </div>\n            </div>\n          </div>\n\n          <button class=\"tb-compare-acc__toggle\" type=\"button\" aria-expanded=\"false\">\n            <span class=\"tb-compare-acc__toggle-text\">\n              L’épaisseur accrue du matelas Hybride Infinite contribue à <strong>un meilleur soutien et une plus grande durabilité.</strong>\n            </span>\n            <span class=\"tb-compare-acc__chev\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" focusable=\"false\" aria-hidden=\"true\">\n                <path d=\"M6 9l6 6 6-6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              </svg>\n            </span>\n          </button>\n\n          <div class=\"tb-compare-acc__panel\" hidden>\n            <p class=\"tb-compare-acc__panel-text\">\n              <strong>Confort progressif :</strong> grâce à ses 31 cm d’épaisseur, le matelas Hybride Infinite offre une meilleure résistance à la compression, permettant au corps d’être d’abord accueilli en douceur puis soutenu avec fermeté.<br><br>\n              <strong>Durabilité renforcée :</strong>  le matelas Hybride Infinite intègre plus de matière permettant de préserver les performances de soutien pendant de nombreuses années.\n            </p>\n          </div>\n          <div class=\"tb-compare-acc__divider\" aria-hidden=\"true\"></div>\n        </div>\n\n        <!-- ROW 2 -->\n        <div class=\"tb-compare-acc__row\">\n          <div class=\"tb-compare-acc__cards\">\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">9 couches de confort</div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">\n                  5 couches de mousse\n                  <small class=\"tb-compare-acc__sub\">Dont une mousse de maintien pour une meilleure stabilité</small>\n                </div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">13 cm d’épaisseur des mousses</div>\n              </div>\n            </div>\n\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">7 couches de confort</div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">\n                  4 couches de mousse\n                  <small class=\"tb-compare-acc__sub\">Sans mousse de maintien limitant la durabilité du confort</small>\n                </div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">5.5 cm d’épaisseur des mousses</div>\n              </div>\n            </div>\n          </div>\n\n          <button class=\"tb-compare-acc__toggle\" type=\"button\" aria-expanded=\"false\">\n            <span class=\"tb-compare-acc__toggle-text\">\n              La mousse de maintien en plus sur l’Hybride Infinite crée <strong>une structure stable.</strong>\n            </span>\n            <span class=\"tb-compare-acc__chev\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" focusable=\"false\" aria-hidden=\"true\">\n                <path d=\"M6 9l6 6 6-6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              </svg>\n            </span>\n          </button>\n\n          <div class=\"tb-compare-acc__panel\" hidden>\n            <p class=\"tb-compare-acc__panel-text\">\n              <strong>Structure stable :</strong>  placée sous les ressorts, la mousse de maintien du matelas Hybride Infinite renforce la stabilité de l’ensemble et améliore sa durabilité.<br><br>\n              <strong>Confort harmonieux :</strong> la mousse de maintien permet de limiter les déformations et assure une assise homogène sur toute la surface du matelas Hybride Infinite.\n            </p>\n          </div>\n          <div class=\"tb-compare-acc__divider\" aria-hidden=\"true\"></div>\n        </div>\n\n        <!-- ROW 3 (AJOUTÉE) -->\n        <div class=\"tb-compare-acc__row\">\n          <div class=\"tb-compare-acc__cards\">\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">493,1 ressorts / m2</div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">36 kg</div>\n              </div>\n            </div>\n\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">196,8 ressorts / m2</div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">29,2 kg</div>\n              </div>\n            </div>\n          </div>\n\n          <button class=\"tb-compare-acc__toggle\" type=\"button\" aria-expanded=\"false\">\n            <span class=\"tb-compare-acc__toggle-text\">\n              Le nombre élevé de ressorts ensachés de L’Hybride Infinite <strong>améliore la respirabilité.</strong>\n            </span>\n            <span class=\"tb-compare-acc__chev\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" focusable=\"false\" aria-hidden=\"true\">\n                <path d=\"M6 9l6 6 6-6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              </svg>\n            </span>\n          </button>\n\n          <div class=\"tb-compare-acc__panel\" hidden>\n            <p class=\"tb-compare-acc__panel-text\">\n              <strong>Respirabilité optimisée :</strong> le matelas Hybride Infinite, composé jusqu’à 1 700 micro-ressorts répartis en 7 zones de confort, assure une circulation de l’air optimale et évacue efficacement la chaleur.<br></br>\n<strong>Soutien ultra-ciblé :</strong> la combinaison de la mousse d’accueil haute résilience et des micro-ressorts du matelas Hybride Infinite assure un soutien précis sur chaque zone du corps.\n            </p>\n          </div>\n          <div class=\"tb-compare-acc__divider\" aria-hidden=\"true\"></div>\n        </div>\n\n        <!-- ROW 4 (AJOUTÉE) -->\n        <div class=\"tb-compare-acc__row\">\n          <div class=\"tb-compare-acc__cards\">\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">\n                  7 zones de soutien\n                  <small class=\"tb-compare-acc__sub\">Tête, épaules, lombaires, hanches, cuisses, jambes et pieds</small>\n                </div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--ok\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">\n                  Avec carénage\n                  <small class=\"tb-compare-acc__sub\">Garantit une meilleure stabilité et un confort plus durable</small>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"tb-compare-acc__stack\" data-stack>\n              <div class=\"tb-compare-acc__cell is-top\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">\n                  7 zones de soutien\n                  <small class=\"tb-compare-acc__sub\">Tête, nuque, épaules, lombaires, hanches, jambes et pieds</small>\n                </div>\n              </div>\n\n              <div class=\"tb-compare-acc__cell is-bottom\">\n                <span class=\"tb-compare-acc__icon\" aria-hidden=\"true\">\n                  <span class=\"tb-compare-acc__badge tb-compare-acc__badge--no\">\n                    <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n                      <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n                    </svg>\n                  </span>\n                </span>\n                <div class=\"tb-compare-acc__value\">\n                  Sans carénage\n                  <small class=\"tb-compare-acc__sub\">Risque d’affaissement sur les bords</small>\n                </div>\n              </div>\n            </div>\n          </div>\n<button class=\"tb-compare-acc__toggle\" type=\"button\" aria-expanded=\"false\">\n            <span class=\"tb-compare-acc__toggle-text\">\n             Grâce au carénage de maintien, l’Hybride Infinite <strong>garantit plus de stabilité.</strong>\n            </span>\n            <span class=\"tb-compare-acc__chev\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" focusable=\"false\" aria-hidden=\"true\">\n                <path d=\"M6 9l6 6 6-6\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              </svg>\n            </span>\n          </button>\n\n          <div class=\"tb-compare-acc__panel\" hidden>\n            <p class=\"tb-compare-acc__panel-text\">\n              <strong>Stabilité renforcée : </strong> le carénage de maintien du matelas Hybride Infinite de Tediber consolide le pourtour et évite l’affaissement des bords assurant un confort durable.<br></br>\n<strong>Surface de couchage optimisée :</strong> grâce à des bords plus fermes et la structure renforcée, le soutien reste homogène jusqu’aux extrémités.\n            </p>\n          </div>\n          <div class=\"tb-compare-acc__divider\" aria-hidden=\"true\"></div>\n        </div>\n\n  <style>\n  /* ===== Full section background ===== */\n  .tb-compare-techfull{\n    --tb-bg-1:#010d27;\n    --tb-bg-2:#0b1730;\n    --tb-ink:#f5eee6;\n    color: var(--tb-ink);\n    padding: 28px 16px 24px;\n    overflow: hidden;\n  }\n  .tb-compare-techfull__inner{ max-width: 1100px; margin: 0 auto; }\n\n  @media (min-width: 1024px){\n    .tb-compare-techfull{ padding: 44px 40px 34px; }\n  }\n\n  /* ===== Header ===== */\n  .tb-compare-tech{ color: var(--tb-ink); padding: 0; }\n  .tb-compare-tech__inner{\n    display: grid;\n    justify-items: center;\n    gap: 12px;\n    text-align: center;\n    margin-bottom: 14px;\n  }\n\n  /* ✅ Section title: 28px mobile */\n  .tb-compare-tech__title{\n    margin: 0;\n    text-transform: uppercase;\n    letter-spacing: 0.02em;\n    font-weight: 900;\n    line-height: 1;\n    font-size: 28px;\n    color: var(--tb-ink);\n  }\n\n  .tb-compare-tech__winner{\n    --tb-gold:#e7c06a;\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 10px 14px;\n    border-radius: 6px;\n    border: 2px solid var(--tb-gold);\n    max-width: 100%;\n    background: rgba(1, 13, 39, 0.10);\n  }\n\n  .tb-compare-tech__medal{\n    display: inline-flex;\n    width: 24px;\n    height: 24px;\n    align-items: center;\n    justify-content: center;\n    transform: translateY(1px);\n    flex: 0 0 auto;\n  }\n  .tb-compare-tech__medal svg{ width: 24px; height: 24px; }\n\n  /* ✅ Winner tag text: 14px mobile */\n  .tb-compare-tech__winner-text{\n    font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n    font-weight: 800;\n    font-size: 14px;\n    line-height: 1.1;\n    color: var(--tb-ink);\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    max-width: 78vw;\n  }\n\n  @media (min-width: 1024px){\n    .tb-compare-tech__title{ font-size: 32px; }\n    .tb-compare-tech__winner-text{ max-width: none; font-size: 16px; }\n  }\n\n  /* ===== Comparator ===== */\n  .tb-compare-acc{\n    --tb-ink:#f5eee6;\n    --tb-divider:rgba(245,238,230,.22);\n    --tb-left:#0e2b2f;\n    --tb-right:#2a3546;\n    --tb-radius:4px;\n    --tb-ok:#1f7a55;\n    --tb-no:#d55b57;\n\n    color: var(--tb-ink);\n    padding: 6px 0 0;\n  }\n\n  .tb-compare-acc__inner{ margin: 0; }\n  .tb-compare-acc__row{ padding: 12px 0; }\n\n  .tb-compare-acc__cards{\n    display:grid;\n    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);\n    gap: 12px;\n    margin-bottom: 10px;\n    width: 100%;\n  }\n\n  .tb-compare-acc__stack{\n    display:flex;\n    flex-direction:column;\n    min-width: 0;\n    align-items: stretch;\n  }\n\n  .tb-compare-acc__cell{\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    text-align:center;\n\n    padding: 14px 10px;\n    color: var(--tb-ink);\n    font-weight: 800;\n\n    /* ✅ Cell titles: 14px mobile */\n    font-size: 14px;\n    line-height: 1.15;\n\n    border-top: 1px solid rgba(245,238,230,.08);\n    min-width: 0;\n    word-break: break-word;\n    width: 100%;\n  }\n\n  .tb-compare-acc__cell.is-top{ border-top: none; }\n\n  .tb-compare-acc__stack:nth-child(1) .tb-compare-acc__cell{ background: var(--tb-left); }\n  .tb-compare-acc__stack:nth-child(2) .tb-compare-acc__cell{ background: var(--tb-right); }\n\n  .tb-compare-acc__cell.is-top{\n    border-top-left-radius: var(--tb-radius);\n    border-top-right-radius: var(--tb-radius);\n  }\n  .tb-compare-acc__cell.is-bottom{\n    border-bottom-left-radius: var(--tb-radius);\n    border-bottom-right-radius: var(--tb-radius);\n  }\n\n  .tb-compare-acc__icon{ margin-bottom: 8px; }\n\n  .tb-compare-acc__badge{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    width: 26px;\n    height: 26px;\n    border-radius: 999px;\n    color: #fff;\n  }\n  .tb-compare-acc__badge svg{ width: 16px; height: 16px; }\n  .tb-compare-acc__badge--ok{ background: var(--tb-ok); }\n  .tb-compare-acc__badge--no{ background: var(--tb-no); }\n\n  /* ✅ Subtitles: 12px mobile */\n  .tb-compare-acc__sub{\n    display:block;\n    margin-top: 8px;\n    font-weight: 600;\n    font-size: 12px;\n    line-height: 1.25;\n    opacity: 0.95;\n  }\n\n  .tb-compare-acc__toggle{\n    width: 100%;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap: 12px;\n\n    background: transparent;\n    color: var(--tb-ink);\n    border: 0;\n    padding: 2px 0 0;\n    cursor: pointer;\n    text-align: left;\n  }\n\n  /* (tu n’as pas demandé de changer cette typo, je la laisse) */\n  .tb-compare-acc__toggle-text{\n    font-size: 16px;\n    line-height: 1.2;\n    font-weight: 500;\n    letter-spacing: -0.01em;\n  }\n  .tb-compare-acc__toggle-text strong{ font-weight: 900; }\n\n  .tb-compare-acc__chev{\n    flex: 0 0 auto;\n    width: 28px;\n    height: 28px;\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    opacity: 0.95;\n    transform: rotate(0deg);\n    transition: transform .18s ease;\n  }\n  .tb-compare-acc__row.is-open .tb-compare-acc__chev{ transform: rotate(180deg); }\n\n  .tb-compare-acc__panel{ padding: 10px 0 0; }\n  .tb-compare-acc__panel-text{\n    margin: 0;\n    font-size: 14px;\n    line-height: 1.45;\n    opacity: 0.92;\n    max-width: 70ch;\n  }\n\n  .tb-compare-acc__divider{\n    height: 1px;\n    width: 100%;\n    background: var(--tb-divider);\n    margin-top: 12px;\n  }\n\n  /* Desktop: monte un peu sans devenir énorme */\n  @media (min-width: 990px){\n    .tb-compare-acc__cards{ gap: 16px; }\n    .tb-compare-acc__cell{ padding: 18px 14px; font-size: 16px; }\n    .tb-compare-acc__sub{ font-size: 14px; }\n    .tb-compare-acc__toggle-text{ font-size: 18px; }\n    .tb-compare-acc__panel-text{ font-size: 15px; }\n  }\n</style>\n\n  <script>\n    (function(){\n      var root = document.currentScript && document.currentScript.closest('.tb-compare-techfull');\n      if(!root) return;\n\n      var acc = root.querySelector('.tb-compare-acc');\n      if(!acc) return;\n\n      var rows = Array.prototype.slice.call(acc.querySelectorAll('.tb-compare-acc__row'));\n\n      function closeRow(row){\n        row.classList.remove('is-open');\n        var btn = row.querySelector('.tb-compare-acc__toggle');\n        var panel = row.querySelector('.tb-compare-acc__panel');\n        if(btn) btn.setAttribute('aria-expanded', 'false');\n        if(panel) panel.hidden = true;\n      }\n\n      function openRow(row){\n        row.classList.add('is-open');\n        var btn = row.querySelector('.tb-compare-acc__toggle');\n        var panel = row.querySelector('.tb-compare-acc__panel');\n        if(btn) btn.setAttribute('aria-expanded', 'true');\n        if(panel) panel.hidden = false;\n      }\n\n      // Equalize heights per row, per cell index (left vs right)\n      function equalizeRowCells(row){\n        var stacks = row.querySelectorAll('.tb-compare-acc__stack');\n        if(!stacks || stacks.length < 2) return;\n\n        var leftCells = Array.prototype.slice.call(stacks[0].querySelectorAll('.tb-compare-acc__cell'));\n        var rightCells = Array.prototype.slice.call(stacks[1].querySelectorAll('.tb-compare-acc__cell'));\n        var maxLen = Math.max(leftCells.length, rightCells.length);\n\n        leftCells.forEach(function(c){ c.style.minHeight = ''; });\n        rightCells.forEach(function(c){ c.style.minHeight = ''; });\n\n        for(var i=0; i<maxLen; i++){\n          var l = leftCells[i];\n          var r = rightCells[i];\n          if(!l || !r) continue;\n\n          var lh = l.offsetHeight;\n          var rh = r.offsetHeight;\n          var mh = Math.max(lh, rh);\n\n          l.style.minHeight = mh + 'px';\n          r.style.minHeight = mh + 'px';\n        }\n      }\n\n      function equalizeAll(){\n        rows.forEach(equalizeRowCells);\n      }\n\n      // Accordion init\n      rows.forEach(function(row){\n        var btn = row.querySelector('.tb-compare-acc__toggle');\n        if(!btn) return;\n\n        closeRow(row);\n\n        btn.addEventListener('click', function(){\n          var isOpen = row.classList.contains('is-open');\n\n          rows.forEach(function(r){\n            if(r !== row) closeRow(r);\n          });\n\n          if(isOpen) closeRow(row);\n          else openRow(row);\n\n          // heights can change slightly when panel opens\n          equalizeAll();\n        });\n      });\n\n      equalizeAll();\n      window.addEventListener('resize', equalizeAll);\n      window.setTimeout(equalizeAll, 80);\n      window.setTimeout(equalizeAll, 300);\n      if(document.fonts && document.fonts.ready){\n        document.fonts.ready.then(equalizeAll).catch(function(){});\n      }\n    })();\n  </script>\n</section>\n{%- comment -%}\n  TB Compare — CRITÈRES DE CONFORT (Custom Liquid)\n  - Title + winner pill\n  - 2 columns, 3 stacked cells each\n  - Border radius only top/bottom of each stack\n  - Icons above text\n  - Equal height per row index (table-like)\n{%- endcomment -%}\n\n{%- assign section_title = 'CRITÈRES DE CONFORT' -%}\n{%- assign winner_text = 'Gagnant : Hybride Infinite' -%}\n\n<section class=\"tb-comfort\" role=\"region\" aria-label=\"{{ section_title | escape }}\">\n  <div class=\"tb-comfort__inner\">\n\n    <h2 class=\"tb-comfort__title\">{{ section_title }}</h2>\n\n    <div class=\"tb-comfort__winner\" aria-label=\"{{ winner_text | escape }}\">\n      <span class=\"tb-comfort__medal\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 40 40\" width=\"28\" height=\"28\" focusable=\"false\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"tbGoldComfort\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#f7d47a\"/>\n              <stop offset=\"0.55\" stop-color=\"#d4a93a\"/>\n              <stop offset=\"1\" stop-color=\"#f7d47a\"/>\n            </linearGradient>\n          </defs>\n          <path d=\"M13 4h7l-4 10H9L13 4Z\" fill=\"#b24b45\"/>\n          <path d=\"M20 4h7l4 10h-7L20 4Z\" fill=\"#3b6db2\"/>\n          <circle cx=\"20\" cy=\"22\" r=\"10.5\" fill=\"url(#tbGoldComfort)\" stroke=\"#c5972f\" stroke-width=\"1.5\"/>\n          <circle cx=\"20\" cy=\"22\" r=\"6.4\" fill=\"none\" stroke=\"#b8861f\" stroke-width=\"1.4\" opacity=\"0.7\"/>\n          <path d=\"M20 16.5l1.7 3.7 4 .5-3 2.7.9 4-3.6-2.1-3.6 2.1.9-4-3-2.7 4-.5L20 16.5Z\" fill=\"#8b6511\" opacity=\"0.9\"/>\n        </svg>\n      </span>\n      <span class=\"tb-comfort__winner-text\">{{ winner_text }}</span>\n    </div>\n\n    <div class=\"tb-comfort__grid\" data-eq-grid>\n      <!-- LEFT STACK -->\n      <div class=\"tb-comfort__stack\" data-stack>\n        <div class=\"tb-comfort__cell is-top is-ok\">\n          <span class=\"tb-comfort__badge tb-comfort__badge--ok\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n            </svg>\n          </span>\n          <div class=\"tb-comfort__cell-title\">Excellente absorption des mouvements</div>\n          <div class=\"tb-comfort__cell-sub\">Jusqu’à 1 700 micro-ressorts \nensachés répartis en 7 zones</div>\n        </div>\n\n        <div class=\"tb-comfort__cell is-ok\">\n          <span class=\"tb-comfort__badge tb-comfort__badge--ok\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n            </svg>\n          </span>\n          <div class=\"tb-comfort__cell-title\">Très bonne respirabilité et fraîcheur</div>\n          <div class=\"tb-comfort__cell-sub\">Housse en Tencel + mousse d’accueil enrichie en graphite</div>\n        </div>\n\n        <div class=\"tb-comfort__cell is-ok\">\n          <span class=\"tb-comfort__badge tb-comfort__badge--ok\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n            </svg>\n          </span>\n\n          </span>\n          <div class=\"tb-comfort__cell-title\">Réversible</div>\n          <div class=\"tb-comfort__cell-sub\">2 faces : fraîche + accueillante ou moelleuse</div>\n        </div>\n      </div>\n\n      <!-- RIGHT STACK -->\n         <div class=\"tb-comfort__stack\" data-stack>\n        <div class=\"tb-comfort__cell is-top is-ok\">\n          <span class=\"tb-comfort__badge tb-comfort__badge--ok\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n            </svg>\n          </span>\n          <div class=\"tb-comfort__cell-title\">Bonne absorption des mouvements</div>\n          <div class=\"tb-comfort__cell-sub\">Indépendance de couchage limitée par des mousses fines</div>\n        </div>\n\n        <div class=\"tb-comfort__cell is-ok\">\n          <span class=\"tb-comfort__badge tb-comfort__badge--ok\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M10.4 15.6 7.7 12.9a1 1 0 1 1 1.4-1.4l1.7 1.7 4.2-4.2a1 1 0 0 1 1.4 1.4l-5 5a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n            </svg>\n          </span>\n          <div class=\"tb-comfort__cell-title\">Bonne respirabilité</div>\n          <div class=\"tb-comfort__cell-sub\">Mousse d’accueil enrichie en graphite</div>\n        </div>\n\n        <div class=\"tb-comfort__cell is-bottom is-no\">\n          <span class=\"tb-comfort__badge tb-comfort__badge--no\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n            </svg>\n          </span>\n          <div class=\"tb-comfort__cell-title\">Non réversible</div>\n          <div class=\"tb-comfort__cell-sub\">Personnalisation du confort\nlimitée</div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <style>\n  .tb-comfort{\n    --tb-ink:#f5eee6;\n    --tb-gold:#e7c06a;\n\n    --tb-left:#0e2b2f;\n    --tb-right:#2a3546;\n\n    --tb-ok:#1f7a55;\n    --tb-no:#d55b57;\n\n    --tb-radius:4px;\n\n    color: var(--tb-ink);\n    padding: 24px 16px 28px;\n    overflow: hidden;\n  }\n\n  .tb-comfort__inner{\n    max-width: 1100px;\n    margin: 0 auto;\n    display:grid;\n    justify-items:center;\n    gap: 12px;\n    text-align:center;\n  }\n\n  /* ✅ Section title: 24px on ~370px */\n  .tb-comfort__title{\n    margin: 0;\n    text-transform: uppercase;\n    letter-spacing: 0.02em;\n    font-weight: 900;\n    line-height: 1;\n    font-size: 28px;\n  }\n\n  .tb-comfort__winner{\n    display:inline-flex;\n    align-items:center;\n    gap: 10px;\n    padding: 10px 14px;\n    border-radius: 6px;\n    border: 2px solid var(--tb-gold);\n    background: rgba(1, 13, 39, 0.10);\n    max-width: 100%;\n  }\n\n  .tb-comfort__medal{\n    display:inline-flex;\n    width: 24px;\n    height: 24px;\n    align-items:center;\n    justify-content:center;\n    transform: translateY(1px);\n    flex: 0 0 auto;\n  }\n  .tb-comfort__medal svg{ width: 24px; height: 24px; }\n\n  /* ✅ Winner tag text: 14px */\n  .tb-comfort__winner-text{\n    font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n    font-weight: 800;\n    font-size: 14px;\n    line-height: 1.1;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    max-width: 78vw;\n  }\n\n  /* grid of the two stacks */\n  .tb-comfort__grid{\n    width: 100%;\n    display:grid;\n    grid-template-columns: minmax(0,1fr) minmax(0,1fr);\n    gap: 12px;\n    margin-top: 10px;\n    text-align: left;\n  }\n\n  .tb-comfort__stack{\n    display:flex;\n    flex-direction:column;\n    align-items: stretch;\n    min-width: 0;\n  }\n\n  .tb-comfort__cell{\n    background: var(--tb-left);\n    border-top: 1px solid rgba(245,238,230,.08);\n\n    padding: 14px 10px 16px;\n    min-width: 0;\n    width: 100%;\n\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:flex-start;\n    text-align:center;\n    gap: 8px;\n  }\n\n  .tb-comfort__stack:nth-child(2) .tb-comfort__cell{ background: var(--tb-right); }\n\n  .tb-comfort__cell.is-top{\n    border-top: none;\n    border-top-left-radius: var(--tb-radius);\n    border-top-right-radius: var(--tb-radius);\n  }\n  .tb-comfort__cell.is-bottom{\n    border-bottom-left-radius: var(--tb-radius);\n    border-bottom-right-radius: var(--tb-radius);\n  }\n\n  .tb-comfort__badge{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    width: 26px;\n    height: 26px;\n    border-radius: 999px;\n    flex: 0 0 auto;\n    margin-top: 2px;\n  }\n  .tb-comfort__badge svg{ width: 16px; height: 16px; }\n  .tb-comfort__badge--ok{ background: var(--tb-ok); }\n  .tb-comfort__badge--no{ background: var(--tb-no); }\n\n  /* ✅ Cell typography */\n  .tb-comfort__cell-title{\n    font-weight: 900;\n    text-transform: none;\n    font-size: 14px;   /* requested */\n    line-height: 1.15;\n    letter-spacing: -0.01em;\n  }\n  .tb-comfort__cell-sub{\n    font-weight: 600;\n    font-size: 12px;   /* requested */\n    line-height: 1.3;\n    opacity: 0.96;\n  }\n\n  /* Desktop: keep it readable but not huge */\n  @media (min-width: 1024px){\n    .tb-comfort{ padding: 36px 40px 40px; }\n    .tb-comfort__winner-text{ max-width: none; }\n    .tb-comfort__grid{ gap: 16px; margin-top: 14px; }\n    .tb-comfort__cell{ padding: 18px 16px 20px; gap: 10px; }\n\n    .tb-comfort__title{ font-size: 32px; }\n    .tb-comfort__winner-text{ font-size: 16px; }\n    .tb-comfort__cell-title{ font-size: 16px; }\n    .tb-comfort__cell-sub{ font-size: 14px; }\n  }\n</style>\n\n  <script>\n    (function(){\n      var root = document.currentScript && document.currentScript.closest('.tb-comfort');\n      if(!root) return;\n\n      var grid = root.querySelector('[data-eq-grid]');\n      if(!grid) return;\n\n      var stacks = grid.querySelectorAll('[data-stack]');\n      if(!stacks || stacks.length < 2) return;\n\n      function equalize(){\n        var leftCells = Array.prototype.slice.call(stacks[0].querySelectorAll('.tb-comfort__cell'));\n        var rightCells = Array.prototype.slice.call(stacks[1].querySelectorAll('.tb-comfort__cell'));\n        var maxLen = Math.max(leftCells.length, rightCells.length);\n\n        leftCells.forEach(function(c){ c.style.minHeight = ''; });\n        rightCells.forEach(function(c){ c.style.minHeight = ''; });\n\n        for(var i=0;i<maxLen;i++){\n          var l = leftCells[i];\n          var r = rightCells[i];\n          if(!l || !r) continue;\n\n          var lh = l.offsetHeight;\n          var rh = r.offsetHeight;\n          var mh = Math.max(lh, rh);\n\n          l.style.minHeight = mh + 'px';\n          r.style.minHeight = mh + 'px';\n        }\n      }\n\n      equalize();\n      window.addEventListener('resize', equalize);\n      window.setTimeout(equalize, 80);\n      window.setTimeout(equalize, 300);\n      if(document.fonts && document.fonts.ready){\n        document.fonts.ready.then(equalize).catch(function(){});\n      }\n    })();\n  </script>\n</section>\n{%- comment -%}\n  TB Compare — PRIX (Custom Liquid)\n  - Titre + tooltip (icône i)\n  - 2 cartes prix (hauteur alignée)\n  - paragraphe + encadré alerte\n{%- endcomment -%}\n\n{%- assign section_title = 'PRIX' -%}\n{%- assign tooltip_text = \"Les prix indiqués ont été relevés le 27/02/2026 et correspondent à la plus petite taille disponible pour chacun des modèles présentés (80 x 200 cm), dans leur version standard. Ce sont les prix avant promotion, fournis à titre indicatif et susceptibles d’évoluer en fonction des ajustements tarifaires.\" -%}\n\n<section class=\"tb-price\" role=\"region\" aria-label=\"{{ section_title | escape }}\">\n  <div class=\"tb-price__inner\">\n\n    <div class=\"tb-price__head\">\n      <h2 class=\"tb-price__title\">\n        {{ section_title }}\n        <span class=\"tb-price__info-wrap\">\n          <button class=\"tb-price__info-btn\" type=\"button\" aria-label=\"Information sur les prix\" data-tooltip-trigger>\n            <svg viewBox=\"0 0 24 24\" width=\"22\" height=\"22\" focusable=\"false\" aria-hidden=\"true\">\n              <circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n              <path d=\"M12 10.7v6.2\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n              <circle cx=\"12\" cy=\"7.5\" r=\"1.2\" fill=\"currentColor\"/>\n            </svg>\n          </button>\n\n          <span class=\"tb-price__tooltip\" role=\"tooltip\" aria-hidden=\"true\">\n            {{ tooltip_text }}\n          </span>\n        </span>\n      </h2>\n    </div>\n\n    <div class=\"tb-price__cards\" data-eq-grid>\n      <!-- LEFT -->\n      <div class=\"tb-price__card tb-price__card--left\">\n        <div class=\"tb-price__card-price\">Dès 1 069,00 €</div>\n        <div class=\"tb-price__card-sub\">Prix relevé le 27/02/2026 \navant promotion</div>\n      </div>\n\n      <!-- RIGHT -->\n      <div class=\"tb-price__card tb-price__card--right\">\n        <div class=\"tb-price__card-price\">Dès 909,00 €</div>\n        <div class=\"tb-price__card-sub\">Prix relevé le 27/02/2026 \navant promotion</div>\n      </div>\n    </div>\n\n    <div class=\"tb-price__text\">\n      Les prix du <span class=\"tb-price__u\">matelas Hybride Infinite de Tediber</span> et du matelas Original Pro d’Emma ne sont pas fixes tout au long de l’année&nbsp;:\n      <strong>ils varient selon les périodes promotionnelles, les événements commerciaux et les offres exclusives</strong>\n      proposées par les marques ou les revendeurs.\n    </div>\n\n    <div class=\"tb-price__alert\" role=\"note\" aria-label=\"Information importante\">\n      <div class=\"tb-price__alert-head\">\n        <span class=\"tb-price__alert-ico\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" width=\"28\" height=\"28\" aria-hidden=\"true\">\n  <path\n    d=\"M12 3.8\n       L21 19\n       Q21.55 20.05 20.4 20.05\n       H3.6\n       Q2.45 20.05 3 19\n       L12 3.8 Z\"\n    fill=\"none\"\n    stroke=\"currentColor\"\n    stroke-width=\"1.9\"\n    stroke-linejoin=\"round\"\n  />\n  <line x1=\"12\" y1=\"9\" x2=\"12\" y2=\"14\" stroke=\"currentColor\" stroke-width=\"2.1\" stroke-linecap=\"round\"/>\n  <circle cx=\"12\" cy=\"17\" r=\"1.35\" fill=\"currentColor\"/>\n</svg>\n        </span>\n        <div class=\"tb-price__alert-title\">Promotion trompeuse chez EMMA</div>\n      </div>\n      <div class=\"tb-price__alert-body\">\n        Emma a été condamnée pour ses pratiques commerciales le 2 avril 2025.\n      </div>\n    </div>\n\n  </div>\n\n  <style>\n  .tb-price{\n    --tb-bg:#010d27;\n    --tb-ink:#f5eee6;\n\n    --tb-left:#0e2b2f;\n    --tb-right:#2a3546;\n\n    --tb-tip-bg:rgba(1,13,39,.96);\n    --tb-tip-bd:rgba(245,238,230,.20);\n\n    --tb-alert-bg:#f3dfe2;\n    --tb-alert-ink:#2c2c2c;\n    --tb-alert-red:#d55b57;\n\n    background: var(--tb-bg);\n    color: var(--tb-ink);\n    padding: 28px 16px 34px;\n    overflow: hidden;\n  }\n\n  .tb-price__inner{\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  /* ===== Title ===== */\n  .tb-price__head{\n    display:flex;\n    justify-content:center;\n    margin-bottom: 16px;\n    text-align:center;\n  }\n\n  .tb-price__title{\n    margin:0;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    text-transform:uppercase;\n    letter-spacing:.02em;\n    font-weight:900;\n    line-height:1;\n    font-size: 28px;\n    font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n  }\n\n  /* ===== Tooltip ===== */\n  .tb-price__info-wrap{\n    position:relative;\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .tb-price__info-btn{\n    appearance:none;\n    border:0;\n    background:transparent;\n    color: rgba(245,238,230,.92);\n    padding:2px;\n    border-radius:999px;\n    cursor:pointer;\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    line-height:0;\n    transform: translateY(1px);\n  }\n  .tb-price__info-btn:focus{\n    outline:2px solid rgba(245,238,230,.65);\n    outline-offset:2px;\n  }\n\n  .tb-price__tooltip{\n    position:absolute;\n    top: calc(100% + 10px);\n    left: 0;\n    z-index: 5;\n\n    width: max-content;\n    max-width: min(320px, calc(100vw - 24px));\n    padding: 10px 10px;\n    border-radius: 10px;\n\n    background: var(--tb-tip-bg);\n    border: 1px solid var(--tb-tip-bd);\n    box-shadow: 0 16px 40px rgba(0,0,0,.35);\n\n    font-size: 12px;\n    line-height: 1.3;\n    font-weight: 600;\n    color: var(--tb-ink);\n    text-transform: none;\n    letter-spacing: 0;\n\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity .12s ease, transform .12s ease;\n\n    transform: translate3d(var(--tb-tip-x, 0px), -2px, 0);\n  }\n\n  .tb-price__info-wrap.is-open .tb-price__tooltip{\n    opacity: 1;\n    pointer-events: auto;\n    transform: translate3d(var(--tb-tip-x, 0px), 0, 0);\n  }\n\n  .tb-price__tooltip::before{\n    content:\"\";\n    position:absolute;\n    top:-6px;\n    left: var(--tb-tip-arrow, 50%);\n    transform: translateX(-50%) rotate(45deg);\n    width: 10px;\n    height: 10px;\n    background: var(--tb-tip-bg);\n    border-left: 1px solid var(--tb-tip-bd);\n    border-top: 1px solid var(--tb-tip-bd);\n  }\n\n  /* ===== Cards (equal height) ===== */\n  .tb-price__cards{\n    width:100%;\n    display:grid;\n    grid-template-columns: minmax(0,1fr) minmax(0,1fr);\n    gap: 12px;\n    margin-bottom: 18px;\n    align-items: stretch; /* important */\n  }\n\n  .tb-price__card{\n    border-radius: 4px;\n    padding: 14px 12px 16px;\n    min-width: 0;\n    height: 100%;\n\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    text-align:center;\n    gap: 6px;\n  }\n\n  .tb-price__card--left{ background: var(--tb-left); }\n  .tb-price__card--right{ background: var(--tb-right); }\n\n  .tb-price__card-price{\n    font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n    font-weight: 900;\n    text-transform: uppercase;\n    font-size: 14px;\n    line-height: 1.15;\n    letter-spacing: .01em;\n  }\n\n  .tb-price__card-sub{\n    font-weight: 600;\n    font-size: 12px;\n    line-height: 1.25;\n    opacity: .96;\n  }\n\n  /* ===== Body text ===== */\n  .tb-price__text{\n    font-size: 14px;\n    line-height: 1.35;\n    font-weight: 500;\n    letter-spacing: -0.01em;\n    margin: 0 0 16px;\n    max-width: 60ch;\n  }\n\n  .tb-price__text strong{ font-weight: 900; }\n\n  .tb-price__u{\n    text-decoration: underline;\n    text-underline-offset: 3px;\n    text-decoration-thickness: 2px;\n  }\n\n  /* ===== Alert ===== */\n  .tb-price__alert{\n    background: var(--tb-alert-bg);\n    color: var(--tb-alert-ink);\n    border-radius: 10px;\n    padding: 16px;\n    max-width: 520px;\n  }\n\n  .tb-price__alert-head{\n    display:flex;\n    align-items:center;\n    gap: 12px;\n    margin-bottom: 8px;\n    color: var(--tb-alert-red);\n  }\n\n  .tb-price__alert-ico{\n    display:inline-flex;\n    width: 30px;\n    height: 30px;\n    align-items:center;\n    justify-content:center;\n    flex: 0 0 auto;\n  }\n\n  .tb-price__alert-title{\n    font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n    font-weight: 900;\n    font-size: 14px;\n    line-height: 1.2;\n    text-align:left;\n  }\n\n  .tb-price__alert-body{\n    font-size: 14px;\n    line-height: 1.35;\n    font-weight: 500;\n    color: rgba(0,0,0,.70);\n    text-align:left;\n  }\n\n  @media (min-width: 990px){\n    .tb-price{ padding: 44px 40px 48px; }\n    .tb-price__tooltip{ max-width: 360px; }\n  }\n</style>\n\n<script>\n  (function(){\n    var root = document.currentScript && document.currentScript.closest('.tb-price');\n    if(!root) return;\n\n    /* ===== Tooltip ===== */\n    var openWrap = null;\n    var closeTimer = null;\n\n    function closeTooltip(wrap){\n      if(!wrap) return;\n      wrap.classList.remove('is-open');\n      var tip = wrap.querySelector('.tb-price__tooltip');\n      if(tip) tip.setAttribute('aria-hidden', 'true');\n      if(openWrap === wrap) openWrap = null;\n    }\n\n    function positionTooltip(wrap){\n      var tip = wrap.querySelector('.tb-price__tooltip');\n      if(!tip) return;\n\n      var padding = 12;\n\n      var wrapRect = wrap.getBoundingClientRect();\n      var tipRect = tip.getBoundingClientRect();\n\n      var centerX = wrapRect.left + (wrapRect.width / 2);\n      var tipW = tipRect.width;\n\n      var minLeft = padding;\n      var maxLeft = window.innerWidth - padding - tipW;\n\n      var desiredLeft = centerX - (tipW / 2);\n      var finalLeft = Math.max(minLeft, Math.min(maxLeft, desiredLeft));\n\n      var x = finalLeft - wrapRect.left;\n      wrap.style.setProperty('--tb-tip-x', x + 'px');\n\n      var arrowX = centerX - finalLeft;\n      var arrowClamped = Math.max(14, Math.min(tipW - 14, arrowX));\n      wrap.style.setProperty('--tb-tip-arrow', arrowClamped + 'px');\n    }\n\n    function openTooltip(wrap){\n      if(openWrap && openWrap !== wrap) closeTooltip(openWrap);\n      openWrap = wrap;\n\n      wrap.classList.add('is-open');\n      var tip = wrap.querySelector('.tb-price__tooltip');\n      if(tip) tip.setAttribute('aria-hidden', 'false');\n\n      window.requestAnimationFrame(function(){\n        positionTooltip(wrap);\n      });\n    }\n\n    function scheduleClose(wrap){\n      window.clearTimeout(closeTimer);\n      closeTimer = window.setTimeout(function(){ closeTooltip(wrap); }, 120);\n    }\n\n    root.addEventListener('click', function(e){\n      var btn = e.target.closest('[data-tooltip-trigger]');\n      if(btn){\n        e.preventDefault();\n        e.stopPropagation();\n        var wrap = btn.closest('.tb-price__info-wrap');\n        if(!wrap) return;\n\n        if(wrap.classList.contains('is-open')) closeTooltip(wrap);\n        else openTooltip(wrap);\n        return;\n      }\n\n      if(openWrap && !e.target.closest('.tb-price__info-wrap')){\n        closeTooltip(openWrap);\n      }\n    });\n\n    var wraps = Array.prototype.slice.call(root.querySelectorAll('.tb-price__info-wrap'));\n    wraps.forEach(function(wrap){\n      wrap.addEventListener('mouseenter', function(){\n        window.clearTimeout(closeTimer);\n        openTooltip(wrap);\n      });\n      wrap.addEventListener('mouseleave', function(){\n        scheduleClose(wrap);\n      });\n    });\n\n    document.addEventListener('keydown', function(e){\n      if(e.key === 'Escape' && openWrap) closeTooltip(openWrap);\n    });\n\n    window.addEventListener('resize', function(){\n      if(openWrap) positionTooltip(openWrap);\n    });\n\n    /* ===== Equalize cards height (robust, matches other sections) ===== */\n    function equalizeCards(){\n      var cardsWrap = root.querySelector('[data-eq-grid]');\n      if(!cardsWrap) return;\n\n      var cards = Array.prototype.slice.call(cardsWrap.querySelectorAll('.tb-price__card'));\n      if(cards.length < 2) return;\n\n      // reset\n      cards.forEach(function(c){ c.style.minHeight = ''; });\n\n      // measure\n      var maxH = 0;\n      cards.forEach(function(c){\n        var h = c.offsetHeight;\n        if(h > maxH) maxH = h;\n      });\n\n      // apply\n      cards.forEach(function(c){ c.style.minHeight = maxH + 'px'; });\n    }\n\n    equalizeCards();\n    window.addEventListener('resize', equalizeCards);\n    window.setTimeout(equalizeCards, 80);\n    window.setTimeout(equalizeCards, 300);\n    if(document.fonts && document.fonts.ready){\n      document.fonts.ready.then(equalizeCards).catch(function(){});\n    }\n  })();\n</script>\n</section>",
