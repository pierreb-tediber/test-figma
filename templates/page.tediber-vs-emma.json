      "settings": {
        "custom_liquid": "{%- comment -%}\n  TB Compare - 3 CTA cards (mobile proportions + fixed centered separator)\n  For Custom Liquid (no schema)\n{%- endcomment -%}\n\n{%- assign tb_logo = 'https://cdn.shopify.com/s/files/1/0903/1342/5220/files/logo_horizontal_blanc_9f782eb1-ab3e-493d-9abb-43b8b960f501.svg?v=1762799224' -%}\n{%- assign emma_logo = 'https://cdn.shopify.com/s/files/1/0903/1342/5220/files/emma-logo.png?v=1751554118' -%}\n\n{%- assign c1_anchor = '#shopify-section-template--26685462643012__custom_liquid_FJy7MM' -%}\n{%- assign c1_left_title = 'Hybride' -%}\n{%- assign c1_right_title = 'Original Lite' -%}\n\n{%- assign c2_anchor = '#shopify-section-template--26685462643012__custom_liquid_dGcJcG' -%}\n{%- assign c2_left_title = 'Hybride Premium' -%}\n{%- assign c2_right_title = 'Original' -%}\n\n{%- assign c3_anchor = '#shopify-section-template--26685462643012__custom_liquid_X3idne' -%}\n{%- assign c3_left_title = 'Hybride Infinite' -%}\n{%- assign c3_right_title = 'Original Pro' -%}\n\n<center><h2>QUEL MATELAS SOUHAITEZ-VOUS COMPARER ?</h2></center>\n<div class=\"tb-compare-cards\" role=\"navigation\" aria-label=\"Accès rapide aux comparaisons\">\n  <a class=\"tb-compare-card\" href=\"{{ c1_anchor }}\" aria-label=\"Aller à la section {{ c1_left_title }} vs {{ c1_right_title }}\">\n    <span class=\"tb-compare-card__col tb-compare-card__col--left\">\n      <img class=\"tb-compare-card__logo tb-compare-card__logo--tb\" src=\"{{ tb_logo }}\" alt=\"Tediber\" loading=\"lazy\">\n      <span class=\"tb-compare-card__title\">{{ c1_left_title }}</span>\n    </span>\n\n    <span class=\"tb-compare-card__mid\" aria-hidden=\"true\">\n      <span class=\"tb-compare-card__bar\"></span>\n      <span class=\"tb-compare-card__swords\">⚔️</span>\n      <span class=\"tb-compare-card__bar\"></span>\n    </span>\n\n    <span class=\"tb-compare-card__col tb-compare-card__col--right\">\n      <img class=\"tb-compare-card__logo tb-compare-card__logo--emma\" src=\"{{ emma_logo }}\" alt=\"Emma\" loading=\"lazy\">\n      <span class=\"tb-compare-card__title\">{{ c1_right_title }}</span>\n    </span>\n  </a>\n\n  <a class=\"tb-compare-card\" href=\"{{ c2_anchor }}\" aria-label=\"Aller à la section {{ c2_left_title }} vs {{ c2_right_title }}\">\n    <span class=\"tb-compare-card__col tb-compare-card__col--left\">\n      <img class=\"tb-compare-card__logo tb-compare-card__logo--tb\" src=\"{{ tb_logo }}\" alt=\"Tediber\" loading=\"lazy\">\n      <span class=\"tb-compare-card__title\">{{ c2_left_title }}</span>\n    </span>\n\n    <span class=\"tb-compare-card__mid\" aria-hidden=\"true\">\n      <span class=\"tb-compare-card__bar\"></span>\n      <span class=\"tb-compare-card__swords\">⚔️</span>\n      <span class=\"tb-compare-card__bar\"></span>\n    </span>\n\n    <span class=\"tb-compare-card__col tb-compare-card__col--right\">\n      <img class=\"tb-compare-card__logo tb-compare-card__logo--emma\" src=\"{{ emma_logo }}\" alt=\"Emma\" loading=\"lazy\">\n      <span class=\"tb-compare-card__title\">{{ c2_right_title }}</span>\n    </span>\n  </a>\n\n  <a class=\"tb-compare-card\" href=\"{{ c3_anchor }}\" aria-label=\"Aller à la section {{ c3_left_title }} vs {{ c3_right_title }}\">\n    <span class=\"tb-compare-card__col tb-compare-card__col--left\">\n      <img class=\"tb-compare-card__logo tb-compare-card__logo--tb\" src=\"{{ tb_logo }}\" alt=\"Tediber\" loading=\"lazy\">\n      <span class=\"tb-compare-card__title\">{{ c3_left_title }}</span>\n    </span>\n\n    <span class=\"tb-compare-card__mid\" aria-hidden=\"true\">\n      <span class=\"tb-compare-card__bar\"></span>\n      <span class=\"tb-compare-card__swords\">⚔️</span>\n      <span class=\"tb-compare-card__bar\"></span>\n    </span>\n\n    <span class=\"tb-compare-card__col tb-compare-card__col--right\">\n      <img class=\"tb-compare-card__logo tb-compare-card__logo--emma\" src=\"{{ emma_logo }}\" alt=\"Emma\" loading=\"lazy\">\n      <span class=\"tb-compare-card__title\">{{ c3_right_title }}</span>\n    </span>\n  </a>\n</div>\n\n<style>\n  .tb-compare-cards{\n    --tb-card-bg:#f6efe8;\n    --tb-card-ink:#06132b;\n    --tb-card-line:rgba(6,19,43,.35);\n\n    display:grid;\n    gap:16px;\n    margin:18px auto;\n    max-width:980px;\n    padding:0 16px;\n  }\n\n  /* ✅ GRID 3 colonnes: centre toujours fixe */\n  .tb-compare-card{\n    display:grid;\n    grid-template-columns: 1fr 44px 1fr; /* colonne centrale fixe */\n    align-items:center;\n    column-gap:14px;\n\n    background:var(--tb-card-bg);\n    color:var(--tb-card-ink);\n    text-decoration:none;\n\n    border-radius:12px;\n    padding:14px 16px;\n  }\n\n  .tb-compare-card:focus{\n    outline:2px solid rgba(6,19,43,.45);\n    outline-offset:3px;\n  }\n\n  .tb-compare-card__col{\n    display:grid;\n    gap:8px;\n    min-width:0;\n  }\n\n  .tb-compare-card__col--left{justify-items:start;}\n  .tb-compare-card__col--right{justify-items:start;} /* logo + titre alignés comme sur capture */\n\n  .tb-compare-card__logo{\n    height:18px;\n    width:auto;\n    display:block;\n  }\n\n  /* ✅ proportions mobile (plus proche de ta capture) */\n  .tb-compare-card__title{\n    font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n    font-weight:800;\n    font-size: clamp(16px, 3.6vw, 20px);\n    line-height:1.05;\n    letter-spacing:-0.01em;\n\n    /* important: ne pousse pas la colonne centrale */\n    overflow:hidden;\n    text-overflow:ellipsis;\n    white-space:nowrap;\n  }\n\n  .tb-compare-card__mid{\n    display:grid;\n    justify-items:center;\n    align-items:center;\n    gap:8px;\n  }\n\n  .tb-compare-card__bar{\n    width:2px;\n    height:22px;\n    background:var(--tb-card-line);\n    border-radius:2px;\n    display:block;\n  }\n\n  .tb-compare-card__swords{\n    font-size:20px;\n    line-height:1;\n    transform: translateY(-1px);\n  }\n\n  /* Si un titre est vraiment long, on autorise le retour à la ligne sur très petits écrans */\n  @media (max-width: 380px){\n    .tb-compare-card{\n      grid-template-columns: 1fr 40px 1fr;\n      column-gap:10px;\n      padding:12px 14px;\n    }\n    .tb-compare-card__title{\n      white-space:normal;\n      display:-webkit-box;\n      -webkit-line-clamp:2;\n      -webkit-box-orient:vertical;\n    }\n    .tb-compare-card__logo{height:16px;}\n    .tb-compare-card__bar{height:20px;}\n    .tb-compare-card__swords{font-size:18px;}\n  }\n\n@media (min-width: 1024px){\n  .tb-compare-cards{\n    grid-template-columns: repeat(3, 1fr);\n    gap: 24px;\n\n    max-width: none;\n    padding: 0 40px; /* respiration desktop */\n  }\n\n  .tb-compare-card{\n    padding: 22px 24px;\n  }\n\n  .tb-compare-card__title{\n  font-size: 20px;\n\n  white-space: normal;\n  display: -webkit-box;\n  -webkit-line-clamp: 2;   /* max 2 lignes */\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n}\n}\n\n</style>",
