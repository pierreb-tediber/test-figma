ent:center;\n      font-size:18px;line-height:1;opacity:.95;\n    }\n\n    .tb-compare-hero__title{\n      margin:0 auto 14px;text-align:center;text-transform:uppercase;letter-spacing:.02em;\n      font-weight:900;color:var(--tb-ink-strong);\n      font-size:clamp(44px,8.2vw,72px);\n      line-height:.92;\n    }\n    .tb-compare-hero__subtitle{\n      margin:0 auto 22px;text-align:center;font-weight:800;color:var(--tb-ink);\n      font-size:clamp(18px,3.8vw,28px);\n      line-height:1.15;max-width:26ch;\n    }\n\n    /* ✅ Mobile: image + liste côte à côte */\n    .tb-compare-hero__mid{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:16px;\n      margin-top:6px;\n    }\n    .tb-compare-hero__visual{\n      flex:0 0 46%;\n      display:flex;\n      justify-content:center;\n      align-items:center;\n    }\n    .tb-compare-hero__visual-img{\n      width:100%;\n      max-width:260px;\n      height:auto;\n      display:block;\n      filter:drop-shadow(0 18px 38px rgba(0,0,0,.35));\n    }\n    .tb-compare-hero__points{\n      flex:1 1 54%;\n      padding-top:6px;\n      min-width: 0;\n    }\n\n    .tb-compare-hero__points-brand{display:flex;justify-content:center;margin-bottom:12px;}\n    .tb-compare-hero__points-brand-logo{height:26px;width:auto;display:block;opacity:.98;}\n\n    .tb-compare-hero__list{margin:0;padding:0;list-style:none;border-top:1px solid var(--tb-divider);}\n    .tb-compare-hero__item{\n      display:grid;grid-template-columns:30px 1fr;gap:12px;align-items:center;\n      padding:18px 0;border-bottom:1px solid var(--tb-divider);\n    }\n    .tb-compare-hero__check{color:var(--tb-check);display:inline-flex;width:24px;height:24px;align-items:center;justify-content:center;transform:translateY(-1px);}\n    .tb-compare-hero__item-text{\n      text-transform:uppercase;font-weight:900;letter-spacing:.01em;color:var(--tb-ink-strong);\n      font-size:clamp(14px,4.2vw,24px);\n      line-height:1.05;\n    }\n\n    .tb-compare-hero__hint{\n      text-align:center;margin:18px 0 12px;font-weight:800;color:var(--tb-ink);\n      font-size:clamp(16px,3.5vw,20px);\n    }\n    .tb-compare-hero__cta{display:flex;justify-content:center;margin-top:8px;}\n\n    /* ✅ CTA: radius 4px + 16px + Obviously Narrow Bold */\n    .tb-compare-hero__btn{\n      width:100%;\n      max-width:520px;\n      background:var(--tb-btn-bg);\n      color:var(--tb-btn-ink);\n      text-decoration:none;\n      text-align:center;\n\n      border-radius:4px;\n      padding:16px 18px;\n\n      font-size:16px;\n      line-height:1;\n      font-weight:800;\n      font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n\n      box-shadow:0 10px 30px rgba(0,0,0,.25);\n    }\n    .tb-compare-hero__btn:focus{outline:2px solid rgba(245,238,230,.75);outline-offset:3px;}\n\n    /* Très petits écrans : on repasse en colonne pour éviter la casse */\n    @media (max-width: 360px){\n      .tb-compare-hero__mid{flex-direction:column;}\n      .tb-compare-hero__visual,\n      .tb-compare-hero__points{flex:1 1 auto;width:100%;}\n      .tb-compare-hero__visual-img{max-width:320px;}\n    }\n\n    @media (min-width: 990px){\n      .tb-compare-hero{padding:42px 24px 54px;}\n      .tb-compare-hero__subtitle{max-width:40ch;}\n      .tb-compare-hero__mid{gap:34px;margin-top:18px;}\n      .tb-compare-hero__visual{justify-content:flex-start;flex-basis:40%;}\n      .tb-compare-hero__visual-img{max-width:360px;}\n      .tb-compare-hero__points-brand{justify-content:flex-start;}\n      .tb-compare-hero__hint{margin-top:24px;}\n    }\n  </style>\n</section>",
