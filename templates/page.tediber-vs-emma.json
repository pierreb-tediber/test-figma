        "custom_liquid": "<style>\n.image-block-fomo {\n  background:#010C27;\n  display:flex;\n  justify-content:center;\n  align-items:center;\n  width:100%;\n  padding:20px 0;\n}\n\n.image-block-fomo img{\n  max-height:350px;\n  width:auto;\n  max-width:100%;\n  display:block;\n}\n\n/* Mobile */\n@media (max-width: 749px){\n  .image-block-fomo img{\n    max-height:600px;\n  }\n}\n</style>\n\n<div class=\"image-block-fomo\">\n  <img \n  src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/hybride_premium_vs_original.png?v=1772816599\"\n    alt=\"Image\"\n    loading=\"lazy\"\n  >\n</div>",
