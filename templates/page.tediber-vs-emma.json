      "settings": {
        "custom_liquid": "{%- comment -%}\n  TB Compare — CRITÈRES QUALITÉ\n  Custom Liquid (no schema)\n{%- endcomment -%}\n\n{%- assign section_title = 'CRITÈRES QUALITÉ' -%}\n{%- assign winner_text = 'Gagnant : Hybride Infinite' -%}\n\n<section class=\"tb-quality\" role=\"region\" aria-label=\"{{ section_title | escape }}\">\n  <div class=\"tb-quality__inner\">\n\n    <div class=\"tb-quality__head\">\n      <h2 class=\"tb-quality__title\">{{ section_title }}</h2>\n\n      <div class=\"tb-quality__winner\" aria-label=\"{{ winner_text | escape }}\">\n        <span class=\"tb-quality__medal\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 40 40\" width=\"28\" height=\"28\" focusable=\"false\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"tbGoldQuality\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#f7d47a\"/>\n                <stop offset=\"0.55\" stop-color=\"#d4a93a\"/>\n                <stop offset=\"1\" stop-color=\"#f7d47a\"/>\n              </linearGradient>\n            </defs>\n            <path d=\"M13 4h7l-4 10H9L13 4Z\" fill=\"#b24b45\"/>\n            <path d=\"M20 4h7l4 10h-7L20 4Z\" fill=\"#3b6db2\"/>\n            <circle cx=\"20\" cy=\"22\" r=\"10.5\" fill=\"url(#tbGoldQuality)\" stroke=\"#c5972f\" stroke-width=\"1.5\"/>\n            <circle cx=\"20\" cy=\"22\" r=\"6.4\" fill=\"none\" stroke=\"#b8861f\" stroke-width=\"1.4\" opacity=\"0.7\"/>\n            <path d=\"M20 16.5l1.7 3.7 4 .5-3 2.7.9 4-3.6-2.1-3.6 2.1.9-4-3-2.7 4-.5L20 16.5Z\" fill=\"#8b6511\" opacity=\"0.9\"/>\n          </svg>\n        </span>\n        <span class=\"tb-quality__winner-text\">{{ winner_text }}</span>\n      </div>\n    </div>\n\n    <div class=\"tb-quality__grid\" data-eq-grid>\n      <!-- LEFT CARD -->\n      <article class=\"tb-quality__card tb-quality__card--left\">\n        <div class=\"tb-quality__block tb-quality__block--top\">\n          <span class=\"tb-quality__icon tb-quality__icon--star\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"24\" height=\"24\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M12 2.8l2.6 5.3 5.9.9-4.2 4.1 1 5.8L12 16.1 6.7 18.9l1-5.8L3.5 9l5.9-.9L12 2.8Z\" fill=\"currentColor\"/>\n            </svg>\n          </span>\n\n          <div class=\"tb-quality__rating\">\n            5/5\n            <small>sur 4 avis (au 27/02/2026)</small>\n          </div>\n        </div>\n\n        <div class=\"tb-quality__divider\" aria-hidden=\"true\"></div>\n\n        <div class=\"tb-quality__block\">\n          <span class=\"tb-quality__icon tb-quality__icon--flag\" aria-hidden=\"true\">\n  <svg viewBox=\"0 0 24 24\" width=\"24\" height=\"24\" focusable=\"false\" aria-hidden=\"true\">\n    <defs>\n      <clipPath id=\"circle-flag\">\n        <circle cx=\"12\" cy=\"12\" r=\"10\"></circle>\n      </clipPath>\n    </defs>\n\n    <g clip-path=\"url(#circle-flag)\">\n      <!-- bleu -->\n      <rect x=\"2\" y=\"2\" width=\"6.67\" height=\"20\" fill=\"#1f4fa3\"/>\n      <!-- blanc -->\n      <rect x=\"8.67\" y=\"2\" width=\"6.67\" height=\"20\" fill=\"#ffffff\"/>\n      <!-- rouge -->\n      <rect x=\"15.34\" y=\"2\" width=\"6.67\" height=\"20\" fill=\"#d94c4c\"/>\n    </g>\n\n    <!-- contour du cercle -->\n    <circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"/>\n  </svg>\n</span>\n\n          <div class=\"tb-quality__label\">Fabrication française</div>\n          <div class=\"tb-quality__desc\">Garantit le respect des normes de qualité strictes</div>\n        </div>\n\n        <div class=\"tb-quality__divider\" aria-hidden=\"true\"></div>\n\n        <div class=\"tb-quality__block tb-quality__block--bottom\">\n          <span class=\"tb-quality__icon tb-quality__icon--ok\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"22\" height=\"22\" focusable=\"false\" aria-hidden=\"true\">\n              <circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"currentColor\"/>\n              <path d=\"M10.3 15.8 6.9 12.4a1 1 0 1 1 1.4-1.4l2 2 5.4-5.4a1 1 0 0 1 1.4 1.4l-6.1 6.1a1 1 0 0 1-1.4 0Z\" fill=\"#fff\"/>\n            </svg>\n          </span>\n\n          <div class=\"tb-quality__label\">Réparable</div>\n          <div class=\"tb-quality__desc\">Permet de garder le matelas plus de 10 ans</div>\n        </div>\n      </article>\n\n      <!-- RIGHT CARD -->\n      <article class=\"tb-quality__card tb-quality__card--right\">\n        <div class=\"tb-quality__block tb-quality__block--top\">\n          <span class=\"tb-quality__icon tb-quality__icon--star\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"24\" height=\"24\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M12 2.8l2.6 5.3 5.9.9-4.2 4.1 1 5.8L12 16.1 6.7 18.9l1-5.8L3.5 9l5.9-.9L12 2.8Z\" fill=\"currentColor\"/>\n            </svg>\n          </span>\n\n          <div class=\"tb-quality__rating\">\n            4,1/5\n            <small>sur 265 avis (au 27/02/2026)</small>\n          </div>\n        </div>\n\n        <div class=\"tb-quality__divider\" aria-hidden=\"true\"></div>\n\n        <div class=\"tb-quality__block\">\n          <span class=\"tb-quality__icon tb-quality__icon--unknown\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"24\" height=\"24\" focusable=\"false\" aria-hidden=\"true\">\n              <path d=\"M12 21c-3.5-2.7-6-5.7-6-9.4A6 6 0 0 1 12 5.6a6 6 0 0 1 6 6c0 3.7-2.5 6.7-6 9.4Z\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n              <path d=\"M10.8 10.2a1.7 1.7 0 1 1 2.6 1.5c-.9.6-1.2 1-1.2 1.8\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n              <circle cx=\"12\" cy=\"16.3\" r=\"1\" fill=\"currentColor\"/>\n            </svg>\n          </span>\n\n          <div class=\"tb-quality__label\">Lieu de fabrication inconnu</div>\n          <div class=\"tb-quality__desc\">Respect des normes de qualité incertaine</div>\n        </div>\n\n        <div class=\"tb-quality__divider\" aria-hidden=\"true\"></div>\n\n        <div class=\"tb-quality__block tb-quality__block--bottom\">\n          <span class=\"tb-quality__icon tb-quality__icon--no\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 24 24\" width=\"22\" height=\"22\" focusable=\"false\" aria-hidden=\"true\">\n              <circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"currentColor\"/>\n              <path d=\"M8 8l8 8M16 8l-8 8\" stroke=\"#fff\" stroke-width=\"2.2\" stroke-linecap=\"round\"/>\n            </svg>\n          </span>\n\n          <div class=\"tb-quality__label\">Non réparable</div>\n          <div class=\"tb-quality__desc\">Matelas gardé moins longtemps</div>\n        </div>\n      </article>\n    </div>\n\n  </div>\n\n  <style>\n    .tb-quality{\n      --tb-bg:#010d27;\n      --tb-ink:#f5eee6;\n      --tb-gold:#e7c06a;\n      --tb-left:#0e2b2f;\n      --tb-right:#2a3546;\n      --tb-divider:rgba(245,238,230,.08);\n      --tb-star:#f1c24a;\n      --tb-ok:#1f7a55;\n      --tb-no:#d55b57;\n\n      color: var(--tb-ink);\n      background: var(--tb-bg);\n      padding: 24px 20px 24px 20px;\n      overflow: hidden;\n      padding-left: 0 !important;\n      padding-right: 0 !important;\n    }\n\n    .tb-quality__inner{\n      max-width: 1100px;\n      margin: 0 auto;\n    }\n\n    .tb-quality__head{\n      display:grid;\n      justify-items:center;\n      gap: 12px;\n      text-align:center;\n      margin-bottom: 14px;\n    }\n\n    .tb-quality__title{\n      margin:0;\n      text-transform:uppercase;\n      letter-spacing:.02em;\n      font-weight:900;\n      line-height:1;\n      font-size:28px;\n      color: var(--tb-ink);\n      font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n    }\n\n    .tb-quality__winner{\n      display:inline-flex;\n      align-items:center;\n      gap:10px;\n      padding:10px 14px;\n      border-radius:6px;\n      border:2px solid var(--tb-gold);\n      background: rgba(1,13,39,.10);\n      max-width:100%;\n    }\n\n    .tb-quality__medal{\n      display:inline-flex;\n      width:24px;\n      height:24px;\n      align-items:center;\n      justify-content:center;\n      transform: translateY(1px);\n      flex:0 0 auto;\n    }\n    .tb-quality__medal svg{ width:24px; height:24px; }\n\n    .tb-quality__winner-text{\n      font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n      font-weight:800;\n      font-size:14px;\n      line-height:1.1;\n      color: var(--tb-ink);\n      white-space:nowrap;\n      overflow:hidden;\n      text-overflow:ellipsis;\n      max-width:78vw;\n    }\n\n    .tb-quality__grid{\n      display:grid;\n      grid-template-columns:minmax(0,1fr) minmax(0,1fr);\n      gap:12px;\n      width:100%;\n      align-items:stretch;\n    }\n\n    .tb-quality__card{\n      border-radius:4px;\n      overflow:hidden;\n      min-width:0;\n      display:flex;\n      flex-direction:column;\n      height:100%;\n    }\n\n    .tb-quality__card--left{ background: var(--tb-left); }\n    .tb-quality__card--right{ background: var(--tb-right); }\n\n    .tb-quality__block{\n      display:flex;\n      flex-direction:column;\n      align-items:center;\n      justify-content:center;\n      text-align:center;\n      padding:18px 12px;\n      min-height:118px;\n    }\n\n    .tb-quality__block--top{ min-height:126px; }\n    .tb-quality__block--bottom{ min-height:126px; }\n\n    .tb-quality__divider{\n      width:100%;\n      height:1px;\n      background: var(--tb-divider);\n    }\n\n    .tb-quality__icon{\n      display:inline-flex;\n      align-items:center;\n      justify-content:center;\n      margin-bottom:10px;\n      color: var(--tb-ink);\n      flex:0 0 auto;\n    }\n\n    .tb-quality__icon--star{ color: var(--tb-star); }\n    .tb-quality__icon--ok{ color: var(--tb-ok); }\n    .tb-quality__icon--no{ color: var(--tb-no); }\n\n    .tb-quality__rating{\n      font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n      font-weight:900;\n      font-size:20px;\n      line-height:1.05;\n    }\n\n    .tb-quality__rating small{\n      display:block;\n      margin-top:8px;\n      font-family:inherit;\n      font-size:12px;\n      font-weight:600;\n      line-height:1.25;\n      opacity:.96;\n    }\n\n    .tb-quality__info-inline{\n      display:inline-flex;\n      align-items:center;\n      justify-content:center;\n      width:14px;\n      height:14px;\n      border:1.5px solid currentColor;\n      border-radius:999px;\n      font-size:9px;\n      font-weight:800;\n      line-height:1;\n      transform: translateY(-1px);\n      margin-left:3px;\n    }\n\n    .tb-quality__label{\n      font-weight:900;\n      font-size:14px;\n      line-height:1.15;\n      letter-spacing:-0.01em;\n      max-width:12ch;\n      font-family:\"Obviously Narrow\",\"Obviously\",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;\n    }\n\n    .tb-quality__desc{\n      margin-top:8px;\n      font-weight:600;\n      font-size:12px;\n      line-height:1.25;\n      opacity:0.95;\n      max-width:16ch;\n    }\n\n    @media (min-width: 990px){\n      .tb-quality__grid{ gap:16px; }\n      .tb-quality__block{\n        padding:18px 14px;\n        min-height:132px;\n      }\n      .tb-quality__block--top,\n      .tb-quality__block--bottom{\n        min-height:140px;\n      }\n      .tb-quality__title{ font-size:32px; }\n      .tb-quality__winner-text{ max-width:none; font-size:16px; }\n      .tb-quality__rating{ font-size:24px; }\n      .tb-quality__rating small{ font-size:14px; }\n      .tb-quality__label{ font-size:16px; }\n      .tb-quality__desc{ font-size:14px; }\n    }\n  </style>\n\n  <script>\n    (function(){\n      var root = document.currentScript && document.currentScript.closest('.tb-quality');\n      if(!root) return;\n\n      var grid = root.querySelector('[data-eq-grid]');\n      if(!grid) return;\n\n      var cards = Array.prototype.slice.call(grid.querySelectorAll('.tb-quality__card'));\n      if(cards.length < 2) return;\n\n      function equalizeBlocks(){\n        var leftBlocks = Array.prototype.slice.call(cards[0].querySelectorAll('.tb-quality__block'));\n        var rightBlocks = Array.prototype.slice.call(cards[1].querySelectorAll('.tb-quality__block'));\n        var maxLen = Math.max(leftBlocks.length, rightBlocks.length);\n\n        leftBlocks.forEach(function(el){ el.style.minHeight = ''; });\n        rightBlocks.forEach(function(el){ el.style.minHeight = ''; });\n\n        for(var i=0;i<maxLen;i++){\n          var l = leftBlocks[i];\n          var r = rightBlocks[i];\n          if(!l || !r) continue;\n\n          var mh = Math.max(l.offsetHeight, r.offsetHeight);\n          l.style.minHeight = mh + 'px';\n          r.style.minHeight = mh + 'px';\n        }\n      }\n\n      equalizeBlocks();\n      window.addEventListener('resize', equalizeBlocks);\n      window.setTimeout(equalizeBlocks, 80);\n      window.setTimeout(equalizeBlocks, 300);\n      if(document.fonts && document.fonts.ready){\n        document.fonts.ready.then(equalizeBlocks).catch(function(){});\n      }\n\n    })();\n  </script>\n</section>",
