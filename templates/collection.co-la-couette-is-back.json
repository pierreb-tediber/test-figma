    "custom_liquid_P8Jab3": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!doctype html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>La couette. is. back. – Hero</title>\n  <style>\n    * { box-sizing: border-box; }\n    body { \n      margin: 0; \n      font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, Inter, Arial, sans-serif; \n    }\n    \n    .hero {\n      position: relative;\n      color: #fff !important; /* force la typo en blanc */\n      isolation: isolate;\n      overflow: hidden;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      min-height: clamp(220px, 25vw, 620px);\n      background-image: url(\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lacouetteisback_Hero-section-collection_desktop.jpg?v=1760351587\");\n      background-size: cover;\n      background-position: center;\n      background-repeat: no-repeat;\n    }\n\n    /* Overlay pour améliorer la lisibilité du texte sur l'image */\n    .hero::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background: linear-gradient(0deg, rgba(0,0,0,.35), rgba(0,0,0,.05));\n      z-index: 0;\n    }\n\n    .hero__inner {\n      position: relative;\n      z-index: 1;\n      max-width: 900px;\n      padding: 0 16px;\n    }\n\n    /* Forcer tout le texte à hériter du blanc */\n    .hero :is(h1,h2,h3,p,span,strong,em,a,small,li,.code,.subtitle,.title) {\n      color: inherit !important;\n    }\n\n    .title {\n      margin: 0;\n      line-height: .9;\n      font-weight: 800;\n      /* ↓ Réduction du titre desktop */\n      font-size: clamp(2.7rem, 6.5vw, 4.8rem);\n      letter-spacing: .02em;\n    }\n\n    .subtitle {\n      margin-top: clamp(6px, 1vw, 10px);\n      font-size: 16px; /* desktop */\n      font-weight: 700;\n      line-height: 1.1; /* réduit l’espacement vertical */\n    }\n\n    .results {\n      margin-top: clamp(6px, 2vw, 16px);\n      font-size: clamp(0.9rem, 1.9vw, 1.9rem);\n      font-weight: 700;\n    }\n\n    /* Mobile styles */\n    @media (max-width: 749px) {\n      .hero {\n        background-image: url(\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lacouetteisback_Hero-section-collection_mobile.jpg?v=1760444318\");\n      }\n      .title {\n        font-size: clamp(1.6rem, 8vw, 3rem); /* mobile inchangé */\n        line-height: 1;\n      }\n      .subtitle {\n        font-size: 12px; /* mobile */\n        margin-top: 4px;\n        line-height: 1.1;\n      }\n    }\n  </style>\n</head>\n<body>\n\n  <section class=\"hero\" aria-label=\"Promotion French Days\">\n    <div class=\"hero__inner\">\n      <h1 class=\"title\">La couette. is. back.</h1>\n      <p class=\"subtitle\">\n        (ET ELLE N'A PAS FROID AUX PIEDS)<br>\n        -10% DE RÉDUCTION AVEC LE PACK COUETTE ET OREILLERS\n      </p>\n    </div>\n  </section>\n\n</body>\n</html>",
