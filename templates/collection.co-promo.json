{\n  color:white;\n}\n\n.offer-exclusive-text{\n  font-weight:bold;\n}\n\n#countdown-french-days{\n  font-weight:bold;\n  color:white;\n}\n<\/style>\n\n<a href=\"\/collections\/promotions-tediber\" class=\"countdown-banner-french-days\">\n  <span class=\"offer-exclusive-text\">Offre exclusive<\/span>\n  <span id=\"countdown-french-days\"><\/span>\n<\/a>\n\n<script>\n\/\/ Fin de l'offre : 23 juin 2026 à 23h59\nconst endDateFrenchDays = new Date(\"2026-06-23T23:59:00\").getTime();\n\nfunction updateCountdownFrenchDays() {\n  const now = new Date().getTime();\n  const distance = endDateFrenchDays - now;\n\n  const el = document.getElementById(\"countdown-french-days\");\n\n  if (!el) return;\n\n  if (distance <= 0) {\n    el.innerHTML = \"- Offre terminée\";\n    return;\n  }\n\n  const days = Math.floor(distance \/ (1000 * 60 * 60 * 24));\n  const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) \/ (1000 * 60 * 60));\n  const minutes = Math.floor((distance % (1000 * 60 * 60)) \/ (1000 * 60));\n  const seconds = Math.floor((distance % (1000 * 60)) \/ 1000);\n\n  let text = \"- Plus que \";\n  if (days > 0) text += days + \"j \";\n  text += hours + \"h \" + minutes + \"m \" + seconds + \"s\";\n\n  el.innerHTML = text;\n}\n\nupdateCountdownFrenchDays();\nsetInterval(updateCountdownFrenchDays, 1000);\n<\/script>","color_scheme":"scheme-fd8a6b7f-fb17-41ee-ac65-43143a48e740","padding_top":16,"padding_bottom":16}},"custom_liquid_DmdBCm":{"type":"custom-liquid","disabled":true,"name":"Bannière Alma 10x","settings":{"custom_liquid":"<!-- Bannière – HTML pur -->\n<div class=\"banner-alma\" role=\"region\" aria-label=\"Offre exclusive limitée\">\n  <div class=\"banner-alma__inner\">\n\n    <!-- Texte desktop -->\n    <p class=\"banner-alma__text banner-alma__text--desktop\">\n      <strong>OFFRE EXCLUSIVE LIMITÉE*<\/strong>\n    <\/p>\n\n    <!-- Texte mobile -->\n    <p class=\"banner-alma__text banner-alma__text--mobile\">\n      <strong>OFFRE EXCLUSIVE LIMITÉE*<\/strong>