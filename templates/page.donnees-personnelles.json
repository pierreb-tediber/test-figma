    "ax_richtext_6biCGK": {
      "type": "ax-richtext",
      "blocks": {
        "heading_MGgmxh": {
          "type": "heading",
          "settings": {
            "heading": "<p>Est-ce que Tediber revend mes données personnelles ?</p>",
            "heading_size": "h2",
            "heading_alignment": "left"
          }
        },
        "text_zMtjTY": {
          "type": "text",
          "settings": {
            "text": "<p>Non, c’est totalement illégal ! Toutes les données personnelles que nous récoltons ne sont ni vendues et ni échangées à une société tierce. </p>",
            "text_alignment": "left"
          }
        }
      },
      "block_order": [
