    "ax_richtext_MkgApx": {
      "type": "ax-richtext",
      "blocks": {
        "heading_a7YD4z": {
          "type": "heading",
          "settings": {
            "heading": "<p>Qui est le responsable de traitement de mes données personnelles ? </p>",
            "heading_size": "h2",
            "heading_alignment": "left"
          }
        },
        "text_M4Pn6h": {
          "type": "text",
          "settings": {
            "text": "<p>Le responsable du traitement de mes données personnelles est la société Tediber dont l’adresse est 20 rue Sainte-Croix de la Bretonnerie 75004 Paris. Vous pouvez nous joindre par mail sur hello@tediber.com ou par téléphone au 01 86 95 47 10.<br/> L’adresse mail du Délégué à la Protection des Données (Céline) est dpo@tediber.com. </p>",
            "text_alignment": "left"
          }
        }
      },
      "block_order": [
