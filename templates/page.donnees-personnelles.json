    "ax_richtext_9QeXzn": {
      "type": "ax-richtext",
      "blocks": {
        "heading_giNeLH": {
          "type": "heading",
          "settings": {
            "heading": "<p>Pourquoi Tediber collecte mes données personnelles ?</p>",
            "heading_size": "h2",
            "heading_alignment": "left"
          }
        },
        "text_RhaGEk": {
          "type": "text",
          "settings": {
            "text": "<p>Tediber collecte vos données personnelles pour : - Traiter vos commandes et expéditions (confirmation de commande, suivi, facture, paiement etc.) - Réaliser un suivi de la relation client (demande d’avis, gestion des réclamations, service après-vente etc.) - Personnaliser les communications commerciales que nous vous adressons (mails, sms etc.) - Analyser et améliorer nos services (en analysant les statistiques concernant votre activité sur notre site notamment) </p>",
            "text_alignment": "left"
          }
        }
      },
      "block_order": [
        "heading_giNeLH",
        "text_RhaGEk"
      ],
      "name": "Ax richtext",
      "settings": {
        "restricted_width": false,
        "color_scheme": "",
        "color_scheme_container": "",
