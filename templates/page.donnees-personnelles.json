        "heading_LeWpxK": {
          "type": "heading",
          "settings": {
            "heading": "<p>Où sont situés les serveurs de Tediber ?</p>",
            "heading_size": "h2",
            "heading_alignment": "left"
          }
        },
        "text_7aKiBV": {
          "type": "text",
          "settings": {
            "text": "<p>Les serveurs de Tediber sont Netlify et Google.<br/> Netlify Adresse : 2325 3rd Street (Suite 296) 94107 San Francisco (California) Contact : support@netlify.com Site : netlify.com<br/> Google Adresse : 100 Rue de Ghlin 7331 Saint-Ghislain (Belgique) Contact : stghislain@google.com Site : google.com </p>",
            "text_alignment": "left"
          }
        }
      },
      "block_order": [
