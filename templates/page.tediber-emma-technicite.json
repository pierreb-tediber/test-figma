      "blocks": {
        "text_highlight_begiKb": {
          "type": "text_highlight",
          "settings": {
            "text": "<p>Cette page centralise l’ensemble des éléments factuels et données relevées dans le cadre du comparateur <a href=\"https://www.tediber.com/pages/matelas-hybride-vs-emma\" title=\"https://www.tediber.com/pages/matelas-hybride-vs-emma\">Tediber ou Emma</a>.</p>",
