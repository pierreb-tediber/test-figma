      "settings": {
        "custom_liquid": "<!-- Bannière 10× Alma – HTML pur -->\n<div class=\"banner-alma\" role=\"region\" aria-label=\"Paiement 10× Alma sans frais\">\n  <div class=\"banner-alma__inner\">\n    <span class=\"banner-alma__badge\" aria-hidden=\"true\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/Badge-Alma-orange-10x.svg?v=1758009341\" alt=\"10× Alma\" loading=\"lazy\" width=\"96\" height=\"28\">\n    </span>\n\n    <!-- Texte desktop -->\n    <p class=\"banner-alma__text banner-alma__text--desktop\">\n      Jusqu'au 1er décembre inclus, le paiement en <strong>10x sans frais est offert</strong>.\n    </p>\n\n    <!-- Texte mobile -->\n    <p class=\"banner-alma__text banner-alma__text--mobile\">\n       Jusqu'au 1er décembre inclus, le paiement en <strong>10x sans frais est offert</strong>.\n    </p>\n  </div>\n</div>\n\n<style>\n  :root {\n    --alma-blue: #010C27;\n    --alma-text: #ffffff;\n  }\n\n  .banner-alma {\n    background: var(--alma-blue);\n    color: var(--alma-text);\n    width: 100%;\n  }\n\n  .banner-alma__inner {\n    max-width: 1080px;\n    margin: 0 auto;\n    display: flex;                /* ✅ flex au lieu de grid */\n    justify-content: center;      /* ✅ centre horizontalement */\n    align-items: center;          /* aligne verticalement */\n    gap: 0.9rem;                  /* espace logo/texte */\n    padding: 0.75rem 0.4rem;\n    min-height: 56px;\n    text-align: center;           /* centre aussi le texte */\n  }\n\n  /* Badge */\n  .banner-alma__badge {\n    line-height: 0;\n    display: inline-flex;\n    align-items: center;\n  }\n  .banner-alma__badge img {\n    display: block;\n    height: 28px;\n    width: auto;\n  }\n\n  /* Texte */\n  .banner-alma__text {\n    margin: 4px;\n    line-height: 1.35;\n    font-size: 14px;\n    font-weight: 500;\n  }\n  .banner-alma__text strong { font-weight: 700; }\n\n  /* Cacher la version mobile par défaut */\n  .banner-alma__text--mobile { display: none; }\n\n  /* Responsive */\n  @media (max-width: 740px) {\n    .banner-alma__inner {\n      flex-direction: column;     /* ✅ passe en colonne */\n      justify-content: center;\n      gap: 0.55rem;\n      padding: 0.7rem 0.9rem;\n    }\n    .banner-alma__badge img { height: 28px; }\n    .banner-alma__text--desktop { display: none; }\n    .banner-alma__text--mobile { display: block; font-size: 12px; }\n  }\n</style>",
