em 1rem;\n  text-align: center;\n}\n.resume-express h2 {\n  font-size: 1.2rem;\n  font-weight: bold;\n  margin-bottom: 0.3rem;\n}\n.resume-express h3 {\n  font-size: 2rem;\n  font-weight: bold;\n  margin-bottom: 1rem;\n}\n.resume-express p {\n  font-size: 1rem;\n  color: #d1d5db;\n  margin-bottom: 1.5rem;\n}\n\n.comparatif-table {\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n  margin-bottom: 2rem;\n}\n.line {\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n}\n.logo-col {\n  flex-shrink: 0;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  width: 130px;\n}\n.logo-col img {\n  width: 80px;\n  height: auto;\n  margin-bottom: 0.5rem;\n}\n.vainqueur {\n  font-size: 0.85rem;\n  margin-top: 0.2rem;\n}\n.cell {\n  flex: 1;\n  background: #1d273f;\n  border-radius: 8px;\n  padding: 1rem;\n  font-size: 0.95rem;\n}\n\n/* Alert, CTA & Infos */\n.alert {\n  background: #f8d7da;\n  color: #721c24;\n  padding: 1rem;\n  border-radius: 8px;\n  max-width: 800px;\n  margin: 1rem auto 2rem;\n  font-size: 0.95rem;\n}\n.cta-button {\n  display: inline-block;\n  background: #fff;\n  color: #010C27;\n  font-weight: bold;\n  padding: 1rem 2rem;\n  border-radius: 8px;\n  text-decoration: none;\n  margin-bottom: 1.5rem;\n}\n.infos {\n  font-size: 0.9rem;\n  color: #d1d5db;\n}\n\n/* Responsive mobile */\n@media (max-width: 768px) {\n  .comparatif-table {\n    gap: 2rem;\n  }\n  .line {\n    flex-direction: column;\n    align-items: center;\n  }\n  .logo-col {\n    width: auto;\n  }\n  .logo-col img {\n    width: 80px;\n  }\n  .cell {\n    width: 100%;\n  }\n}\n</style>",
