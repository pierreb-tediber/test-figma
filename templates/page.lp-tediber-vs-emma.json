        "custom_liquid": "<div class=\"vs-mattress-comparison\">\n  <div class=\"comparison-content\">\n    <div class=\"comparison-header\">\n      <div class=\"brands\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/ediber-logo.png?v=1751554118\" alt=\"Tediber\" class=\"brand-logo\">\n        <span class=\"vs-text\">vs</span>\n        <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/emma-logo.png?v=1751554118\" alt=\"Emma\" class=\"brand-logo\">\n      </div>\n      <h2 class=\"comparison-title\">\n        Quelle marque propose le meilleur matelas hybride ?\n      </h2>\n      <p class=\"comparison-desc\">\n        Nous avons analysé <strong>chaque détail</strong> selon vos <strong>vrais besoins</strong> : confort, soutien, durabilité, respirabilité et rapport qualité/prix.\n      </p>\n      <a href=\"/products/matelas-hybride\" class=\"comparison-button\">\n        Découvrir le meilleur matelas\n      </a>\n    </div>\n    <div class=\"mattress tediber-mattress\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/mattress_emma-mattress.jpg?v=1751554118\" alt=\"Matelas Tediber\">\n    </div>\n  </div>\n</div>\n\n<style>\n.vs-mattress-comparison {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 20px;\n}\n\n/* content area with flex */\n.comparison-content {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  flex-wrap: wrap;\n  gap: 20px;\n  margin-bottom: 30px;\n}\n\n/* header left, image right */\n.comparison-header {\n  flex: 1 1 50%;\n  text-align: left;\n}\n.comparison-header .brands {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 15px;\n  line-height: 26px;\n}\n.brand-logo {\n  height: auto;\n  max-width: 100px;\n}\n.vs-text {\n  font-size: 24px;\n  font-weight: bold;\n}\n.comparison-title {\n  font-size: 24px;\n  font-weight: bold;\n  margin: 10px 0;\n  line-height: 26px;\n}\n.vs-mattress-comparison {\nbackground : #FBF5ED; }\n.comparison-desc {\n  font-size: 16px;\n  margin-bottom: 20px;\n  max-width: 500px;\n  line-height: 26px;\n}\n.comparison-button {\n  display: inline-block;\n  background-color: #001F3F;\n  color: white;\n  padding: 12px 24px;\n  text-decoration: none;\n  border-radius: 5px;\n  font-weight: bold;\n  transition: background-color 0.3s;\n}\n.comparison-button:hover {\n  background-color: #003366;\n}\n\n/* image right */\n.tediber-mattress {\n  flex: 1 1 45%;\n}\n.tediber-mattress img {\n  width: 100%;\n  border-radius: 8px;\n}\n\n/* images below (emma) */\n.comparison-images {\n  display: flex;\n  justify-content: center;\n  gap: 20px;\n}\n.emma-mattress img {\n  width: 100%;\n  max-width: 400px;\n  border-radius: 8px;\n}\n\n/* Responsive */\n@media (max-width: 768px) {\n  .comparison-content {\n    flex-direction: column;\n    text-align: center;\n  }\n  .comparison-header {\n    flex: 1 1 100%;\n    text-align: center;\n  }\n  .comparison-header .brands {\n    justify-content: center; /* centrage horizontal logos et vs */\n    text-align: center;\n  }\n  .tediber-mattress {\n    flex: 1 1 100%;\n  }\n  .comparison-title {\n    font-size: 20px;\n  }\n  .comparison-desc {\n    font-size: 14px;\n  }\n  .vs-text {\n    font-size: 20px;\n  }\n}\n</style>",
