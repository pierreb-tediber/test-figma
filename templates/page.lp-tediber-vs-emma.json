    "custom_liquid_kCqxmQ": {
      "type": "custom-liquid",
      "name": "comparateur micro",
      "settings": {
        "custom_liquid": "<div class=\"comparatif-complet\">\n  <h2 class=\"titre\">TEDIBER VS EMMA</h2>\n  <h3 class=\"soustitre\">NOTRE COMPARATIF COMPLET</h3>\n  <p class=\"desc\">Découvrez notre <strong>analyse en 5 étapes</strong> pour mieux comprendre quel matelas est <strong>vraiment fait pour vous</strong>.</p>\n\n  <!-- Bloc 1 -->\n  <div class=\"ligne\">\n    <div class=\"icone-texte\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_matelas_bibloc_tediber_emma.png?v=1751876864\" alt=\"Poids du matelas\">\n      <h4>POIDS DU MATELAS</h4>\n    </div>\n    <div class=\"colonnes\">\n      <div class=\"bloc tediber\">\n        <div class=\"header\">\n          <span class=\"marque\">Tediber</span>\n          <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_medaille_tediber.png?v=1751876864\" alt=\"Medaille\" class=\"medaille\">\n        </div>\n        <p><strong>Matelas plus lourd</strong>, synonyme d'une densité des matériaux plus élevée et d'une meilleure durabilité.</p>\n      </div>\n      <div class=\"bloc emma\">\n        <div class=\"header\">\n          <span class=\"marque\">Emma</span>\n        </div>\n        <p><strong>Matelas plus léger</strong>, plus simple à déplacer, mais la densité moindre peut influencer la durabilité.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Bloc 2 -->\n  <div class=\"ligne\">\n    <div class=\"icone-texte\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_bloc_mousse_ressort_matelas_tediber.png?v=1751876864\" alt=\"Épaisseur des mousses\">\n      <h4>ÉPAISSEUR DES MOUSSES</h4>\n    </div>\n    <div class=\"colonnes\">\n      <div class=\"bloc tediber\">\n        <div class=\"header\">\n          <span class=\"marque\">Tediber</span>\n          <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_medaille_tediber.png?v=1751876864\" class=\"medaille\">\n        </div>\n        <p><strong>13 cm de mousse</strong> répartie en plusieurs couches, assurant un amorti progressif et évitant tout contact perceptible avec les ressorts.</p>\n      </div>\n      <div class=\"bloc emma\">\n        <div class=\"header\">\n          <span class=\"marque\">Emma</span>\n        </div>\n        <p><strong>3 cm de mousse</strong> recouvrant les ressorts, laissant parfois apparaître une sensation de contact.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Bloc 3 -->\n  <div class=\"ligne\">\n    <div class=\"icone-texte\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_tediber_qualite_housse_matelas.png?v=1751876863\" alt=\"Qualité de la housse\">\n      <h4>QUALITÉ DE LA HOUSSE</h4>\n    </div>\n    <div class=\"colonnes\">\n      <div class=\"bloc tediber\">\n        <div class=\"header\">\n          <span class=\"marque\">Tediber</span>\n          <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_medaille_tediber.png?v=1751876864\" alt=\"Medaille\" class=\"medaille\">\n        </div>\n        <p><strong>Housse épaisse</strong>, douce et respirante, à base de Tencel®, favorisant la circulation de l’air et la régulation thermique.</p>\n      </div>\n      <div class=\"bloc emma\">\n        <div class=\"header\">\n          <span class=\"marque\">Emma</span>\n        </div>\n        <p><strong>Housse fine</strong>, translucide à la lumière et 100% polyester. Retient la chaleur, moins qualitative au toucher.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Bloc 4 -->\n  <div class=\"ligne\">\n    <div class=\"icone-texte\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_confort_independance_tediber_lit.png?v=1751876863\" alt=\"Soutien et confort\">\n      <h4>SOUTIEN ET CONFORT</h4>\n    </div>\n    <div class=\"colonnes\">\n      <div class=\"bloc tediber\">\n        <div class=\"header\">\n          <span class=\"marque\">Tediber</span>\n          <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_medaille_tediber.png?v=1751876864\" class=\"medaille\">\n        </div>\n        <p><strong>Confort équilibré</strong> : accueil moelleux combiné à une base ferme pour soutenir efficacement la colonne vertébrale.</p>\n      </div>\n      <div class=\"bloc emma\">\n        <div class=\"header\">\n          <span class=\"marque\">Emma</span>\n        </div>\n        <p><strong>Confort très souple</strong>, donnant une sensation d’enfoncement, maintenant moins bien la colonne et limitant la durabilité.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Bloc 5 -->\n  <div class=\"ligne\">\n    <div class=\"icone-texte\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_tediber_analyse_meilleur.png?v=1751876864\" alt=\"Rapport qualité-prix\">\n      <h4>RAPPORT QUALITÉ-PRIX</h4>\n    </div>\n    <div class=\"colonnes\">\n      <div class=\"bloc tediber\">\n        <div class=\"header\">\n          <span class=\"marque\">Tediber</span>\n        </div>\n        <p><strong>Prix plus élevé</strong>, justifié par la densité des matériaux, la fabrication française et la qualité. Peu de promos mais un positionnement clair.</p>\n      </div>\n      <div class=\"bloc emma\">\n        <div class=\"header\">\n          <span class=\"marque\">Emma</span>\n        </div>\n        <p><strong>Promotions régulières</strong>, mais pouvant masquer une qualité moindre et limitant la durabilité.</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Bloc Verdict Final -->\n  <div class=\"ligne final\">\n    <div class=\"icone-texte verdict\">\n      <img class=\"logo-festif\" src=\"https://cdn.shopify.com/s/files/1/0903/1342/5220/files/lp_tediber_logo_festif.png?v=1751876864\" alt=\"Tediber vainqueur\">\n      <h4>VERDICT FINAL</h4>\n    </div>\n    <div class=\"colonnes\">\n      <div class=\"bloc tediber\">\n        <span class=\"marque\">Tediber</span>\n        <p><strong>Nous recommandons le matelas hybride Tediber !</strong> Pour un bon maintien, une housse respirante et une excellente durabilité.</p>\n      </div>\n      <div class=\"bloc emma\">\n        <span class=\"marque\">Emma</span>\n        <p>Un matelas à prix attractif, <strong>mais au détriment d’une qualité et d’une durabilité limitées</strong>.</p>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n.comparatif-complet {\n  font-family: 'Obviously', sans-serif;\n  background: #fef8f2;\n  padding: 2rem;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n.comparatif-complet h2, .comparatif-complet h3 {\n  text-align: center;\n  color: #010C27;\n  margin: 0.5rem 0;\n}\n\n.comparatif-complet .desc {\n  text-align: center;\n  color: #010C27;\n  margin-bottom: 2rem;\n}\n.ligne {\n  display: flex;\n  gap: 2rem;\n  margin-bottom: 2rem;\n  align-items: center;\n}\n.icone-texte {\n  flex: 0 0 180px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n}\n.icone-texte img {\n  width: 80px;\n  height: auto;\n  object-fit: contain;\n  margin-bottom: 0.5rem;\n}\n.icone-texte h4 {\n  color: #010C27;\n  font-size: 2rem;\n}\n.colonnes {\n  display: flex;\n  gap: 1rem;\n  flex: 1;\n}\n.bloc {\n  flex: 1;\n  padding: 1rem;\n  border-radius: 6px;\n}\n.bloc.tediber {\n  background: #fcecdc;\n}\n\n.bloc.emma {\n  background: #fff;\n}\n.header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 0.5rem;\n}\n.medaille {\n  width: 20px;\n}\n.ligne.final {\n  background: #010C27;\n  padding: 2rem;\n  border-radius: 10px;\n  align-items: flex-start;\n}\n.ligne.final .icone-texte img {\n  width: 80px;\n}\n.ligne.final .icone-texte h4 {\n  color: #fff;\n}\n.ligne.final .bloc.tediber, .ligne.final .bloc.emma {\n  background: transparent;\n  color: #fff;\n}\n\n/* Responsive */\n@media (max-width: 768px) {\n  .ligne {\n    flex-direction: column;\n    align-items: center;\n  }\n  .colonnes {\n    flex-direction: column;\n    width: 100%;\n  }\n  .icone-texte {\n    flex: none;\n    margin-bottom: 1rem;\n  }\n}\n</style>",
