    "custom_liquid_qAfAFC": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.countdown-banner{\n  display:flex;\n  justify-content:center;\n  align-items:center;\n  text-align:center;\n  color:white;\n  font-size:16px;\n  font-weight:bold;\n  gap:10px;\n}\n\n/* Mobile */\n@media (max-width: 600px){\n  .countdown-banner{\n    flex-direction:column;\n    gap:8px; /* espace entre les deux lignes */\n  }\n}\n</style>\n\n<div class=\"countdown-banner\">\n  <span>FRENCH DAYS : JUSQU'À -40%\n</div>\n\n<script>\n  const endDate = new Date(\"March 17, 2026 23:55:00\").getTime();\n\n  function updateCountdown() {\n    const now = new Date().getTime();\n    const distance = endDate - now;\n\n    if (distance <= 0) {\n      document.getElementById(\"countdown\").innerHTML = \"Offre terminée\";\n      return;\n    }\n\n    const days = Math.floor(distance / (1000 * 60 * 60 * 24));\n    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));\n    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));\n    const seconds = Math.floor((distance % (1000 * 60)) / 1000);\n\n    document.getElementById(\"countdown\").innerHTML =\n      days + \"j \" + hours + \"h \" + minutes + \"m \" + seconds + \"s\";\n  }\n\n  updateCountdown();\n  setInterval(updateCountdown, 1000);\n</script>",
        "color_scheme": "scheme-fd8a6b7f-fb17-41ee-ac65-43143a48e740",
        "padding_top": 16,
        "padding_bottom": 16
