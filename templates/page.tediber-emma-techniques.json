      "blocks": {
        "text_highlight_begiKb": {
          "type": "text_highlight",
          "settings": {
            "text": "<p>Cette page centralise l’ensemble des éléments factuels et données techniques relevées dans le cadre du comparateur <a href=\"https://www.tediber.com/pages/matelas-hybride-vs-emma\" title=\"https://www.tediber.com/pages/matelas-hybride-vs-emma\">Tediber ou Emma</a>.</p>",
            "text_alignment": "left"
          }
        },
        "text_3qKLMM": {
          "type": "text",
          "settings": {
            "text": "<p>Elle vise à garantir la transparence des informations présentées, documenter les sources et les données utilisées et conserver une trace datée des éléments observés au moment de l’<a href=\"https://www.tediber.com/pages/matelas-hybride-vs-emma\" title=\"https://www.tediber.com/pages/matelas-hybride-vs-emma\">analyse</a>. <br/><br/>Date de mise à jour : 20/03/2026</p>",
