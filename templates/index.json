;\n}\n\n.countdown-banner-french-days span{\n  color:white;\n}\n\n.offer-exclusive-text{\n  font-weight:bold;\n}\n\n#countdown-french-days{\n  font-weight:bold;\n  color:white;\n}\n<\/style>\n\n<a href=\"\/collections\/promotions-tediber\" class=\"countdown-banner-french-days\">\n  <span class=\"offer-exclusive-text\">Offre exclusive<\/span>\n  <span id=\"countdown-french-days\"><\/span>\n<\/a>\n\n<script>\n\/\/ Fin de l'offre : 23 juin 2026 à 23h59\nconst endDateFrenchDays = new Date(\"2026-06-23T23:59:00\").getTime();\n\nfunction updateCountdownFrenchDays() {\n  const now = new Date().getTime();\n  const distance = endDateFrenchDays - now;\n\n  const el = document.getElementById(\"countdown-french-days\");\n\n  if (!el) return;\n\n  if (distance <= 0) {\n    el.innerHTML = \"- Offre terminée\";\n    return;\n  }\n\n  const days = Math.floor(distance \/ (1000 * 60 * 60 * 24));\n  const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) \/ (1000 * 60 * 60));\n  const minutes = Math.floor((distance % (1000 * 60 * 60)) \/ (1000 * 60));\n  const seconds = Math.floor((distance % (1000 * 60)) \/ 1000);\n\n  let text = \"- Plus que \";\n  if (days > 0) text += days + \"j \";\n  text += hours + \"h \" + minutes + \"m \" + seconds + \"s\";\n\n  el.innerHTML = text;\n}\n\nupdateCountdownFrenchDays();\nsetInterval(updateCountdownFrenchDays, 1000);\n<\/script>","color_scheme":"scheme-d4d01469-24a1-4895-bf3f-7040237fac6a","padding_top":0,"padding_bottom":0}},"ax_slider_nM8Ff3":{"type":"ax-slider","blocks":{"slide_mJeJyR":{"type":"slide","settings":{"img_slider":"shopify:\/\/shop_images\/hero-desktop-french-days-2026.jpg","img_slider_mobile":"shopify:\/\/shop_images\/hero_homepage_mobile.jpg","heading":"<p>FRENCH DAYS<\/p>","heading_size":"hxl","heading_font":"campagne_1","heading_font_scale":3,"legend":"Jusqu'à -40%*","legend_font":"default","legend_size":"h5","legend_font_scale":1,"subheading":"","subheading_em_color":"","subheading_shadow":false,"subheading_font":"default"