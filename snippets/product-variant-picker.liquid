{% comment %}
	Renders product variant-picker

	Accepts:
	- product: {Object} product object.
	- block: {Object} passing the block information.
	- product_form_id: {String} Id of the product form to which the variant picker is associated.
	- picker_type: {String} Type of picker to display.
	- selected_variant: {Object} Selected variant.
	- has_changed_option_for_hidden: {Boolean} True if the option has changed for a hidden variant.

	Usage:
	{% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
{% endcomment %}

{%- unless product.has_only_default_variant -%}
	{%- liquid
		# Récupère les traductions des noms d'options pour les tailles
		assign options_names_for_size_translated = 'products.product.options_names_for_size' | t | downcase | replace: ', ', ','
		assign options_names_for_size = options_names_for_size_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les accoudoirs
		assign options_names_for_armrest_translated = 'products.product.options_names_for_armrest_html' | t | downcase | replace: ', ', ','
		assign options_names_for_armrest = options_names_for_armrest_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les pieds
		assign options_names_for_foot_translated = 'products.product.options_names_for_foot' | t | downcase | replace: ', ', ','
		assign options_names_for_foot = options_names_for_foot_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les couleurs
		assign options_names_for_color_translated = 'products.product.options_names_for_color' | t | downcase | replace: ', ', ','
		assign options_names_for_color = options_names_for_color_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les structures
		assign options_names_for_structure_translated = 'products.product.options_names_for_structure' | t | downcase | replace: ', ', ','
		assign options_names_for_structure = options_names_for_structure_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les styles
		assign options_names_for_style_translated = 'products.product.options_names_for_style' | t | downcase | replace: ', ', ','
		assign options_names_for_style = options_names_for_style_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les formes
		assign options_names_for_shape_translated = 'products.product.options_names_for_shape' | t | downcase | replace: ', ', ','
		assign options_names_for_shape = options_names_for_shape_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour le confort
		assign options_names_for_comfort_translated = 'products.product.options_names_for_comfort' | t | downcase | replace: ', ', ','
		assign options_names_for_comfort = options_names_for_comfort_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les draps
		assign options_names_for_parure_sheet_translated = 'products.product.options_names_for_parure_sheet' | t | downcase | replace: ', ', ','
		assign options_names_for_parure_sheet = options_names_for_parure_sheet_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les versions
		assign options_names_for_version_translated = 'products.product.options_names_for_version' | t | downcase | replace: ', ', ','
		assign options_names_for_version = options_names_for_version_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les bonnets
		assign options_names_for_bonnet_translated = 'products.product.options_names_for_bonnet' | t | downcase | replace: ', ', ','
		assign options_names_for_bonnet = options_names_for_bonnet_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les couettes
		assign options_names_for_parure_comforter_translated = 'products.product.options_names_for_parure_comforter' | t | downcase | replace: ', ', ','
		assign options_names_for_parure_comforter = options_names_for_parure_comforter_translated | split: ',' | uniq

		# Format par défaut (Monobloc) : suffixe masqué à l'affichage dans le picker taille
		assign default_format_lc = 'products.product.default_format_for_size_value' | t | downcase | strip

		assign parure_pillowcases = product.metafields.custom.parures_affichage.value

		assign class_hidden = 'hidden visually-hidden'

		# Détecte la position de l'option version (0-indexed) pour la présélection de la version la moins chère côté JS
		assign version_option_position = blank
		for option_check in product.options_with_values
			assign vs_option_name_check = option_check.name | downcase | split: ' ' | uniq
			for option_name in vs_option_name_check
				if options_names_for_version contains option_name
					assign version_option_position = forloop.parentloop.index0
					break
				endif
			endfor
			if version_option_position != blank
				break
			endif
		endfor

		# Détecte si new-offer
		assign is_new_offer = false
		if template_new_offer or template_new_offer_sommier
			assign is_new_offer = true
		endif

		# Détecte si on est sur la fiche pack-new : applique une surcharge visuelle
		# (texte sélectionné en bold, chevron vertical, prix variante + % réduction)
		# sans déclencher la logique conditionnelle is_new_offer.
		assign is_pack_new = false
		if product.template_suffix == 'pack-new'
			assign is_pack_new = true
		endif
	-%}

	{%- liquid
		# Détection template `pack-new` pour pouvoir scoper les overrides de typo
		# (legends en bold etc.) sans toucher au PDP standalone ou au pack legacy.
		assign variant_selects_is_pack_new = false
		if template.suffix == 'pack-new'
			assign variant_selects_is_pack_new = true
		endif
	-%}
	<variant-selects
		id="variant-selects-{{ section.id }}"
		data-section="{{ section.id }}"
		class="product__variant-selects{% if variant_selects_is_pack_new %} product__variant-selects--pack-new{% endif %}"
		{{ block.shopify_attributes }}
		data-parure="{{ parure_pillowcases | default: false }}"
		{% if version_option_position != blank and parure_pillowcases == blank %}
			data-version-option-position="{{ version_option_position }}"
		{% endif %}
	>
		{%- liquid
			assign section_id = section.id

			# Assigne les valeurs par défaut
			assign selected_variant_price = blank
			assign selected_variant_color_hexa = blank
			assign selected_variant_color_image = blank
			assign selected_variant_color_label = blank
			assign selected_variant_size_information = blank
			assign selected_variant_bonnet_information = blank
			assign custom_position = 0
			assign custom_position_increment = 0
			assign use_custom_position_size = false
			assign use_custom_position_comfort = false
			assign use_custom_position_structure = false
			assign use_custom_position_bonnet = false
			assign use_custom_position_version = false
			assign bonnet_extra_offset = 0
			assign version_extra_offset = 0
			assign format_extra_offset = 0
			assign prescan_has_format = false
			assign prescan_size_option_index = blank

			if product.metafields.custom.option_position_custom != true
				assign custom_position = 1
				assign custom_position_increment = 1
			endif

			# Pré-détection : vérifie si les options "bonnet", "taille" et "version" coexistent
			# pour ajuster le positionnement (bonnet en position 2 après taille, version après bonnet)
			# + détecte si l'option taille a plusieurs formats (Monobloc/Bibloc) pour insérer
			# une fake step "Format" entre la taille et la version
			if product.metafields.custom.option_position_custom != true
				assign prescan_has_size = false
				assign prescan_has_bonnet = false
				assign prescan_has_version = false
				for prescan_option in product.options_with_values
					assign prescan_name_array = prescan_option.name | downcase | split: ' ' | uniq

					# Filtre : on exclut les options pied car leur nom contient parfois "Taille"
					# (ex. "Taille et couleur des pieds") et déclencherait une fausse détection taille
					assign prescan_is_foot = false
					for prescan_name in prescan_name_array
						if options_names_for_foot contains prescan_name
							assign prescan_is_foot = true
							break
						endif
					endfor

					assign prescan_is_size = false
					unless prescan_is_foot
						for prescan_name in prescan_name_array
							if options_names_for_size contains prescan_name
								assign prescan_has_size = true
								assign prescan_is_size = true
							endif
							if options_names_for_bonnet contains prescan_name
								assign prescan_has_bonnet = true
							endif
							if options_names_for_version contains prescan_name
								assign prescan_has_version = true
							endif
						endfor
					endunless
					# Si c'est l'option taille, on retient sa position 0-indexed et
					# on collecte les formats distincts présents dans ses valeurs.
					# En contexte bundle on saute la détection des formats : le picker du
					# parent pack agrège des values hétérogènes (avec et sans suffixe) et
					# la fake step Format n'est pas désirée sur les packs.
					if prescan_is_size and is_bundle != true
						assign prescan_size_option_index = prescan_option.position | minus: 1
						assign prescan_formats_seen_str = ''
						for prescan_size_value in prescan_option.values
							assign prescan_size_parts = prescan_size_value | split: ' - '
							assign prescan_format_marker = '|default|'
							if prescan_size_parts.size > 1
								assign prescan_format_candidate = prescan_size_parts | last | strip
								assign prescan_format_marker = '|' | append: prescan_format_candidate | append: '|'
							endif
							unless prescan_formats_seen_str contains prescan_format_marker
								assign prescan_formats_seen_str = prescan_formats_seen_str | append: prescan_format_marker
							endunless
						endfor
						# Compte les formats distincts (séparés par '||' une fois jointés)
						assign prescan_formats_array = prescan_formats_seen_str | split: '||'
						if prescan_formats_array.size > 1
							assign prescan_has_format = true
						endif
					endif
				endfor
				if prescan_has_size and prescan_has_bonnet
					assign bonnet_extra_offset = 1
				endif
				if prescan_has_version
					assign version_extra_offset = 1
				endif
				if prescan_has_format
					assign format_extra_offset = 1
				endif
			endif

			if selected_variant == blank
				assign selected_variant = product.selected_or_first_available_variant
			endif

			# Comptage des formats pour la dim de la variante COURANTE (vs prescan_has_format
			# qui est product-level). Sert à savoir si la fake step Format va apparaître ou
			# pas : quand la taille courante n'a qu'un seul format, le snippet
			# `product-variant-picker-format` masque sa step, et le help text
			# `taille_information` doit donc être rendu sous le picker taille à la place
			# (cf. condition `current_size_has_single_format` dans le rendu de variant-dropdown).
			assign prescan_current_size_format_count = 0
			assign current_size_has_single_format = false
			if prescan_has_format and prescan_size_option_index != blank and selected_variant != blank
				assign current_size_raw_for_count = selected_variant.options[prescan_size_option_index]
				if current_size_raw_for_count != blank
					assign current_size_parts_for_count = current_size_raw_for_count | split: ' - '
					assign current_dimensions_for_count = current_size_parts_for_count[0] | strip
					assign current_size_format_option_obj = product.options_with_values[prescan_size_option_index]
					assign formats_seen_lc_for_count = ','
					for size_value_for_count in current_size_format_option_obj.values
						assign size_value_parts_for_count = size_value_for_count | split: ' - '
						assign value_dim_for_count = size_value_parts_for_count[0] | strip
						unless value_dim_for_count == current_dimensions_for_count
							continue
						endunless
						assign value_format_for_count = 'default'
						if size_value_parts_for_count.size > 1
							assign value_format_for_count = size_value_parts_for_count[1] | strip | downcase
						endif
						assign format_marker_for_count = ',' | append: value_format_for_count | append: ','
						unless formats_seen_lc_for_count contains format_marker_for_count
							assign formats_seen_lc_for_count = formats_seen_lc_for_count | append: value_format_for_count | append: ','
							assign prescan_current_size_format_count = prescan_current_size_format_count | plus: 1
						endunless
					endfor
					if prescan_current_size_format_count < 2
						assign current_size_has_single_format = true
					endif
				endif
			endif

			# Assigne les valeurs si la variante est trouvée
			if selected_variant != blank
				# Assigne le prix si il est défini
				assign selected_variant_price = selected_variant.price

				# Assigne le prix de référence si il est défini
				if selected_variant.compare_at_price != blank
					assign selected_variant_compare_at_price = selected_variant.compare_at_price
				else
					assign selected_variant_compare_at_price = selected_variant.price
				endif

				# Assigne la couleur si elle est définie
				if selected_variant.metafields.custom.color.value.color.value != blank
					assign selected_variant_color_hexa = selected_variant.metafields.custom.color.value.color.value
				endif

				# Assigne l'image si elle est définie
				if selected_variant.metafields.custom.color.value.image.value != blank
					assign selected_variant_color_image = selected_variant.metafields.custom.color.value.image.value
				endif

				# Assigne l'image si elle est définie
				if selected_variant.metafields.custom.color.value.image_de_la_variante.value != blank
					assign selected_variant_color_image = selected_variant.metafields.custom.color.value.image_de_la_variante.value
				endif

				# Assigne le label si il est défini
				if selected_variant.metafields.custom.color.value.label.value != blank
					assign selected_variant_color_label = selected_variant.metafields.custom.color.value.label.value
				endif

				# Assigne les informations de taille si elles sont définies
				if selected_variant.metafields.custom.taille_information.value != blank
					assign selected_variant_size_information = selected_variant.metafields.custom.taille_information.value
				endif

				# Assigne les informations de bonnet si elles sont définies
				if selected_variant.metafields.custom.bonnet_information.value != blank
					assign selected_variant_bonnet_information = selected_variant.metafields.custom.bonnet_information.value
				endif
			endif
		-%}

		{%- for option in product.options_with_values -%}
			{%- liquid
				assign custom_position_increment = custom_position_increment | plus: 1
				assign custom_position = custom_position_increment

				# Détermine le nombre de swatches (échantillons visuels) disponibles
				assign swatch_count = option.values | map: 'swatch' | compact | size
				assign picker_type = block.settings.picker_type | default: 'variant_dropdown'

				# Variables de contrôle de l'affichage
				assign hide_information = false
				assign current_is_bonnet = false
				assign current_is_version = false

				# Vérifie si des swatches sont disponibles et si la forme n'est pas 'none'
				if swatch_count > 0 and block.settings.swatch_shape != 'none'
					# Adapte le type de sélecteur en fonction des paramètres
					if block.settings.picker_type == 'dropdown'
						assign picker_type = 'swatch_variant_dropdown'
					else
						assign picker_type = 'swatch'
					endif
				endif

				# Assigne les valeurs par défaut
				assign show_size_information = false
				assign show_size_information_price = false

				# Détermine la classe pour le conteneur des swatches
				assign class_for_swatch_list = 'product__variant-selects__swatch__list__color--'

				# Détermine le nombre de couleurs disponibles
				assign option_values_size = option.values | size
				if option_values_size < 5
					assign class_for_swatch_list = class_for_swatch_list | append: '4'
				else
					assign class_for_swatch_list = class_for_swatch_list | append: '5'
				endif

				# Traitement du nom de l'option en minuscules
				assign option_name_downcase = option.name | downcase

				# Divise le nom de l'option en tableau de mots uniques
				assign option_name_array = option_name_downcase | split: ' ' | uniq

				for translation in options_names_for_foot
					assign has_foot_in_array = option_name_array | find: translation
					if has_foot_in_array
						assign has_foot_in_array = true
						break
					endif
				endfor

				for translation in options_names_for_structure
					assign has_structure_in_array = option_name_array | find: translation
					if has_structure_in_array
						assign has_structure_in_array = true
						break
					endif
				endfor

				if has_foot_in_array
					assign picker_type = 'swatch_foot'
				elsif has_structure_in_array
					assign picker_type = 'swatch_structure'
					if use_custom_position_structure == false
						if product.metafields.custom.option_position_custom != true
							assign custom_position_increment = custom_position_increment | minus: 1
							assign custom_position = 1
						endif
						assign use_custom_position_structure = true
					endif
				else
					# Analyse chaque mot du nom de l'option pour déterminer le type de sélecteur approprié
					for option_name in option_name_array
						# Si l'option est liée à une couleur
						if options_names_for_color contains option_name
							assign picker_type = 'swatch'
							break
						endif

						# Si l'option est liée à une forme
						if options_names_for_shape contains option_name
							assign picker_type = 'swatch_shape'
							assign class_for_swatch_list = 'product__variant-selects__swatch__list__shape'
							break
						endif

						# Si l'option est liée à un accoudoir
						assign show_armrest_information = false
						if options_names_for_armrest contains option_name
							assign show_armrest_information = true
						endif

						# Si l'option est liée à une taille
						if options_names_for_size contains option_name or show_armrest_information == true
							assign picker_type = 'variant_dropdown'
							if use_custom_position_size == false
								assign show_size_information = true
								assign show_size_information_price = true
								if is_new_offer
									assign show_size_information = true
									assign show_size_information_price = false
								endif

								if product.metafields.custom.option_position_custom != true and show_armrest_information == false
									assign custom_position_increment = custom_position_increment | minus: 1
									assign custom_position = 1
								endif
								assign use_custom_position_size = true
							endif
							break
						endif

						# Si l'option est liée à un confort
						if options_names_for_comfort contains option_name
							assign picker_type = 'swatch_comfort'
							assign class_for_swatch_list = 'product__variant-selects__swatch-comfort'
							if use_custom_position_comfort == false
								if product.metafields.custom.option_position_custom != true
									assign custom_position_increment = custom_position_increment | minus: 1
									assign custom_position = 1
								endif
								assign use_custom_position_comfort = true
							endif
							break
						endif

						# Si l'option est liée à un style
						if options_names_for_style contains option_name
							assign picker_type = 'swatch_style'
							break
						endif

						# Si l'option est liée à une version
						if options_names_for_version contains option_name
							assign picker_type = 'button'
							assign current_is_version = true
							if use_custom_position_version == false
								if product.metafields.custom.option_position_custom != true and prescan_has_size
									assign custom_position_increment = custom_position_increment | minus: 1
									assign custom_position = 2
									if prescan_has_bonnet
										assign custom_position = 3
									endif
									# Décale version d'1 si la fake step format est insérée entre taille et version
									if prescan_has_format
										assign custom_position = custom_position | plus: 1
									endif
								endif
								assign use_custom_position_version = true
							endif
							break
						endif

						# Si l'option est liée à un bonnet
						if options_names_for_bonnet contains option_name
							assign picker_type = 'variant_dropdown'
							assign current_is_bonnet = true
							if use_custom_position_bonnet == false
								if product.metafields.custom.option_position_custom != true and prescan_has_size
									assign custom_position_increment = custom_position_increment | minus: 1
									assign custom_position = 2
								endif
								assign use_custom_position_bonnet = true
							endif
							break
						endif
					endfor
				endif

				# Pré-calcul du booléen pour le rendu du help text taille_information
				# sous le picker taille. Liquid ne supportant pas les parenthèses dans
				# une condition `and`/`or`, on stocke le résultat ici.
				# True si :
				#   - show_size_information est actif (option taille détectée + texte dispo)
				#   - ET (pas de step Format au niveau produit OU taille courante avec 1 seul format)
				assign show_size_info_under_size = false
				if show_size_information
					if prescan_has_format == false
						assign show_size_info_under_size = true
					elsif current_size_has_single_format
						assign show_size_info_under_size = true
					endif
				endif

				if product.metafields.custom.option_position_custom != true and product.options_with_values.size == 1 and forloop.last
					assign custom_position = 1
					assign custom_position_increment = 1
				endif

				# Décale les options non-prioritaires quand bonnet et taille coexistent
				# (les options qui ne sont ni taille ni bonnet doivent être après bonnet)
				if bonnet_extra_offset > 0 and custom_position != 1 and current_is_bonnet == false
					assign custom_position = custom_position | plus: bonnet_extra_offset
				endif

				# Décale les options non-prioritaires quand version et taille coexistent
				# (les options qui ne sont ni taille, ni bonnet, ni version doivent être après version)
				if version_extra_offset > 0 and custom_position != 1 and current_is_bonnet == false and current_is_version == false
					assign custom_position = custom_position | plus: version_extra_offset
				endif

				# Décale les options non-prioritaires quand la fake step format est insérée
				# entre taille et version (les options non taille/bonnet/version se décalent d'1)
				if format_extra_offset > 0 and custom_position != 1 and current_is_bonnet == false and current_is_version == false
					assign custom_position = custom_position | plus: format_extra_offset
				endif

				# Calcule la valeur sélectionnée pour cette option basée sur la variante spécifique
				assign current_option_selected_value = blank
				if selected_variant != blank
					assign option_index = option.position | minus: 1
					# Si la valeur sélectionnée pour cette option est différente de la valeur de la variante sélectionnée, on assigne la valeur de la variante sélectionnée
					if selected_variant.options[option_index] != option.selected_value
						assign current_option_selected_value = selected_variant.options[option_index]
					endif
				endif

				if current_option_selected_value == blank
					assign current_option_selected_value = option.selected_value
				endif

				# Détection option taille (pour masquage suffixe " - Monobloc" à l'affichage)
				assign current_is_size = false
				for option_name in option_name_array
					if options_names_for_size contains option_name
						assign current_is_size = true
						break
					endif
				endfor

				# Valeur affichée du sélecteur (texte uniquement) : strippe " - Monobloc/Bibloc"
				# si option taille. Contexte bundle : on garde la value brute affichée
				# (le picker pack agrège des values hétérogènes — pas de strip).
				assign current_option_selected_value_display = current_option_selected_value
				if current_is_size and is_bundle != true
					assign current_value_parts_display = current_option_selected_value | split: ' - '
					if current_value_parts_display.size > 1
						assign current_value_format_display_lc = current_value_parts_display | last | strip | downcase
						if current_value_format_display_lc == default_format_lc or current_value_format_display_lc == 'bibloc'
							assign current_option_selected_value_display = current_value_parts_display | first | strip
						endif
					endif
				endif

