					</legend>
					<div class="product__variant-selects__swatch__list {{ class_for_swatch_list }}">
						{%- render 'product-variant-options',
							product: product,
							option: option,
							position: option.position,
							custom_position: custom_position,
							block: block,
							picker_type: picker_type,
							section_id: section_id,
							is_bundle: is_bundle,
							reference_price: reference_price,
							reference_price_compare_at_price: reference_price_compare_at_price,
							selected_variant: selected_variant,
							has_changed_option_for_hidden: has_changed_option_for_hidden
						-%}
					</div>
				</fieldset>
			{%- elsif picker_type == 'swatch_style' -%}
				<fieldset
					class="js product-form__input product-form__input--swatch product__variant-selects__swatch product__variant-selects__swatch-style{% if hide_information %} {{ class_hidden }}{% endif %}"
					style="order: {{ custom_position }};"
				>
					<legend class="form__label product__variant-selects__label product__variant-selects__swatch__label">
						{{ custom_position_label -}}
						{{- 'products.product.product_option_name_choose' | t: option_name: option_name_downcase }}
						<span data-selected-value class="visually-hidden">
							{{- current_option_selected_value -}}
						</span>
					</legend>
					{%- liquid
						# Récupère la position de l'option actuelle
						assign option_current = 'option' | append: option.position

						# Group values by bed style
						assign bed_styles_array = '' | split: ''
						assign bed_styles_array_with_variants = '' | split: ''

						for value in option.values
							# Extract the bed style part (before the dash)
							assign value_parts = value | split: '-'
							if value_parts.size > 0
								assign bed_style = value_parts | first | strip
								unless bed_styles_array contains bed_style
									# Create a temporary array with the single value and concat with existing array
									assign bed_style_array = bed_style | sort
									assign bed_styles_array = bed_styles_array | concat: bed_style_array

									# Récupère les variantes pour le style de lit
									assign bed_styles_array_with_variant_array = product.variants | where: option_current, value | first | sort
									assign bed_styles_array_with_variants = bed_styles_array_with_variants | concat: bed_styles_array_with_variant_array
								endunless
							endif
						endfor

						assign bed_style_active = blank
						if current_option_selected_value != blank
							assign bed_style_active = current_option_selected_value | split: '-' | first | strip
						endif
					-%}
					<div class="product__variant-selects__swatch-style__container">
						{%- for bed_style in bed_styles_array -%}
							{%- liquid
								# Vérifie si au moins une option est disponible pour ce bed_style
								assign has_available_option = false

								for value in option.values
									assign value_bed_style = value | split: '-' | first | strip
									if value_bed_style == bed_style
										# Récupère la première variante pour cette valeur
										assign first_variant_with_value_option = product.variants | where: option_current, value | first

										# Vérifie si cette option doit être masquée selon la même logique que product-variant-options.liquid
										assign not_show_value_check = false

										if is_bundle != true
											if product.metafields.custom.combined_listings_produit_parent.value != blank
												# Récupère la première variante pour l'option actuelle correspondant à la valeur actuelle
												assign first_variant_with_value_option = product.metafields.custom.combined_listings_produit_parent.value.variants | where: option_current, value | first
												# Récupère toutes les variantes possibles pour le produit parent
												assign all_variants_check = product.metafields.custom.combined_listings_produit_parent.value.variants
											else
												assign all_variants_check = product.variants
											endif

											comment
												VÉRIFICATION DES VARIANTES CACHÉES/INDISPONIBLES POUR LES OPTIONS

												On ajoute une vérification supplémentaire pour cacher les valeurs dont toutes les variantes accessibles sont cachées/indisponibles
											endcomment
											if product.options.size == 1
												assign has_hidden_variant_option_check = false

												# Récupère les variantes possibles pour l'option actuelle
												assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', value

												# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
												assign option_all_hidden_check = true
												for variant_check in candidate_variants_matching_options_check
													if variant_check.metafields.custom.hidden_variant.value != true
														assign option_all_hidden_check = false
														break
													endif
												endfor

												# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option_check
												if option_all_hidden_check == true
													assign has_hidden_variant_option_check = true
												else
													# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
													for variant_check in candidate_variants_matching_options_check
														if variant_check.options[0] == value
															if variant_check.metafields.custom.hidden_variant.value == true
																assign has_hidden_variant_option_check = true
																break
															endif
														endif
													endfor
												endif

											elsif product.options.size == 2
												assign has_hidden_variant_option_check = false
												assign first_option_selected_variant_1_check = selected_variant.options[0]
												assign first_option_selected_variant_2_check = selected_variant.options[1]

												if first_option_selected_variant_1_check == blank or first_option_selected_variant_2_check == blank
													for option_temp in product.options_with_values
														if option_temp.position == 1
															assign first_option_selected_variant_1_check = option_temp.selected_value
														elsif option_temp.position == 2
															assign first_option_selected_variant_2_check = option_temp.selected_value
															break
														endif
													endfor
												endif

												# Récupère les variantes possibles pour l'option actuelle, LIMITE shopify 250 variantes avec le where
												if value.product_url == blank and first_option_selected_variant_1.product_url != blank and first_option_selected_variant_1.variant != blank
													assign all_variants_check = first_option_selected_variant_1.variant.product.variants
												elsif value.product_url != blank and value.variant != blank
													assign all_variants_check = value.variant.product.variants
												endif

												# Récupère les variantes possibles pour l'option actuelle
												if option.position == 2
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', first_option_selected_variant_1_check | where: 'option2', value
												else
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', value
													if value.product_url != blank and custom_position != option.position
														assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', value | where: 'option2', first_option_selected_variant_2_check
													endif
												endif

												# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
												assign option_all_hidden_check = true
												for variant_check in candidate_variants_matching_options_check
													if variant_check.metafields.custom.hidden_variant.value != true
														assign option_all_hidden_check = false
														break
													endif
												endfor

												# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option_check
												if option_all_hidden_check == true
													assign has_hidden_variant_option_check = true
												else
													# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
													for variant_check in candidate_variants_matching_options_check
														if variant_check.options[0] == first_option_selected_variant_1_check and variant_check.options[1] == value
															if variant_check.metafields.custom.hidden_variant.value == true
																assign has_hidden_variant_option_check = true
																break
															endif
														endif
													endfor
												endif

											elsif product.options.size == 3
												assign has_hidden_variant_option_check = false
												assign first_option_selected_variant_1_check = selected_variant.options[0]
												assign first_option_selected_variant_2_check = selected_variant.options[1]

												if first_option_selected_variant_1_check == blank or first_option_selected_variant_2_check == blank
													for option_temp in product.options_with_values
														if option_temp.position == 1
															assign first_option_selected_variant_1_check = option_temp.selected_value
														elsif option_temp.position == 2
															assign first_option_selected_variant_2_check = option_temp.selected_value
															break
														endif
													endfor
												endif

												# Récupère les variantes possibles pour l'option actuelle, LIMITE shopify 250 variantes avec le where
												if value.product_url == blank and first_option_selected_variant_1.product_url != blank and first_option_selected_variant_1.variant != blank
													assign all_variants_check = first_option_selected_variant_1.variant.product.variants
												elsif value.product_url != blank and value.variant != blank
													assign all_variants_check = value.variant.product.variants
												endif

												# Récupère les variantes possibles pour l'option actuelle
												if option.position == 3
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', first_option_selected_variant_1_check | where: 'option2', first_option_selected_variant_2_check | where: 'option3', value
												elsif option.position == 2
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', first_option_selected_variant_1_check | where: 'option2', value
												else
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', value
													if value.product_url != blank and custom_position != option.position
														assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', value | where: 'option2', first_option_selected_variant_2_check
													endif
												endif

												# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
												assign option_all_hidden_check = true
												for variant_check in candidate_variants_matching_options_check
													if variant_check.metafields.custom.hidden_variant.value != true
														assign option_all_hidden_check = false
														break
													endif
												endfor

												# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option_check
												if option_all_hidden_check == true
													assign has_hidden_variant_option_check = true
												else
													# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
													for variant_check in candidate_variants_matching_options_check
														if variant_check.options[0] == first_option_selected_variant_1_check and variant_check.options[1] == first_option_selected_variant_2_check and variant_check.options[2] == value
															if variant_check.metafields.custom.hidden_variant.value == true
																assign has_hidden_variant_option_check = true
																break
															endif
														endif
													endfor
												endif

											elsif product.options.size == 4
												assign has_hidden_variant_option_check = false
												assign first_option_selected_variant_1_check = selected_variant.options[0]
												assign first_option_selected_variant_2_check = selected_variant.options[1]
												assign first_option_selected_variant_3_check = selected_variant.options[2]

												if first_option_selected_variant_1_check == blank or first_option_selected_variant_2_check == blank or first_option_selected_variant_3_check == blank
													for option_temp in product.options_with_values
														if option_temp.position == 1
															assign first_option_selected_variant_1_check = option_temp.selected_value
														elsif option_temp.position == 2
															assign first_option_selected_variant_2_check = option_temp.selected_value
														elsif option_temp.position == 3
															assign first_option_selected_variant_3_check = option_temp.selected_value
														endif
													endfor
												endif

												# Récupère les variantes possibles pour l'option actuelle, LIMITE shopify 250 variantes avec le where
												if value.product_url == blank and first_option_selected_variant_1.product_url != blank and first_option_selected_variant_1.variant != blank
													assign all_variants_check = first_option_selected_variant_1.variant.product.variants
												elsif value.product_url != blank and value.variant != blank
													assign all_variants_check = value.variant.product.variants
												endif

												# Récupère les variantes possibles pour l'option actuelle
												if option.position == 4
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', first_option_selected_variant_1_check | where: 'option2', first_option_selected_variant_2_check | where: 'option3', first_option_selected_variant_3_check
												elsif option.position == 3
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', first_option_selected_variant_1_check | where: 'option2', first_option_selected_variant_2_check | where: 'option3', value
												elsif option.position == 2
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', first_option_selected_variant_1_check | where: 'option2', value
												else
													assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', value
													if value.product_url != blank and custom_position != option.position
														assign candidate_variants_matching_options_check = all_variants_check | where: 'option1', value | where: 'option2', first_option_selected_variant_2_check
													endif
												endif

												# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
												assign option_all_hidden_check = true
												for variant_check in candidate_variants_matching_options_check
													if variant_check.metafields.custom.hidden_variant.value != true
														assign option_all_hidden_check = false
														break
													endif
												endfor

												# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option_check
												if option_all_hidden_check == true
													assign has_hidden_variant_option_check = true
												else
													# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
													for variant_check in candidate_variants_matching_options_check
														if variant_check.options[0] == first_option_selected_variant_1_check and variant_check.options[1] == first_option_selected_variant_2_check and variant_check.options[2] == first_option_selected_variant_3_check and variant_check.options[3] == value
															if variant_check.metafields.custom.hidden_variant.value == true
																assign has_hidden_variant_option_check = true
																break
															endif
														endif
													endfor
												endif
											endif

											comment
												Si aucune variante non cachée n'a été trouvée, on cache cette option
											endcomment
											if has_hidden_variant_option_check == true
												assign not_show_value_check = true
											endif
										endif

										# Si cette option n'est pas masquée, on a trouvé une option disponible
										if not_show_value_check == false
											assign has_available_option = true
											break
										endif
									endif
								endfor

								# Si aucune option n'est disponible pour ce bed_style, on passe au suivant
								unless has_available_option
									continue
								endunless

								# Assigne les valeurs par défaut
								assign selected_variant_style_type = blank
								assign selected_variant_style_text = blank
								assign selected_variant_style_image = blank
								assign selected_variant_style_feature = blank

								# Assigne la variante par défaut si aucune trouvée
								if bed_style_active == bed_style
									assign first_variant_with_value_option = selected_variant
									if selected_variant == blank
										assign first_variant_with_value_option = bed_styles_array_with_variants[forloop.index0]
									endif
								else
									assign first_variant_with_value_option = bed_styles_array_with_variants[forloop.index0]
								endif

								# Assigne les valeurs par défaut si la variante est trouvée
								if first_variant_with_value_option != blank
									assign selected_variant_style_type = first_variant_with_value_option.metafields.custom.style_de_lit.value.type.value
									assign selected_variant_style_text = first_variant_with_value_option.metafields.custom.style_de_lit.value.text.value
									assign selected_variant_style_image = first_variant_with_value_option.metafields.custom.style_de_lit.value.image_du_lit.value
									assign selected_variant_style_feature = first_variant_with_value_option.metafields.custom.style_de_lit.value.features.value
								endif
							-%}
							<details
								class="product__variant-selects__swatch-style__details"
								{% if bed_style_active == bed_style %}
									open
								{% endif %}
								data-name="{{ picker_type | append: '-' | append: option.position }}"
							>
								<summary class="product__variant-selects__swatch-style__summary">
									{%- if selected_variant_style_image != blank -%}
										<span class="product__variant-selects__swatch-style__summary__image">
											{{
												selected_variant_style_image
												| image_url: width: 81
												| image_tag: loading: 'lazy', alt: selected_variant_style_label
											}}
										</span>
									{%- endif -%}
									<span class="product__variant-selects__swatch-style__summary__text-wrapper">
										<span class="product__variant-selects__swatch-style__summary__label">
											{%- if selected_variant_style_type != blank -%}
												{{ selected_variant_style_type }}
											{%- else -%}
												{{ bed_style }}
											{%- endif -%}
										</span>
										{%- if selected_variant_style_feature != blank -%}
											<span class="product__variant-selects__swatch-style__summary__features">
												{%- for feature in selected_variant_style_feature -%}
													<span class="product__variant-selects__swatch-style__summary__features__item">
														{{ feature }}
													</span>
												{%- endfor -%}
											</span>
										{%- endif -%}
									</span>
								</summary>
								<div class="product__variant-selects__swatch-style__wrapper">
									{%- if selected_variant_style_text != blank -%}
										<div class="product__variant-selects__swatch-style__text">
											{{ selected_variant_style_text }}
										</div>
									{%- endif -%}
									<div class="product__variant-selects__swatch-style__list">
										{%- render 'product-variant-options',
											product: product,
											option: option,
											position: option.position,
											custom_position: custom_position,
											block: block,
											picker_type: picker_type,
											bed_style: bed_style,
											section_id: section_id,
											is_bundle: is_bundle,
											reference_price: reference_price,
											reference_price_compare_at_price: reference_price_compare_at_price,
											selected_variant: selected_variant,
											has_changed_option_for_hidden: has_changed_option_for_hidden
										-%}
									</div>
								</div>
							</details>
						{%- endfor -%}
					</div>
				</fieldset>
			{%- elsif picker_type == 'button' -%}
				{%- comment -%}
					CALCUL DE L'ORDRE BASÉ SUR LE PRIX POUR LES OPTIONS VERSION

					Pour trier visuellement les versions du moins cher au plus cher,
					on crée un tableau de prix triés et on utilise l'index comme valeur d'ordre CSS
				{%- endcomment -%}
				{%- liquid
					# Récupère l'identifiant de l'option actuelle pour filtrer les variantes
					assign option_current = 'option' | append: option.position

					# Récupère les options sélectionnées pour filtrer les variantes (comme dans product-variant-options)
					assign sort_selected_option1 = selected_variant.options[0]
					assign sort_selected_option2 = selected_variant.options[1]
					assign sort_selected_option3 = selected_variant.options[2]

					if sort_selected_option1 == blank or sort_selected_option2 == blank
						for option_temp in product.options_with_values
							if option_temp.position == 1 and sort_selected_option1 == blank
								assign sort_selected_option1 = option_temp.selected_value
							elsif option_temp.position == 2 and sort_selected_option2 == blank
								assign sort_selected_option2 = option_temp.selected_value
							elsif option_temp.position == 3 and sort_selected_option3 == blank
								assign sort_selected_option3 = option_temp.selected_value
							endif
						endfor
					endif

					# Collecte tous les prix pour les valeurs de cette option
					assign all_prices_for_option = '' | split: ''
					for value in option.values
						# Récupère la variante correspondante en tenant compte des autres options sélectionnées
						if product.options.size == 1
							assign value_variant_for_sort = product.variants | where: 'option1', value | first
						elsif product.options.size == 2
							if option.position == 2
								assign value_variant_for_sort = product.variants | where: 'option1', sort_selected_option1 | where: 'option2', value | first
							else
								assign value_variant_for_sort = product.variants | where: 'option1', value | where: 'option2', sort_selected_option2 | first
							endif
						elsif product.options.size == 3
							if option.position == 3
								assign value_variant_for_sort = product.variants | where: 'option1', sort_selected_option1 | where: 'option2', sort_selected_option2 | where: 'option3', value | first
							elsif option.position == 2
								assign value_variant_for_sort = product.variants | where: 'option1', sort_selected_option1 | where: 'option2', value | first
							else
								assign value_variant_for_sort = product.variants | where: 'option1', value | where: 'option2', sort_selected_option2 | first
							endif
						elsif product.options.size == 4
							if option.position == 4
								# option4 n'existe pas en Liquid, on filtre manuellement via options[3]
								assign value_variant_for_sort = blank
								assign candidate_variants_option4 = product.variants | where: 'option1', sort_selected_option1 | where: 'option2', sort_selected_option2 | where: 'option3', sort_selected_option3
								for variant_candidate in candidate_variants_option4
									if variant_candidate.options[3] == value
										assign value_variant_for_sort = variant_candidate
										break
									endif
								endfor
							elsif option.position == 3
								assign value_variant_for_sort = product.variants | where: 'option1', sort_selected_option1 | where: 'option2', sort_selected_option2 | where: 'option3', value | first
							elsif option.position == 2
								assign value_variant_for_sort = product.variants | where: 'option1', sort_selected_option1 | where: 'option2', value | first
							else
								assign value_variant_for_sort = product.variants | where: 'option1', value | where: 'option2', sort_selected_option2 | first
							endif
						endif

						if value_variant_for_sort != blank and value_variant_for_sort.price != blank
							# Ajoute le prix au string (séparé par des virgules)
							assign all_prices_for_option_array = value_variant_for_sort.price | sort

							assign all_prices_for_option = all_prices_for_option | concat: all_prices_for_option_array
						endif
					endfor

					# Convertit le string en array et supprime les doublons
					assign unique_prices = all_prices_for_option | uniq

					# Trie les prix par ordre croissant (du moins cher au plus cher)
					# Note: Liquid sort fait un tri alphabétique, donc on doit gérer les nombres
					assign sorted_prices = unique_prices | sort
				-%}

				<fieldset
					class="js product-form__input product-form__input--pill product__variant-selects__pill product__variant-selects__pill--button{% if hide_information %} {{ class_hidden }}{% endif %}"
					style="order: {{ custom_position }};"
				>
					<legend class="form__label product__variant-selects__label product__variant-selects__pill__label">
						<span>
							{{ custom_position_label -}}
							{{- 'products.product.product_option_name_choose' | t: option_name: option_name_downcase }}
						</span>
						{% if selected_variant.metafields.custom.version_information.value.tooltip_content != blank %}
							<div class="tooltip">
								{{- 'icon-info.svg' | inline_asset_content -}}
								<div class="tooltip-content">
									{% if selected_variant.metafields.custom.version_information.value.tooltip_image != blank %}
										{{
											selected_variant.metafields.custom.version_information.value.tooltip_image
											| image_url: height: 80
											| image_tag: loading: 'lazy', alt: 'tooltip image'
										}}
									{% endif %}
									{{ selected_variant.metafields.custom.version_information.value.tooltip_content | metafield_tag }}
								</div>
							</div>
						{% endif %}
					</legend>
					<div class="product__variant-selects__pill__container">
						{%- render 'product-variant-options',
							product: product,
							option: option,
							position: option.position,
							custom_position: custom_position,
							block: block,
							picker_type: picker_type,
							section_id: section_id,
							is_bundle: is_bundle,
							reference_price: reference_price,
							reference_price_compare_at_price: reference_price_compare_at_price,
							selected_variant: selected_variant,
							has_changed_option_for_hidden: has_changed_option_for_hidden,
							sorted_prices: sorted_prices
						-%}
					</div>
				</fieldset>
			{%- elsif picker_type == 'variant_dropdown' or picker_type == 'swatch_variant_dropdown' -%}
				<div
					class="product-form__input product-form__input--dropdown product__variant-selects__dropdown product__variant-selects__dropdown--{{ picker_type }}{% if hide_information %} {{ class_hidden }}{% endif %}"
					style="order: {{ custom_position }};"
				>
					<variant-dropdown class="variant-dropdown{% if is_new_offer or is_pack_new %} variant-dropdown--new-offer{% endif %}{% if is_pack_new %} variant-dropdown--pack-new{% endif %}">
						<label
							class="form__label product__variant-selects__label product__variant-selects__dropdown__label"
							id="label-{{ section.id }}-{{ forloop.index0 }}"
							{% comment %}for="Option-{{ section.id }}-{{ forloop.index0 }}"{% endcomment %}
						>
							{{ custom_position_label -}}
							{{- 'products.product.product_option_name_choose' | t: option_name: option_name_downcase }}
							{% if selected_variant.metafields.custom.size_information != blank %}
								<div class="tooltip">
									{{- 'icon-info.svg' | inline_asset_content -}}
									<div class="tooltip-content">
										{{ selected_variant.metafields.custom.size_information | metafield_tag }}
									</div>
								</div>
							{% endif %}
						</label>

						<div class="variant-dropdown__container">
							<button
								type="button"
								class="variant-dropdown__selected"
								aria-haspopup="listbox"
								aria-expanded="false"
								aria-labelledby="label-{{ section.id }}-{{ forloop.index0 }}"
								id="variant-dropdown-button-{{ section.id }}-{{ forloop.index0 }}"
							>
								<span class="variant-dropdown__selected__left">
									{%- if picker_type == 'swatch_variant_dropdown'
										and selected_variant_color_image != blank
										or selected_variant_color_hexa != blank
									-%}
										<span class="variant-dropdown__selected__swatch">
											{%- if selected_variant_color_image != blank -%}
												{{
													selected_variant_color_image
													| image_url: width: 50
													| image_tag: loading: 'lazy', alt: selected_variant_color_label
												}}
											{%- else -%}
												<span
													class="variant-dropdown__selected__swatch__color"
													style="background-color: {{ selected_variant_color_hexa }};"
												></span>
											{%- endif -%}
										</span>
									{%- endif -%}
									<span class="variant-dropdown__selected__text">{{ current_option_selected_value_display }}</span>
								</span>

								<span class="variant-dropdown__selected__right">
									<span class="variant-dropdown__selected__price{% if selected_variant_compare_at_price > selected_variant_price %} variant-dropdown__selected__price--compare-price{% endif %}">
										{%- if picker_type == 'swatch_variant_dropdown' -%}
											{{ 'products.product.product_option_name_choose_swatch' | t }}
										{%- else -%}
											{%- if show_size_information_price and is_bundle != true -%}
												<span class="variant-dropdown__selected__price--last">
													{{ selected_variant_price | money }}
												</span>
												{%- if selected_variant_compare_at_price > selected_variant_price -%}
													<s class="variant-dropdown__selected__price--regular">
														{{ selected_variant_compare_at_price | money }}
													</s>
												{%- endif -%}
											{%- elsif show_size_information == false and is_bundle != true and is_new_offer -%}
												{{ 'products.product.product_option_name_choose_swatch' | t }}
											{%- elsif is_bundle -%}
												{%- liquid
													assign variant_price_to_use = selected_variant.price
													assign selected_variant_price_surplus = variant_price_to_use | minus: reference_price

													assign variant_compare_at_price_to_use = selected_variant.compare_at_price | default: selected_variant.price
													assign selected_variant_compare_at_price_surplus = variant_compare_at_price_to_use | minus: reference_price_compare_at_price
												-%}
												{%- if is_pack_new -%}
													{%- liquid
														# Pack-new : on s'appuie sur compare_at_price natif de la
														# variante (Shopify standard). Le badge % est calculé via
														# la formule standard arrondie.
														assign pack_badge_percent = 0
														if selected_variant.compare_at_price > selected_variant.price
															assign pack_badge_percent = selected_variant.compare_at_price | minus: selected_variant.price | times: 100.0 | divided_by: selected_variant.compare_at_price | round
														endif
													-%}
													<span class="variant-dropdown__selected__price--last">
														{{ selected_variant.price | money }}
													</span>
													{%- if selected_variant.compare_at_price > selected_variant.price -%}
														<s class="variant-dropdown__selected__price--regular">
															{{ selected_variant.compare_at_price | money }}
														</s>
													{%- endif -%}
													{%- if pack_badge_percent > 0 -%}
														<span class="badge price__badge-sale color-{{ settings.sale_badge_color_scheme }}">
															-{{ pack_badge_percent }}%
														</span>
													{%- endif -%}
												{%- elsif selected_variant_price_surplus > 0 -%}
													<span class="variant-dropdown__selected__price--last">
														{{ selected_variant_price_surplus | money | prepend: '+' }}
													</span>
													{%- if selected_variant_compare_at_price_surplus > selected_variant_price_surplus -%}
														<s class="variant-dropdown__selected__price--regular">
															{{ selected_variant_compare_at_price_surplus | money | prepend: '+' }}
														</s>
													{%- endif -%}
												{%- endif -%}
											{%- elsif parure_pillowcases -%}
												{%- liquid
													assign selected_variant_price_surplus = selected_variant.price | minus: selected_variant_price
													if selected_variant_price_surplus > 0
														echo selected_variant_price_surplus | money | prepend: '+'
													endif
												-%}
											{%- endif -%}
										{%- endif -%}
									</span>
									<span class="svg-wrapper">
										{{- 'icon-caret.svg' | inline_asset_content -}}
									</span>
								</span>
							</button>

							<ul
								class="variant-dropdown__options"
								role="listbox"
								aria-labelledby="label-{{ section.id }}-{{ forloop.index0 }}"
								aria-hidden="true"
								id="variant-dropdown-options-{{ section.id }}-{{ forloop.index0 }}"
							>
								{%- render 'product-variant-options',
									product: product,
									option: option,
									position: option.position,
									custom_position: custom_position,
									block: block,
									picker_type: picker_type,
									section_id: section_id,
									is_bundle: is_bundle,
									is_pack_new: is_pack_new,
									reference_price: reference_price,
									reference_price_compare_at_price: reference_price_compare_at_price,
									show_size_information_price: show_size_information_price,
									selected_variant: selected_variant,
									has_changed_option_for_hidden: has_changed_option_for_hidden
								-%}
							</ul>

							<div class="select visually-hidden" aria-hidden="true">
								<select
									id="Option-{{ section.id }}-{{ forloop.index0 }}"
									class="select__select"
									name="options[{{ option.name | escape }}]"
									form="{{ product_form_id }}"
									aria-hidden="true"
									tabindex="-1"
								>
									{%- render 'product-variant-options',
										product: product,
										option: option,
										position: option.position,
										custom_position: custom_position,
										block: block,
										picker_type: 'dropdown',
										section_id: section_id,
										is_bundle: is_bundle,
										reference_price: reference_price,
										reference_price_compare_at_price: reference_price_compare_at_price,
										show_size_information_price: show_size_information_price,
										selected_variant: selected_variant,
										has_changed_option_for_hidden: has_changed_option_for_hidden
									-%}
								</select>
							</div>
						</div>
						{%- if parure_pillowcases -%}
							{%- liquid
								for translation in options_names_for_parure_sheet
									assign has_parure_sheet_in_array = option_name_array | find: translation
									if has_parure_sheet_in_array
										assign has_parure_sheet_in_array = true
										break
									endif
								endfor

								for translation in options_names_for_parure_comforter
									assign has_parure_comforter_in_array = option_name_array | find: translation
									if has_parure_comforter_in_array
										assign has_parure_comforter_in_array = true
										break
									endif
								endfor
							-%}
							<div class="product__variant-selects__dropdown__size-information">
								{%- if has_parure_sheet_in_array -%}
									{{ 'products.product.parure_sheet' | t }}
								{%- elsif has_parure_comforter_in_array -%}
									{{ 'products.product.parure_comforter' | t }}
								{%- endif -%}
							</div>
						{%- elsif show_size_info_under_size -%}
							{%- comment -%}
								Help text `taille_information` rendu sous le picker taille :
								- prescan_has_format == false : pas de fake step Format → texte ici
								  comme avant (legacy).
								- current_size_has_single_format : la fake step Format existe mais
								  est masquée par le snippet (taille avec 1 seul format) → on
								  rapatrie le help ici pour conserver la bonne indentation
								  (inside variant-dropdown). Sans ça, le texte tomberait en
								  dehors du wrapper et serait mal aligné.
								(Booléen pré-calculé `show_size_info_under_size` car Liquid ne
								supporte pas les parenthèses dans une condition `or`/`and`.)
							{%- endcomment -%}
							<div class="product__variant-selects__dropdown__size-information">
								{{ selected_variant_size_information }}
							</div>
						{%- elsif current_is_bonnet and selected_variant_bonnet_information != blank -%}
							<div class="product__variant-selects__dropdown__size-information">
								{{ selected_variant_bonnet_information }}
							</div>
						{%- endif -%}
					</variant-dropdown>
				</div>
			{%- else -%}
				<div
					class="product-form__input product-form__input--dropdown product__variant-selects__dropdown{% if hide_information %} {{ class_hidden }}{% endif %}"
					style="order: {{ custom_position }};"
				>
					<label
						class="form__label product__variant-selects__label product__variant-selects__dropdown__label"
						for="Option-{{ section.id }}-{{ forloop.index0 }}"
					>
						{{ custom_position_label -}}
						{{- 'products.product.product_option_name_choose' | t: option_name: option_name_downcase }}
					</label>
					<div class="select">
						{%- if picker_type == 'swatch_dropdown' -%}
							<span
								data-selected-value
								class="dropdown-swatch"
							>
								{%- render 'swatch',
									swatch: current_option_selected_value.swatch,
									shape: block.settings.swatch_shape
								-%}
							</span>
						{%- endif -%}
						<select
							id="Option-{{ section.id }}-{{ forloop.index0 }}"
							class="select__select"
							name="options[{{ option.name | escape }}]"
							form="{{ product_form_id }}"
						>
							{%- render 'product-variant-options',
								product: product,
								option: option,
								position: option.position,
								custom_position: custom_position,
								block: block,
								picker_type: picker_type,
								section_id: section_id,
								is_bundle: is_bundle,
								reference_price: reference_price,
								reference_price_compare_at_price: reference_price_compare_at_price,
								selected_variant: selected_variant,
								has_changed_option_for_hidden: has_changed_option_for_hidden
							-%}
						</select>
						<span class="svg-wrapper">
							{{- 'icon-caret.svg' | inline_asset_content -}}
						</span>
					</div>
				</div>
			{%- endif -%}
		{%- endfor -%}

		{%- if prescan_has_format -%}
			{%- liquid
				# Position et label de la fake step "Format" : juste après la taille (= 2),
				# ou décalée à 3 si bonnet occupe déjà la position 2.
				assign format_step_custom_position = 2
				if prescan_has_bonnet
					assign format_step_custom_position = 3
				endif
				assign format_step_custom_position_label = format_step_custom_position | append: '. '
				if is_new_offer
					assign format_step_custom_position_label = ''
				endif
			-%}
			{%- render 'product-variant-picker-format',
				product: product,
				selected_variant: selected_variant,
				section_id: section_id,
				size_option_index: prescan_size_option_index,
				custom_position: format_step_custom_position,
				custom_position_label: format_step_custom_position_label,
				selected_variant_size_information: selected_variant_size_information,
				is_new_offer: is_new_offer,
				is_pack_new: is_pack_new,
				hide_extras: hide_extras
			-%}
		{%- endif -%}

		<script
			type="application/json"
			data-selected-variant
			{% if selected_variant != blank and selected_variant.metafields.custom.hidden_variant.value == true %}
				data-selected-variant-hidden
			{% endif %}
		>
			{{ selected_variant | json }}
		</script>
		{%- if parure_pillowcases or version_option_position != blank -%}
			{%- liquid
				assign array_option1_values = '' | split: ''
				assign array_option1_id = '' | split: ''
				assign array_option2_values = '' | split: ''
				assign array_option2_id = '' | split: ''
				assign array_option3_values = '' | split: ''
				assign array_option3_id = '' | split: ''
				assign array_option4_values = '' | split: ''
				assign array_option4_id = '' | split: ''

				for option in product.options_with_values
					for value in option.values
						assign array_id = value.id | sort
						assign array_value = value | sort
						if option.position == 1
							assign array_option1_values = array_option1_values | concat: array_value
							assign array_option1_id = array_option1_id | concat: array_id
						endif
						if option.position == 2
							assign array_option2_values = array_option2_values | concat: array_value
							assign array_option2_id = array_option2_id | concat: array_id
						endif
						if option.position == 3
							assign array_option3_values = array_option3_values | concat: array_value
							assign array_option3_id = array_option3_id | concat: array_id
						endif
						if option.position == 4
							assign array_option4_values = array_option4_values | concat: array_value
							assign array_option4_id = array_option4_id | concat: array_id
						endif
					endfor
				endfor

				assign object_product_options = null | default: option1_values: array_option1_values, option1_id: array_option1_id, option2_values: array_option2_values, option2_id: array_option2_id, option3_values: array_option3_values, option3_id: array_option3_id, option4_values: array_option4_values, option4_id: array_option4_id
			-%}

			<script type="application/json" data-product-options>
				{{ object_product_options | json }}
			</script>

			<script type="application/json" data-product-variants>
				{{ product.variants | json }}
			</script>

			<script type="application/json" data-hidden-variant-ids>
				{%- liquid
					assign hidden_ids = '' | split: ''
					for variant in product.variants
						if variant.metafields.custom.hidden_variant.value == true
							assign variant_id_array = variant.id | sort
							assign hidden_ids = hidden_ids | concat: variant_id_array
						endif
					endfor

					echo hidden_ids | json
				-%}
			</script>
		{%- endif -%}
	</variant-selects>
{%- endunless -%}
