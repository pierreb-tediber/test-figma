{% comment %}
  Renders a megamenu for the header.

  Usage:
  {% render 'header-mega-menu' %}
{% endcomment %}

<div class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- if get_url contains 'section_id' or get_url contains 'sections' -%}
      {%- render 'mega-menu-content', section: section -%}
    {%- else -%}
      {%- for link in section.settings.menu.links -%}
        {%- liquid
          assign link_title = link.title | handle
          assign current_block = blank
          assign custom_link_block = blank
          assign link_color = blank
          assign link_weight = blank
          assign link_icon = blank
          assign link_icon_class = ''

          # Chercher d'abord un bloc custom-link (prioritaire)
          for block in section.blocks
            if block.type == 'custom-link'
              assign block_title = block.settings.title | handle
              if block_title == link_title
                assign custom_link_block = block
                break
              endif
            endif
          endfor

          # Si custom-link trouvé, utiliser ses paramètres
          if custom_link_block != blank
            assign link_color = custom_link_block.settings.color
            assign link_weight = custom_link_block.settings.weight
            assign link_icon = custom_link_block.settings.icon
            if custom_link_block.settings.keep_icon_color
              assign link_icon_class = 'keep-icon-color'
            endif
          else
            # Sinon, chercher les autres blocs
            for block in section.blocks
              if block.type != 'push-global' and block.type != 'custom-link'
                assign block_title = block.settings.title | handle
                if block_title == link_title
                  assign current_block = block
                  break
                endif
              endif
            endfor

            if current_block != blank
              assign link_color = current_block.settings.color
            endif
          endif
        -%}

        <li>
          {%- if link.links != blank -%}
            <header-menu data-section-id="{{ section.id }}">
              <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu details-animate">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset{% if link_color != blank or link_weight != blank %} modified{% endif %}"
                >
                  <a href="{{ link.url }}">
                    <span
                      {% if link_color != blank or link_weight != blank %}
                        style="{% if link_color != blank %}color: {{ link_color }};{% endif %}{% if link_weight != blank %} font-weight: {{ link_weight }};{% endif %}"
                      {% endif %}
                    >
                      {%- if link_icon != blank -%}
                        {%- if link_icon != blank -%}
                          <img
                            src="{{ link_icon | image_url: width: 16 }}"
                            srcset="{{ link_icon | image_url: width: 1 }} 1w, {{ link_icon | image_url: width: 16 }} 16w"
                            sizes="(max-width: 1200px) 1px, 16px"
                            loading="eager"
                            width="16"
                            height="16"
                            alt="icon {{- link.title | escape -}}"
                            {% if link_icon_class != blank %} class="{{ link_icon_class }}"{% endif %}
                          >
                        {%- endif -%}
                      {%- endif -%}
                      <span class="header__menu-item__label">{{- link.title | escape -}}</span>
                    </span>
                  </a>
                </summary>
                <div
                  id="MegaMenu-Content-{{ forloop.index }}"
                  class="mega-menu__content page-width details__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                  tabindex="-1"
                >
                  <div class="header__menu__loading header__mega-menu__loading">
                    {% render 'loading-spinner' %}
                  </div>
                </div>
              </details>
            </header-menu>
          {%- else -%}
            <a
              id="HeaderMenu-{{ link.handle }}"
              href="{{ link.url }}"
              class="header__menu-item list-menu__item link link--text focus-inset{% if link_color != blank or link_weight != blank %} modified{% endif %}"
              {% if link.current %}
                aria-current="page"
              {% endif %}
            >
              <span
                {% if link_color != blank or link_weight != blank %}
                  style="{% if link_color != blank %}color: {{ link_color }};{% endif %}{% if link_weight != blank %} font-weight: {{ link_weight }};{% endif %}"
                {% endif %}
              >
                {%- if link_icon != blank -%}
                  {%- if link_icon != blank -%}
                    <img
                      src="{{ link_icon | image_url: width: 16 }}"
                      srcset="{{ link_icon | image_url: width: 1 }} 1w, {{ link_icon | image_url: width: 16 }} 16w"
                      sizes="(max-width: 1200px) 1px, 16px"
                      loading="eager"
                      width="16"
                      height="16"
                      alt="icon {{- link.title | escape -}}"
                      {% if link_icon_class != blank %} class="{{ link_icon_class }}"{% endif %}
                    >
                  {%- endif -%}
                {%- endif -%}
                <span class="header__menu-item__label">{{- link.title | escape -}}</span>
              </span>
            </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    {%- endif -%}
  </ul>
</div>
