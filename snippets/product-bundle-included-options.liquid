{% comment %}
	Renders product variant options

	Accepts:
	- product: {Object} product object.
	- option: {Object} current product_option object.
	- block: {Object} block object.
	- picker_type: {String} type of picker to dispay
	- section_id: {String} id of the section


	Usage:
	{% render 'product-variant-options',
	  product: product,
	  option: option,
	  block: block,
	  picker_type: picker_type,
	  section_id: section_id
	%}
{% endcomment %}

{%- liquid
	# Détection option taille + format par défaut (Monobloc) pour masquage du suffixe à l'affichage
	# Les attributs value/data-value gardent la valeur Shopify brute, seul le texte affiché est nettoyé
	assign default_format_lc = 'products.product.default_format_for_size_value' | t | downcase | strip
	assign options_names_for_size_translated = 'products.product.options_names_for_size' | t | downcase | replace: ', ', ','
	assign options_names_for_size = options_names_for_size_translated | split: ',' | uniq
	assign size_option_name_array = option.name | downcase | split: ' ' | uniq
	assign is_size_option = false
	for size_option_name in size_option_name_array
		if options_names_for_size contains size_option_name
			assign is_size_option = true
			break
		endif
	endfor
-%}

{%- for value in option.values -%}
	{%- liquid
		assign swatch_focal_point = null

		# Valeur d'affichage : strippe les suffixes Monobloc ET Bibloc (et seulement ceux-là)
		# pour l'option taille. default_format_lc vient de la locale (= "monobloc"),
		# bibloc hardcodé car convention métier Tediber non traduite.
		assign value_display = value
		if is_size_option
			assign value_parts_display = value | split: ' - '
			if value_parts_display.size > 1
				assign value_format_display_lc = value_parts_display | last | strip | downcase
				if value_format_display_lc == default_format_lc or value_format_display_lc == 'bibloc'
					assign value_display = value_parts_display | first | strip
				endif
			endif
		endif

		if value.swatch.image
			assign image_url = value.swatch.image | image_url: width: 50
			assign swatch_value = 'url(' | append: image_url | append: ')'
			assign swatch_focal_point = value.swatch.image.presentation.focal_point
		elsif value.swatch.color
			assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
		else
			assign swatch_value = null
		endif

		comment
			VÉRIFICATION SI L'OPTION A ÉTÉ MODIFIÉE

			Si la variante sélectionnée est différente de la variante actuelle,
			on assigne true à has_changed_option_for_hidden
		endcomment
		assign has_changed_option_for_hidden = false
		if selected_variant != blank and product.selected_or_first_available_variant.id != selected_variant.id
			assign has_changed_option_for_hidden = true
		else
			assign option_disabled = true
			if value.available
				assign option_disabled = false
			endif
		endif

		# Récupère la variante
		assign value_variant = value.variant

		# Récupère la position de l'option actuelle
		assign option_current = 'option' | append: option.position

		# Récupère la première variante pour l'option actuelle correspondant à la valeur actuelle
		assign first_variant_with_value_option = product.variants | where: option_current, value | first

		unless variant_ids contains value_variant.id
			continue
		endunless

		comment
			VÉRIFICATION DES VARIANTES CACHÉES/INDISPONIBLES POUR LES OPTIONS

			On ajoute une vérification supplémentaire pour cacher les valeurs dont toutes les variantes accessibles sont cachées/indisponibles
		endcomment
		assign not_show_value = false

		if product.metafields.custom.combined_listings_produit_parent.value != blank
			# Récupère la première variante pour l'option actuelle correspondant à la valeur actuelle
			assign first_variant_with_value_option = product.metafields.custom.combined_listings_produit_parent.value.variants | where: option_current, value | first
			# Récupère toutes les variantes possibles pour le produit parent
			assign all_variants = product.metafields.custom.combined_listings_produit_parent.value.variants
		else
			assign all_variants = product.variants
		endif

		comment
			VÉRIFICATION DES VARIANTES CACHÉES/INDISPONIBLES POUR LES OPTIONS

			On ajoute une vérification supplémentaire pour cacher les valeurs dont toutes les variantes accessibles sont cachées/indisponibles
		endcomment
		if product.options.size == 1
			assign has_hidden_variant_option = false

			# Récupère les variantes possibles pour l'option actuelle
			assign candidate_variants_matching_options = all_variants | where: 'option1', value

			# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
			assign option_all_hidden = true
			for variant_check in candidate_variants_matching_options
				if variant_check.metafields.custom.hidden_variant.value != true
					assign option_all_hidden = false
					break
				endif
			endfor

			# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option
			if option_all_hidden == true
				assign has_hidden_variant_option = true
			else
				# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
				for variant_check in candidate_variants_matching_options
					if variant_check.options[0] == value
						if variant_check.metafields.custom.hidden_variant.value == true
							assign has_hidden_variant_option = true
							break
						endif
					endif
				endfor
			endif

			# Si has_changed_option_for_hidden la valeur value.available ne fonctionne plus correctement
			# On doit verifier si la valeur actuelle est vraiment pas available donc on doit boucler sur les variantes pour verifier si la valeur actuelle est disponible sur une des variantes
			if has_changed_option_for_hidden == true and value.product_url == blank
				assign option_disabled = true
				for variant_check in candidate_variants_matching_options
					assign option_position = option.position | minus: 1
					if variant_check.options[option_position] == value
						if variant_check.available == true
							assign option_disabled = false
							break
						endif
					endif
				endfor
			endif
		elsif product.options.size == 2
			assign has_hidden_variant_option = false
			assign first_option_selected_variant_1 = blank
			assign first_option_selected_variant_2 = blank

			if selected_variant != blank
				assign first_option_selected_variant_1 = selected_variant.options[0]
				assign first_option_selected_variant_2 = selected_variant.options[1]
			endif

			if first_option_selected_variant_1 == blank or first_option_selected_variant_2 == blank
				for option_temp in product.options_with_values
					if option_temp.position == 1
						assign first_option_selected_variant_1 = option_temp.selected_value
					elsif option_temp.position == 2
						assign first_option_selected_variant_2 = option_temp.selected_value
						break
					endif
				endfor
			endif

			# Récupère les variantes possibles pour l'option actuelle, LIMITE shopify 250 variantes avec le where
			if value.product_url == blank and first_option_selected_variant_1.product_url != blank and first_option_selected_variant_1.variant != blank
				assign all_variants = first_option_selected_variant_1.variant.product.variants
			elsif value.product_url != blank and value.variant != blank
				assign all_variants = value.variant.product.variants
			endif

			# Récupère les variantes possibles pour l'option actuelle
			if option.position == 2
				assign candidate_variants_matching_options = all_variants | where: 'option1', first_option_selected_variant_1 | where: 'option2', value
			else
				assign candidate_variants_matching_options = all_variants | where: 'option1', value
				if value.product_url != blank and custom_position != option.position
					assign candidate_variants_matching_options = all_variants | where: 'option1', value | where: 'option2', first_option_selected_variant_2
				endif
			endif

			# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
			assign option_all_hidden = true
			for variant_check in candidate_variants_matching_options
				if variant_check.metafields.custom.hidden_variant.value != true
					assign option_all_hidden = false
					break
				endif
			endfor

			# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option
			if option_all_hidden == true
				assign has_hidden_variant_option = true
			else
				# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
				for variant_check in candidate_variants_matching_options
					if variant_check.options[0] == first_option_selected_variant_1 and variant_check.options[1] == value
						if variant_check.metafields.custom.hidden_variant.value == true
							assign has_hidden_variant_option = true
							break
						endif
					endif
				endfor
			endif

			# Si has_changed_option_for_hidden la valeur value.available ne fonctionne plus correctement
			# On doit verifier si la valeur actuelle est vraiment pas available donc on doit boucler sur les variantes pour verifier si la valeur actuelle est disponible sur une des variantes
			if has_changed_option_for_hidden == true and value.product_url == blank
				assign option_disabled = true
				for variant_check in candidate_variants_matching_options
					assign option_position = option.position | minus: 1
					if variant_check.options[option_position] == value
						if variant_check.available == true
							assign option_disabled = false
							break
						endif
					endif
				endfor
			endif

		elsif product.options.size == 3
			assign has_hidden_variant_option = false
			assign first_option_selected_variant_1 = blank
			assign first_option_selected_variant_2 = blank

			if selected_variant != blank
				assign first_option_selected_variant_1 = selected_variant.options[0]
				assign first_option_selected_variant_2 = selected_variant.options[1]
			endif

			if first_option_selected_variant_1 == blank or first_option_selected_variant_2 == blank
				for option_temp in product.options_with_values
					if option_temp.position == 1
						assign first_option_selected_variant_1 = option_temp.selected_value
					elsif option_temp.position == 2
						assign first_option_selected_variant_2 = option_temp.selected_value
						break
					endif
				endfor
			endif

			# Récupère les variantes possibles pour l'option actuelle, LIMITE shopify 250 variantes avec le where
			if value.product_url == blank and first_option_selected_variant_1.product_url != blank and first_option_selected_variant_1.variant != blank
				assign all_variants = first_option_selected_variant_1.variant.product.variants
			elsif value.product_url != blank and value.variant != blank
				assign all_variants = value.variant.product.variants
			endif

			# Récupère les variantes possibles pour l'option actuelle
			if option.position == 3
				assign candidate_variants_matching_options = all_variants | where: 'option1', first_option_selected_variant_1 | where: 'option2', first_option_selected_variant_2 | where: 'option3', value
			elsif option.position == 2
				assign candidate_variants_matching_options = all_variants | where: 'option1', first_option_selected_variant_1 | where: 'option2', value
			else
				assign candidate_variants_matching_options = all_variants | where: 'option1', value
				if value.product_url != blank and custom_position != option.position
					assign candidate_variants_matching_options = all_variants | where: 'option1', value | where: 'option2', first_option_selected_variant_2
				endif
			endif

			# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
			assign option_all_hidden = true
			for variant_check in candidate_variants_matching_options
				if variant_check.metafields.custom.hidden_variant.value != true
					assign option_all_hidden = false
					break
				endif
			endfor

			# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option
			if option_all_hidden == true
				assign has_hidden_variant_option = true
			else
				# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
				for variant_check in candidate_variants_matching_options
					if variant_check.options[0] == first_option_selected_variant_1 and variant_check.options[1] == first_option_selected_variant_2 and variant_check.options[2] == value
						if variant_check.metafields.custom.hidden_variant.value == true
							assign has_hidden_variant_option = true
							break
						endif
					endif
				endfor
			endif

			# Si has_changed_option_for_hidden la valeur value.available ne fonctionne plus correctement
			# On doit verifier si la valeur actuelle est vraiment pas available donc on doit boucler sur les variantes pour verifier si la valeur actuelle est disponible sur une des variantes
			if has_changed_option_for_hidden == true and value.product_url == blank
				assign option_disabled = true
				for variant_check in candidate_variants_matching_options
					assign option_position = option.position | minus: 1
					if variant_check.options[option_position] == value
						if variant_check.available == true
							assign option_disabled = false
							break
						endif
					endif
				endfor
			endif
		elsif product.options.size == 4
			assign has_hidden_variant_option = false
			assign first_option_selected_variant_1 = blank
			assign first_option_selected_variant_2 = blank
			assign first_option_selected_variant_3 = blank

			if selected_variant != blank
				assign first_option_selected_variant_1 = selected_variant.options[0]
				assign first_option_selected_variant_2 = selected_variant.options[1]
				assign first_option_selected_variant_3 = selected_variant.options[2]
			endif

			if first_option_selected_variant_1 == blank or first_option_selected_variant_2 == blank or first_option_selected_variant_3 == blank
				for option_temp in product.options_with_values
					if option_temp.position == 1
						assign first_option_selected_variant_1 = option_temp.selected_value
					elsif option_temp.position == 2
						assign first_option_selected_variant_2 = option_temp.selected_value
					elsif option_temp.position == 3
						assign first_option_selected_variant_3 = option_temp.selected_value
					endif
				endfor
			endif

			# Récupère les variantes possibles pour l'option actuelle, LIMITE shopify 250 variantes avec le where
			if value.product_url == blank and first_option_selected_variant_1.product_url != blank and first_option_selected_variant_1.variant != blank
				assign all_variants = first_option_selected_variant_1.variant.product.variants
			elsif value.product_url != blank and value.variant != blank
				assign all_variants = value.variant.product.variants
			endif

			# Récupère les variantes possibles pour l'option actuelle
			if option.position == 4
				assign candidate_variants_matching_options = all_variants | where: 'option1', first_option_selected_variant_1 | where: 'option2', first_option_selected_variant_2 | where: 'option3', first_option_selected_variant_3
			elsif option.position == 3
				assign candidate_variants_matching_options = all_variants | where: 'option1', first_option_selected_variant_1 | where: 'option2', first_option_selected_variant_2 | where: 'option3', value
			elsif option.position == 2
				assign candidate_variants_matching_options = all_variants | where: 'option1', first_option_selected_variant_1 | where: 'option2', value
			else
				assign candidate_variants_matching_options = all_variants | where: 'option1', value
				if value.product_url != blank and custom_position != option.position
					assign candidate_variants_matching_options = all_variants | where: 'option1', value | where: 'option2', first_option_selected_variant_2
				endif
			endif

			# Vérifie si toutes les variantes sont cachées/indisponibles pour l'option actuelle
			assign option_all_hidden = true
			for variant_check in candidate_variants_matching_options
				if variant_check.metafields.custom.hidden_variant.value != true
					assign option_all_hidden = false
					break
				endif
			endfor

			# Si toutes les variantes sont cachées/indisponibles, on assigne true à has_hidden_variant_option
			if option_all_hidden == true
				assign has_hidden_variant_option = true
			else
				# Sinon, on vérifie si la valeur actuelle est disponible sur une des variantes
				for variant_check in candidate_variants_matching_options
					if variant_check.options[0] == first_option_selected_variant_1 and variant_check.options[1] == first_option_selected_variant_2 and variant_check.options[2] == first_option_selected_variant_3 and variant_check.options[3] == value
						if variant_check.metafields.custom.hidden_variant.value == true
							assign has_hidden_variant_option = true
							break
						endif
					endif
				endfor
			endif

			# Si has_changed_option_for_hidden la valeur value.available ne fonctionne plus correctement
			# On doit verifier si la valeur actuelle est vraiment pas available donc on doit boucler sur les variantes pour verifier si la valeur actuelle est disponible sur une des variantes
			if has_changed_option_for_hidden == true and value.product_url == blank
				assign option_disabled = true
				for variant_check in candidate_variants_matching_options
					assign option_position = option.position | minus: 1
					if variant_check.options[option_position] == value
						if variant_check.available == true
							assign option_disabled = false
							break
						endif
					endif
				endfor
			endif
		endif

		comment
			Si aucune variante non cachée n'a été trouvée, on cache cette option
		endcomment
		if has_hidden_variant_option == true
			assign not_show_value = true
		endif

		# Assigne la variante par défaut si aucune correspondance trouvée
		if value_variant == blank and first_variant_with_value_option != blank
			assign value_variant = first_variant_with_value_option
		endif

		# Calcule la valeur sélectionnée pour cette option basée sur la variante spécifique
		assign current_option_selected = false
		if selected_variant != blank
			assign option_index = option.position | minus: 1
			# Si la valeur sélectionnée pour cette option est différente de la valeur de la variante sélectionnée, on assigne la valeur de la variante sélectionnée
			if selected_variant.options[option_index] == value
				assign current_option_selected = true
			endif
		else
			assign current_option_selected = value.selected
		endif

		if current_option_selected == true and not_show_value == true
			assign option_disabled = true
			assign not_show_value = false
		endif
	-%}

	{%- capture input_id -%}
    {{ section_id }}-{{ option.position }}-{{ forloop.index0 }}-bundle-item-included-{{ value.id }}
  {%- endcapture -%}

	{%- capture input_dataset -%}
    data-product-url="{{ value.product_url }}"
    data-option-value-id="{{ value.id }}"
  {%- endcapture -%}

	{%- if picker_type == 'variant_dropdown' or picker_type == 'swatch_variant_dropdown' -%}
		{%- liquid
			# Pack-new : sous-titre du card = taille_information de la variante
			# associée (ex. "240 x 220 cm" sous "Petit tombant").
			assign included_option_sub = blank
			if is_pack_new
				if value_variant != blank
					assign included_option_sub = value_variant.metafields.custom.taille_information.value
				endif
				if included_option_sub == blank and first_variant_with_value_option != blank
					assign included_option_sub = first_variant_with_value_option.metafields.custom.taille_information.value
				endif
			endif
		-%}
		<li
			class="variant-dropdown__option{% if not_show_value %} visually-hidden{% endif %}{% if is_pack_new %} variant-dropdown__option--pack-new-included{% endif %}"
			role="option"
			data-value="{{ value | escape }}"
			tabindex="-1"
			{% if current_option_selected %}
				aria-selected="true"
			{% endif %}
			{% if option_disabled %}
				data-disabled="true"
			{% endif %}
		>
			<span class="variant-dropdown__option__container">
				{% if option_disabled -%}
					<span class="variant-dropdown__option-text variant-dropdown__option-text--disabled">
						{{- 'products.product.value_unavailable' | t: option_value: value_display -}}
					</span>
				{%- else -%}
					<span class="variant-dropdown__option-text">{{- value_display -}}</span>
				{%- endif %}
				{%- if is_pack_new and included_option_sub != blank -%}
					<span class="variant-dropdown__option-sub">{{ included_option_sub }}</span>
				{%- endif -%}
			</span>
		</li>
	{%- elsif picker_type == 'dropdown' or picker_type == 'swatch_dropdown' -%}
		<option
			id="{{ input_id }}"
			value="{{ value | escape }}"
			{% if current_option_selected %}
				selected="selected"
			{% endif %}
			{% if swatch_value and picker_type == 'swatch_dropdown' %}
				data-option-swatch-value="{{ swatch_value }}"
				{% if swatch_focal_point %}
					data-option-swatch-focal-point="{{ swatch_focal_point }}"
				{% endif %}
			{% endif %}
			{{ input_dataset }}
		>
			{% if option_disabled -%}
				{{- 'products.product.value_unavailable' | t: option_value: value_display -}}
			{%- else -%}
				{{- value_display -}}
			{%- endif %}
		</option>
	{%- endif -%}
{%- endfor -%}
