{% comment %}
	Renders a product card

	Accepts:
	- card_product: {Object} Product Liquid object (optional)
	- media_aspect_ratio: {String} Size of the product image card. Values are "square" and "portrait". Default is "square" (optional)
	- image_shape: {String} Image mask to apply to the product image card. Values are "arch", "blob", "chevronleft", "chevronright", "diamond", "parallelogram", and "round". (optional)
	- show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
	- show_vendor: {Boolean} Show the product vendor. Default: false
	- show_h2: {Boolean} Show the tag h2. Default: false
	- no_hn: {Boolean} Show the tag div. Default: false
	- show_rating: {Boolean} Show the product rating. Default: false
	- extend_height: {Boolean} Card height extends to available container space. Default: true (optional)
	- lazy_load: {Boolean} Image should be lazy loaded. Default: true (optional)
	- strong_lazy_load: {Boolean} Image should be lazy loaded with src and srcset replaced. Default: false (optional)
	- skip_styles: {Boolean} Don't include component styles. Useful when rendering multiple product cards in a loop. Default: false (optional)
	- quick_add: {Boolean} Show the quick add button.
	- section_id: {String} The ID of the section that contains this card.
	- horizontal_class: {Boolean} Add a card--horizontal class if set to true. Default: false (optional)
	- horizontal_layout_menu: {Boolean} Add a card--horizontal class if set to true. Default: false (optional)
	- horizontal_mobile_class: {Boolean} Add a card--horizontal class if set to true. Default: false (optional)
	- horizontal_quick_add: {Boolean} Changes the quick add button styles when set to true. Default: false (optional)
	- placeholder_image: {String} The placeholder image to use when no product exists. Default: 'product-apparel-2' (optional)
	- is_variant: {Boolean} Whether the product is a variant. Default: false (optional)
	- variant: {Object} The variant object. Default: null (optional)
	- is_current_product: {Boolean} Whether this product is the current product being viewed. Disables the link when true. Default: false (optional)
	- is_bundle: {Boolean} Whether the product is a bundle. Default: false (optional)
	- first_attr_only: {Boolean} Whether to show only the first attribute. Default: false (optional)
	- hide_color_swatches: {Boolean} Hide color swatches. Default: false (optional)
	- show_scores: {Boolean} Show product scores (notes). Default: false (optional)
	- show_extended_scores: {Boolean} Show extended scores (durée de vie, indépendance, réparabilité). Default: false (optional)
	- show_menu_image: {Boolean} Show image menu with métafields
	- show_trustpilot: {Boolean} Show Trustpilot mini widget below the title. Default: false

	Usage:
	{% render 'card-product', show_vendor: section.settings.show_vendor %}
{% endcomment %}
{%- unless skip_styles -%}
	{{ 'component-rating.css' | asset_url | stylesheet_tag }}
	{{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}

	{{ 'component-price.css' | asset_url | stylesheet_tag }}
	{{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
	{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if card_product and card_product != empty -%}
	{%- liquid
		assign has_menu_image = false
		assign card_product_featured_media = card_product.featured_media
		assign card_product_media = card_product.media[1]
		assign card_product_images_desktop = card_product.metafields.custom.card_product_image_desktop.value | compact
		assign card_product_images_mobile = card_product.metafields.custom.card_product_image_mobile.value | compact
		if show_menu_image
			if card_product.metafields.custom.card_produit_menu_image_desktop.value != blank
				assign card_product_images_desktop = card_product.metafields.custom.card_produit_menu_image_desktop.value | compact
				assign has_menu_image = true
			endif
			if card_product.metafields.custom.card_produit_menu_image_mobile.value != blank
				assign card_product_images_mobile = card_product.metafields.custom.card_produit_menu_image_mobile.value | compact
			endif
		endif
		if card_product.metafields.custom.combined_listings_premier_produit_enfant.value != blank
			assign card_product_combined_listings = card_product.metafields.custom.combined_listings_premier_produit_enfant.value
			assign card_product_featured_media = card_product_combined_listings.featured_media
			assign card_product_media = card_product_combined_listings.media[1]
			assign card_product_images_desktop = card_product_combined_listings.metafields.custom.card_product_image_desktop.value | compact
			assign card_product_images_mobile = card_product_combined_listings.metafields.custom.card_product_image_mobile.value | compact
			if show_menu_image
				if card_product_combined_listings.metafields.custom.card_produit_menu_image_desktop.value != blank
					assign card_product_images_desktop = card_product_combined_listings.metafields.custom.card_produit_menu_image_desktop.value | compact
					assign has_menu_image = true
				endif
				if card_product_combined_listings.metafields.custom.card_produit_menu_image_mobile.value != blank
					assign card_product_images_mobile = card_product_combined_listings.metafields.custom.card_produit_menu_image_mobile.value | compact
				endif
			endif
		elsif is_variant and variant.featured_image != blank
			assign card_product_featured_media = variant.featured_image
			assign card_product_media = card_product.media[1]
		endif

		# Images desktop: priorité au métachamp, ordre primaire puis secondaire
		if card_product_images_desktop != blank
			if card_product_images_desktop[0] != blank
				assign card_product_featured_media = card_product_images_desktop[0]
			endif

			if card_product_images_desktop[1] != blank
				assign card_product_media = card_product_images_desktop[1]
			endif
		endif

		# Image mobile primaire (pas de secondaire sur mobile)
		assign card_product_mobile_primary_media = card_product_featured_media
		if card_product_images_mobile != blank and card_product_images_mobile[0] != blank
			assign card_product_mobile_primary_media = card_product_images_mobile[0]
		endif

		comment
			DÉTECTION OFFRE LIMITÉE (countdown ribbon + override visuels)

			Si une offre limitée est active, le visuel mobile/desktop du card
			est remplacé par les images du métaobject (priorité maximale).
			Le countdown sera également rendu dans card__content (en haut).
			Fallback sur le premier enfant pour les combined listings.
		endcomment
		assign offre = card_product.metafields.custom.offre_limitee.value
		if offre == blank and card_product.metafields.custom.combined_listings_premier_produit_enfant.value != blank
			assign offre = card_product.metafields.custom.combined_listings_premier_produit_enfant.value.metafields.custom.offre_limitee.value
		endif
		assign offre_active = false
		assign offre_initial_timer = ''
		assign card_product_mobile_hover_media = blank
		if offre != blank and offre.date_fin != blank
			assign now_ts = 'now' | date: '%s' | times: 1
			assign end_ts = offre.date_fin | date: '%s' | times: 1
			assign start_ts = 0
			if offre.date_debut != blank
				assign start_ts = offre.date_debut | date: '%s' | times: 1
			endif
			if end_ts > now_ts and start_ts <= now_ts
				assign offre_active = true

				# Override des visuels: l'offre prime sur toutes les autres conditions
				if offre.image_desktop != blank
					assign card_product_featured_media = offre.image_desktop
				endif
				if offre.image_mobile != blank
					assign card_product_mobile_primary_media = offre.image_mobile
				endif
				if offre.image_hover_desktop != blank
					assign card_product_media = offre.image_hover_desktop
				endif
				if offre.image_hover_mobile != blank
					assign card_product_mobile_hover_media = offre.image_hover_mobile
				endif

				# Pré-calcul du timer pour éviter le flicker à l'hydratation
				assign remaining = end_ts | minus: now_ts
				assign days = remaining | divided_by: 86400
				assign days = days | floor
				assign remaining_h = remaining | modulo: 86400
				assign hours = remaining_h | divided_by: 3600
				assign hours = hours | floor
				assign remaining_m = remaining_h | modulo: 3600
				assign minutes = remaining_m | divided_by: 60
				assign minutes = minutes | floor
				assign seconds = remaining_m | modulo: 60
				assign d_str = days | append: '' | prepend: '00' | slice: -2, 2
				assign h_str = hours | append: '' | prepend: '00' | slice: -2, 2
				assign m_str = minutes | append: '' | prepend: '00' | slice: -2, 2
				assign s_str = seconds | append: '' | prepend: '00' | slice: -2, 2
				assign offre_initial_timer = d_str | append: 'j ' | append: h_str | append: 'h ' | append: m_str | append: 'm ' | append: s_str | append: 's'
			endif
		endif

		assign ratio = 1
		if card_product_featured_media or card_product.product.featured_media and media_aspect_ratio == 'portrait'
			assign ratio = 0.77
			if show_menu_image
				assign ratio = 0.87
			endif
		elsif card_product_featured_media and media_aspect_ratio == 'adapt'
			assign ratio = card_product_featured_media.aspect_ratio
		endif
		if ratio == 0 or ratio == null
			assign ratio = 1
		endif

		assign card_product_tag = 'h3'
		if show_h2
			assign card_product_tag = 'h2'
		elsif no_hn
			assign card_product_tag = 'div'
		endif

		# Bundle
		assign is_bundle = false
		assign bundle_configurator = card_product.metafields.custom.pack_configurateur.value
		if bundle_configurator != blank
			assign is_bundle = true
		endif

		assign card_product_selected_variant = card_product.selected_or_first_available_variant

		comment
			VÉRIFICATION ET REMPLACEMENT DES VARIANTES CACHÉES

			Si la variante sélectionnée a le métafield hidden_variant à true,
			on cherche une variante alternative disponible et non cachée
		endcomment
		if card_product_selected_variant.metafields.custom.hidden_variant.value == true
			if card_product_selected_variant.options.size == 1
				assign candidate_variants_all = card_product.variants
			elsif card_product_selected_variant.options.size == 2
				assign candidate_variants_all = card_product.variants
				assign candidate_variants_matching_first_options = card_product.variants | where: 'option1', card_product_selected_variant.options[0] | where: 'option2', card_product_selected_variant.options[1]
			elsif card_product_selected_variant.options.size == 3
				assign candidate_variants_all = card_product.variants
				assign candidate_variants_matching_first_options = card_product.variants | where: 'option1', card_product_selected_variant.options[0] | where: 'option2', card_product_selected_variant.options[1] | where: 'option3', card_product_selected_variant.options[2]
				assign candidate_variants_matching_two_options = card_product.variants | where: 'option1', card_product_selected_variant.options[0] | where: 'option2', card_product_selected_variant.options[1] | where: 'option3', card_product_selected_variant.options[2]
			elsif card_product_selected_variant.options.size == 4
				assign candidate_variants_all = card_product.variants
				assign candidate_variants_matching_first_options = card_product.variants | where: 'option1', card_product_selected_variant.options[0] | where: 'option2', card_product_selected_variant.options[1]
				assign candidate_variants_matching_two_options = card_product.variants | where: 'option1', card_product_selected_variant.options[0] | where: 'option2', card_product_selected_variant.options[1] | where: 'option3', card_product_selected_variant.options[2]
				assign candidate_variants_matching_three_options = card_product.variants | where: 'option1', card_product_selected_variant.options[0] | where: 'option2', card_product_selected_variant.options[1] | where: 'option3', card_product_selected_variant.options[2]
			endif

			assign valid_variant_bundle_found = false
			if valid_variant_bundle_found == false and candidate_variants_matching_three_options != blank
				for variant in candidate_variants_matching_three_options
					comment
						Pour option4, on doit filtrer manuellement car where: 'option4' n'existe pas en Liquid
					endcomment
					if variant.options[3] != card_product_selected_variant.options[3]
						continue
					endif

					comment
						VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

						Même logique que dans le reste du fichier pour garantir
						qu'on sélectionne une variante réellement disponible
					endcomment
					assign check_against_inventory = true
					if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
						assign check_against_inventory = false
					endif

					assign quantity_rule_soldout = false
					if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
						assign quantity_rule_soldout = true
					endif

					assign variant_available = true
					if variant.available == false or quantity_rule_soldout or variant == null
						assign variant_available = false
					endif

					comment
						Sélectionner cette variante si elle est disponible ET non cachée
					endcomment
					if variant_available and variant.metafields.custom.hidden_variant.value != true
						assign card_product_selected_variant = variant
						assign valid_variant_bundle_found = true
						break
					endif
				endfor
			endif

			if valid_variant_bundle_found == false and candidate_variants_matching_two_options != blank
				for variant in candidate_variants_matching_two_options
					comment
						VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

						Même logique que dans le reste du fichier pour garantir
						qu'on sélectionne une variante réellement disponible
					endcomment
					assign check_against_inventory = true
					if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
						assign check_against_inventory = false
					endif

					assign quantity_rule_soldout = false
					if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
						assign quantity_rule_soldout = true
					endif

					assign variant_available = true
					if variant.available == false or quantity_rule_soldout or variant == null
						assign variant_available = false
					endif

					comment
						Sélectionner cette variante si elle est disponible ET non cachée
					endcomment
					if variant_available and variant.metafields.custom.hidden_variant.value != true
						assign card_product_selected_variant = variant
						assign valid_variant_bundle_found = true
						break
					endif
				endfor
			endif

			if valid_variant_bundle_found == false and candidate_variants_matching_first_options != blank
				for variant in candidate_variants_matching_first_options
					comment
						VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

						Même logique que dans le reste du fichier pour garantir
						qu'on sélectionne une variante réellement disponible
					endcomment
					assign check_against_inventory = true
					if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
						assign check_against_inventory = false
					endif

					assign quantity_rule_soldout = false
					if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
						assign quantity_rule_soldout = true
					endif

					assign variant_available = true
					if variant.available == false or quantity_rule_soldout or variant == null
						assign variant_available = false
					endif

					comment
						Sélectionner cette variante si elle est disponible ET non cachée
					endcomment
					if variant_available and variant.metafields.custom.hidden_variant.value != true
						assign card_product_selected_variant = variant
						assign valid_variant_bundle_found = true
						break
					endif
				endfor
			endif

			if valid_variant_bundle_found == false and candidate_variants_all != blank
				for variant in candidate_variants_all
					comment
						VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

						Même logique que dans le reste du fichier pour garantir
						qu'on sélectionne une variante réellement disponible
					endcomment
					assign check_against_inventory = true
					if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
						assign check_against_inventory = false
					endif

					assign quantity_rule_soldout = false
					if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
						assign quantity_rule_soldout = true
					endif

					assign variant_available = true
					if variant.available == false or quantity_rule_soldout or variant == null
						assign variant_available = false
					endif

					comment
						Sélectionner cette variante si elle est disponible ET non cachée
					endcomment
					if variant_available and variant.metafields.custom.hidden_variant.value != true
						assign card_product_selected_variant = variant
						assign valid_variant_bundle_found = true
						break
					endif
				endfor
			endif
		endif

		comment
			DÉTECTION DE LA POSITION DE L'OPTION VERSION POUR LES CARD PRODUCTS

			Identifie automatiquement l'option "version" du card_product
			en utilisant les mêmes traductions que pour le produit principal
		endcomment
		assign options_names_for_version_card_translated = 'products.product.options_names_for_version' | t | downcase | replace: ', ', ','
		assign options_names_for_version_card = options_names_for_version_card_translated | split: ',' | uniq
		assign option_position_version_card_array = blank

		unless card_product.has_only_default_variant
			for option in card_product.options_with_values
				assign option_name_downcase = option.name | downcase
				assign option_name_array = option_name_downcase | split: ' ' | uniq

				for option_name in option_name_array
					if options_names_for_version_card contains option_name
						assign option_position_version_card_array = option.position | minus: 1
						break
					endif
				endfor

				if option_position_version_card_array != blank
					break
				endif
			endfor
		endunless

		comment
			SÉLECTION DE LA VARIANTE LA MOINS CHÈRE POUR L'OPTION VERSION (CARD PRODUCT)

			Même logique que pour le produit principal (lignes 548-628),
			mais appliquée aux variantes du card_product
		endcomment
		if card_product.selected_variant == null and option_position_version_card_array != blank
			assign cheapest_variant_card = blank
			assign cheapest_price_card = blank

			for variant in card_product.variants
				if variant.metafields.custom.hidden_variant.value == true
					continue
				endif

				assign check_against_inventory = true
				if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
					assign check_against_inventory = false
				endif

				assign quantity_rule_soldout = false
				if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
					assign quantity_rule_soldout = true
				endif

				assign variant_available = true
				if variant.available == false or quantity_rule_soldout or variant == null
					assign variant_available = false
				endif

				unless variant_available
					continue
				endunless

				comment
					Vérifie que toutes les options non-version correspondent
					à celles de la variante actuellement sélectionnée
				endcomment
				assign matches_other_options = true

				if card_product.options.size >= 1 and option_position_version_card_array != 0
					if variant.options[0] != card_product_selected_variant.options[0]
						assign matches_other_options = false
					endif
				endif

				if matches_other_options and card_product.options.size >= 2 and option_position_version_card_array != 1
					if variant.options[1] != card_product_selected_variant.options[1]
						assign matches_other_options = false
					endif
				endif

				if matches_other_options and card_product.options.size >= 3 and option_position_version_card_array != 2
					if variant.options[2] != card_product_selected_variant.options[2]
						assign matches_other_options = false
					endif
				endif

				if matches_other_options and card_product.options.size >= 4 and option_position_version_card_array != 3
					if variant.options[3] != card_product_selected_variant.options[3]
						assign matches_other_options = false
					endif
				endif

				if matches_other_options
					if cheapest_variant_card == blank
						assign cheapest_variant_card = variant
						assign cheapest_price_card = variant.price
					elsif variant.price < cheapest_price_card
						assign cheapest_variant_card = variant
						assign cheapest_price_card = variant.price
					endif
				endif
			endfor

			if cheapest_variant_card != blank
				assign card_product_selected_variant = cheapest_variant_card
			endif
		endif

		capture card_price
			if is_variant
				render 'price', product: variant, price_class: '', show_compare_at_price: true, show_badges: true, is_bundle: is_bundle
			else
				render 'price', product: card_product, price_class: '', show_compare_at_price: true, show_badges: true, is_bundle: is_bundle
			endif
		endcapture

		assign claims_position = claims_position | default: 'horizontal'

		assign has_color_swatches_with_images = false

		# Utiliser exactement la même logique que celle d'affichage des swatches
		if card_product.options_with_values.size > 0 and card_product.metafields.custom.combined_listings_produit_parent.value == blank
			for option in card_product.options_with_values
				assign show_color = false

				# Traitement du nom de l'option en minuscules (identique à la logique d'affichage)
				assign option_name_downcase = option.name | downcase
				assign option_name_array = option_name_downcase | split: ' ' | uniq

				# Récupère les traductions (identique à la logique d'affichage)
				assign options_names_for_foot_translated = 'products.product.options_names_for_foot' | t | downcase | replace: ', ', ','
				assign options_names_for_foot = options_names_for_foot_translated | split: ',' | uniq
				assign options_names_for_color_translated = 'products.product.options_names_for_color' | t | downcase | replace: ', ', ','
				assign options_names_for_color = options_names_for_color_translated | split: ',' | uniq

				# Vérifier les pieds (identique à la logique d'affichage)
				for translation in options_names_for_foot
					assign has_foot_in_array = option_name_array | find: translation
					if has_foot_in_array
						assign has_foot_in_array = true
						break
					endif
				endfor

				if has_foot_in_array
					continue
				endif

				# Vérifier les couleurs (identique à la logique d'affichage)
				for translation in options_names_for_color
					assign has_color_in_array = option_name_array | find: translation
					if has_color_in_array
						assign has_color_in_array = true
						break
					endif
				endfor

				if has_color_in_array
					assign show_color = true
				endif

				# Si on a des couleurs, vérifier s'il y a des images de variantes
				if show_color
					assign counter_color = 0
					for value in option.values
						if counter_color <= 5
							# Récupère la variante (identique à la logique d'affichage)
							assign value_variant = value.variant
							assign option_current = 'option' | append: option.position
							assign first_variant_with_value_option = card_product.variants | where: option_current, value | first

							if value_variant == blank and first_variant_with_value_option != blank
								assign value_variant = first_variant_with_value_option
							endif

							assign value_variant_color_hexa = blank
							assign value_variant_color_image = blank
							assign value_variant_color_label = blank

							# Assigne les valeurs si la variante est trouvée (identique à la logique d'affichage)
							if value_variant != blank
								if value_variant.metafields.custom.color.value.color.value != blank
									assign value_variant_color_hexa = value_variant.metafields.custom.color.value.color.value
								endif
								if value_variant.metafields.custom.color.value.image.value != blank
									assign value_variant_color_image = value_variant.metafields.custom.color.value.image.value
								endif
								if value_variant.metafields.custom.color.value.label.value != blank
									assign value_variant_color_label = value_variant.metafields.custom.color.value.label.value
								endif
							endif

							if value.swatch == blank
								assign object_color = null | default: image: value_variant_color_image, label: value_variant_color_label, color: value_variant_color_hexa
								assign swatch = object_color
							endif

							assign variant_image = blank
							if value_variant != blank and value_variant.product.featured_image != blank
								assign variant_image = value_variant.product.featured_image
							elsif value_variant.featured_image != blank
								assign variant_image = value_variant.featured_image
							elsif card_product.featured_image != blank
								assign variant_image = card_product.featured_image
							elsif value_variant_color_image != blank
								assign variant_image = value_variant_color_image
							endif

							if swatch.color != blank or variant_image != blank
								assign has_color_swatches_with_images = true
								break
							endif

							assign counter_color = counter_color | plus: 1
						endif
					endfor

					if has_color_swatches_with_images
						break
					endif
				endif
			endfor
		endif

		# Déterminer si on doit montrer la secondary image
		assign should_show_secondary = false
		if show_secondary_image and has_color_swatches_with_images == false
			assign should_show_secondary = true
		endif

		assign is_horizontal_layout_menu = false
		if has_menu_image and horizontal_layout_menu and horizontal_class
			assign is_horizontal_layout_menu = true
		endif
	-%}
	<div class="card-wrapper product-miniature product-card-wrapper{% if is_horizontal_layout_menu %} product-miniature--horizontal{% endif %}{% if horizontal_mobile_class %} product-miniature--mobile-horizontal{% endif %}{% if card_product.template_suffix == 'pack-new' %} product-miniature--pack-new{% endif %}">
		<div
			class="
				card card--product card--{{ settings.card_style }}
				{% if card_product_featured_media %} card--media{% else %} card--text{% endif %}
				{% if settings.card_style == 'card' %} color-{{ settings.card_color_scheme }} gradient{% endif %}
				{% if image_shape and image_shape != 'default' %} card--shape{% endif %}
				{% if extend_height %} card--extend-height{% endif %}
				{% if card_product_featured_media == nil and settings.card_style == 'card' %} ratio{% endif %}
				{% if horizontal_class %} card--horizontal{% endif %}
			"
			style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
		>
			<div
				class="card__inner {% if settings.card_style == 'standard' %}color-{{ settings.card_color_scheme }} gradient{% endif %}{% if card_product_featured_media or settings.card_style == 'standard' %} ratio{% endif %}"
				style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
			>
				{%- if card_product_featured_media -%}
					<div class="card__media{% if image_shape and image_shape != 'default' %} shape--{{ image_shape }} color-{{ settings.card_color_scheme }} gradient{% endif %}{% if should_show_secondary %} card__media_secondary{% endif %}">
						<div class="media media--transparent media--hover-effect">
							{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
							{%- capture product_images -%}
								<picture>
									<source
										media="(max-width: 749px)"
										srcset="{{ card_product_mobile_primary_media | image_url: width: 533 }}"
									>
									<img
										srcset="
											{%- if card_product_featured_media.width >= 165 -%}{{ card_product_featured_media | image_url: width: 165 }} 165w,{%- endif -%}
											{%- if card_product_featured_media.width >= 360 -%}{{ card_product_featured_media | image_url: width: 360 }} 360w,{%- endif -%}
											{%- if card_product_featured_media.width >= 533 -%}{{ card_product_featured_media | image_url: width: 533 }} 533w,{%- endif -%}
											{%- if card_product_featured_media.width >= 720 -%}{{ card_product_featured_media | image_url: width: 720 }} 720w,{%- endif -%}
											{%- if card_product_featured_media.width >= 940 -%}{{ card_product_featured_media | image_url: width: 940 }} 940w,{%- endif -%}
											{%- if card_product_featured_media.width >= 1066 -%}{{ card_product_featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
											{{ card_product_featured_media | image_url }} {{ card_product_featured_media.width }}w
										"
										src="{{ card_product_featured_media | image_url: width: 533 }}"
										sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
										alt="{{ card_product.title | escape }}"
										class="motion-reduce"
										{% unless lazy_load == false %}
											loading="lazy"
										{% endunless %}
										width="{{ card_product_featured_media.width }}"
										height="{{ card_product_featured_media.height }}"
										role="img"
										aria-label="{{ card_product_featured_media.alt | escape }}">
								</picture>

								{%- if card_product_media != null and should_show_secondary -%}
									{% assign img_alt = card_product_media.alt | default: card_product.title %}
									<picture>
										{%- if card_product_mobile_hover_media != blank -%}
											<source
												media="(max-width: 749px)"
												srcset="{{ card_product_mobile_hover_media | image_url: width: 533 }}"
											>
										{%- else -%}
											<source
												media="(max-width: 749px)"
												srcset="{{ images['1x1.png'] | image_url: width: 1 }}"
											>
										{%- endif -%}
										<img
											srcset="
												{%- if card_product_media.width >= 165 -%}{{ card_product_media | image_url: width: 165 }} 165w,{%- endif -%}
												{%- if card_product_media.width >= 360 -%}{{ card_product_media | image_url: width: 360 }} 360w,{%- endif -%}
												{%- if card_product_media.width >= 533 -%}{{ card_product_media | image_url: width: 533 }} 533w,{%- endif -%}
												{%- if card_product_media.width >= 720 -%}{{ card_product_media | image_url: width: 720 }} 720w,{%- endif -%}
												{%- if card_product_media.width >= 940 -%}{{ card_product_media | image_url: width: 940 }} 940w,{%- endif -%}
												{%- if card_product_media.width >= 1066 -%}{{ card_product_media | image_url: width: 1066 }} 1066w,{%- endif -%}
												{{ card_product_media | image_url }} {{ card_product_media.width }}w
											"
											src="{{ card_product_media | image_url: width: 533 }}"
											sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
											alt="{{ img_alt | escape }}"
											class="motion-reduce"
											loading="lazy"
											width="{{ card_product_media.width }}"
											height="{{ card_product_media.height }}"
										>
									</picture>
								{%- endif -%}
							{%- endcapture -%}
							{%- if strong_lazy_load -%}
								{{ product_images | replace: 'src="', 'lazy-src="' | replace: 'srcset="', 'lazy-srcset="' }}
							{%- else -%}
								{{ product_images }}
							{%- endif -%}
							{% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
						</div>
					</div>
				{%- endif -%}
				<div class="card__content">
					<div class="card__top-stack">
						{%- if offre_active and hide_offer_countdown != true -%}
							{%- unless is_horizontal_layout_menu or horizontal_mobile_class -%}
								{%- render 'card-offer-countdown', offre: offre, offre_initial_timer: offre_initial_timer, class: 'card__offer-countdown' -%}
							{%- endunless -%}
						{%- endif -%}
						{%- liquid
							unless is_horizontal_layout_menu
								assign badge_classes = 'card__badge card__badge--in-stack ' | append: settings.badge_position
								render 'product-badges', class: badge_classes, product: card_product, selected_variant: card_product_selected_variant, show_discount: true
							endunless
						-%}
					</div>
					{%- liquid
						assign badge_classes = 'card__badge card__badge--images bottom left'
						render 'product-badges-images', class: badge_classes, product: card_product, lazy_load: strong_lazy_load
					-%}

					{%- if view_product -%}
						<button class="card__product-view-product button button--primary large-hide">
							{{ 'products.product.view' | t }}
						</button>
					{%- endif -%}
				</div>
			</div>
			<div class="card__content">
				<div class="card__information">
					{%- liquid
						if horizontal_mobile_class
							if offre_active and hide_offer_countdown != true
								render 'card-offer-countdown', offre: offre, offre_initial_timer: offre_initial_timer, class: 'card__offer-countdown--horizontal medium-hide large-hide'
							endif
							assign badge_classes = 'card__badge card__badge--horizontal medium-hide large-hide ' | append: settings.badge_position
							render 'product-badges', class: badge_classes, product: card_product, selected_variant: card_product_selected_variant, show_discount: true
						endif
					-%}
					<{{ card_product_tag }}
						class="card__heading{% if card_product_featured_media or settings.card_style == 'standard' %} h5{% endif %}"
						{% if card_product_featured_media or settings.card_style == 'card' %}
							id="title-{{ section_id }}-{{ card_product.id }}"
						{% endif %}
					>
						{%- liquid
							assign variant_title = variant.title
							assign product_title = card_product.title
							assign same_name_variant = false

							if product_title contains variant_title
								assign same_name_variant = true
							endif

							if card_product.metafields.custom.combined_listings_produit_parent.value != blank
								assign variant_title = variant_title | split: ' / ' | slice: 1, 10 | join: ' - '
							else
								assign variant_title = variant_title | split: ' / ' | join: ' - '
							endif
						-%}
						{%- if is_current_product -%}
							<span
								id="CardLink-{{ section_id }}-{{ card_product.id }}"
								class="full-unstyled-link current-product-disabled"
								aria-labelledby="CardLink-{{ section_id }}-{{ card_product.id }} Badge-{{ section_id }}-{{ card_product.id }}"
								aria-describedby="CardDescription-{{ section_id }}-{{ card_product.id }}"
							>
								{{ card_product.title | escape }}
								{%- if is_variant
									and variant_title != blank
									and variant_title != 'Default Title'
									and same_name_variant == false
								-%}
									{{ variant_title | escape | prepend: ' - ' }}
								{%- endif -%}
							</span>
						{%- else -%}
							<a
								href="{% if is_variant and variant %}{{ variant.url }}{% else %}{{ card_product.url }}{% endif %}"
								id="CardLink-{{ section_id }}-{{ card_product.id }}"
								class="full-unstyled-link"
								aria-labelledby="CardLink-{{ section_id }}-{{ card_product.id }} Badge-{{ section_id }}-{{ card_product.id }}"
								aria-describedby="CardDescription-{{ section_id }}-{{ card_product.id }}"
							>
								{{ card_product.title | escape }}
								{%- if is_variant
									and variant_title != blank
									and variant_title != 'Default Title'
									and same_name_variant == false
								-%}
									{{ variant_title | escape | prepend: ' - ' }}
								{%- endif -%}
							</a>
						{%- endif -%}
					</{{ card_product_tag }}>
					{%- if show_trustpilot and card_product.metafields.custom.show_trustpilot_card.value != false -%}
						{% render 'card-product-trustpilot', card_product: card_product %}
					{%- endif -%}
					<div class="card-information">
						{%- if show_vendor -%}
							<span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
							<div class="caption-with-letter-spacing light">{{ card_product.vendor }}</div>
						{%- endif -%}

						{%- comment -%}
							Rendu claims inline (entre titre et prix) :
							- Layout standard (PDP collection cards, etc.) : toujours inline.
							- Layout horizontal menu mobile : inline UNIQUEMENT si pack-new
							  (`template_suffix == 'pack-new'`). Les autres
							  (matelas/sommier standalone + packs legacy) gardent leur claims
							  post-card (block en bas du fichier).
						{%- endcomment -%}
						{%- liquid
							assign render_claims_inline = true
							if is_horizontal_layout_menu and card_product.template_suffix != 'pack-new'
								assign render_claims_inline = false
							endif
						-%}
						{%- if render_claims_inline -%}
							{%- if card_product.template_suffix == 'pack-new' and card_product.metafields.custom.claims.value != blank -%}
								{%- comment -%}
									Pack-new : rendu claims simple avec icon check + texte gris
									(12px narrow-medium), 1 ligne par claim, source `claims` (liste
									de strings) au lieu du metaobject `liste_des_caracteristiques_du_matelas`
									utilisé par les matelas. Pas d'image miniature, pas de layout
									horizontal — toujours vertical.
								{%- endcomment -%}
								<div class="card__product-claims card__product-claims--pack-new">
									<ul class="card__product-claims__list">
										{%- for claim in card_product.metafields.custom.claims.value -%}
											<li class="card__product-claims__item card__product-claims__item--pack-new">
												<span class="card__product-claims__item__check" aria-hidden="true">
													{{- 'icon-check.svg' | inline_asset_content -}}
												</span>
												<div class="card__product-claims__item-text">
													{{ claim }}
												</div>
											</li>
										{%- endfor -%}
									</ul>
								</div>
							{%- elsif card_product.metafields.custom.liste_des_caracteristiques_du_matelas.value != blank -%}
								<div class="card__product-claims">
									<ul class="card__product-claims__list{% if claims_position == 'horizontal' %} card__product-claims__list--horizontal{% endif %}">
										{%- for claim in card_product.metafields.custom.liste_des_caracteristiques_du_matelas.value -%}
											{%- if claim.texte_court.value != blank or claim.image_miniature.value != blank -%}
												<li class="card__product-claims__item">
													{%- if claim.image_miniature.value != blank -%}
														<div class="card__product-claims__item-image">
															{{ claim.image_miniature.value | image_url: width: 40 | image_tag: loading: 'lazy' }}
														</div>
													{%- endif -%}
													{%- if claim.texte_court.value != blank -%}
														<div class="card__product-claims__item-text">
															{{ claim.texte_court.value }}
														</div>
													{%- endif -%}
												</li>
											{%- endif -%}
										{%- endfor -%}
									</ul>
								</div>
							{%- elsif card_product.metafields.custom.attributs.value != blank -%}
								<div class="card__product-description">
									{%- for attribut in card_product.metafields.custom.attributs.value -%}
										<span>{{ attribut }}</span>
										{%- if first_attr_only -%}
											{%- break -%}
										{%- endif -%}
									{%- endfor -%}
								</div>
							{%- endif -%}
						{%- endif -%}

						{%- liquid
							if is_horizontal_layout_menu
								if offre_active and hide_offer_countdown != true
									render 'card-offer-countdown', offre: offre, offre_initial_timer: offre_initial_timer, class: 'card__offer-countdown--horizontal'
								endif
								# Pack-new menu horizontal : pas de badge horizontal sur la card
								# — seul le badge réduction (-X%) du price snippet
								# (show_badges: true) est conservé, à côté du prix.
								# Autres templates : on garde le render badge legacy.
								unless card_product.template_suffix == 'pack-new'
									assign badge_classes = 'card__badge card__badge--horizontal' | append: settings.badge_position
									render 'product-badges', class: badge_classes, product: card_product, selected_variant: card_product_selected_variant, show_discount: true
								endunless
							endif
						-%}

						{%- if show_scores -%}
							{%- render 'product-scores', product: card_product, show_extended_scores: show_extended_scores -%}
						{%- endif -%}

						{%- if block.settings.description != blank -%}
							<span class="caption-large light">{{ block.settings.description | escape }}</span>
						{%- endif -%}

						{%- if show_rating and card_product.metafields.reviews.rating.value != blank -%}
							{%- liquid
								assign rating_decimal = 0
								assign decimal = card_product.metafields.reviews.rating.value.rating | modulo: 1
								if decimal >= 0.3 and decimal <= 0.7
									assign rating_decimal = 0.5
								elsif decimal > 0.7
									assign rating_decimal = 1
								endif
							-%}
							<div
								class="rating"
								role="img"
								aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: card_product.metafields.reviews.rating.value, rating_max: card_product.metafields.reviews.rating.value.scale_max }}"
							>
								<span
									aria-hidden="true"
									class="rating-star"
									style="--rating: {{ card_product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ card_product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
								></span>
							</div>
							<p class="rating-text caption">
								<span aria-hidden="true">
									{{- card_product.metafields.reviews.rating.value }} /
									{{ card_product.metafields.reviews.rating.value.scale_max -}}
								</span>
							</p>
							<p class="rating-count caption">
								<span aria-hidden="true">({{ card_product.metafields.reviews.rating_count }})</span>
								<span class="visually-hidden">
									{{- card_product.metafields.reviews.rating_count }}
									{{ 'accessibility.total_reviews' | t -}}
								</span>
							</p>
						{%- endif -%}

						{%- if view_product -%}
							<div class="card-product__price-view-product">
								{{ card_price }}

								<span class="ax-link reversed small-hide medium-hide">
									{{ 'products.product.view' | t }}
								</span>
							</div>
						{%- else -%}
							{{ card_price }}
						{%- endif -%}

						{%- if card_product.quantity_price_breaks_configured? -%}
							{%- if card_product.variants_count == 1 and quick_add == 'bulk' -%}
								{% liquid
									assign quantity_rule = card_product_selected_variant.quantity_rule
									assign has_qty_rules = false
									if quantity_rule.increment > 1 or quantity_rule.min > 1 or quantity_rule.max != null
										assign has_qty_rules = true
									endif
								-%}
								<quantity-popover>
									<button class="card__information-volume-pricing-note card__information-volume-pricing-note--button card__information-volume-pricing-note--button-{{ settings.card_text_alignment }} quantity-popover__info-button--icon-only button button button--tertiary medium-hide small-hide">
										<span class="caption">{{ 'products.product.volume_pricing.note' | t }}</span>
									</button>
									<button class="card__information-volume-pricing-note card__information-volume-pricing-note--button card__information-volume-pricing-note--button-{{ settings.card_text_alignment }} quantity-popover__info-button--icon-with-label button button--tertiary large-up-hide">
										<span class="caption">{{ 'products.product.volume_pricing.note' | t }}</span>
									</button>
							{%- else -%}
								<div class="card__information-volume-pricing-note">
									<span class="caption">{{ 'products.product.volume_pricing.note' | t }}</span>
								</div>
							{%- endif -%}
							{%- if card_product.variants_count == 1 and quick_add == 'bulk' -%}
								<div
									class="global-settings-popup quantity-popover__info"
									tabindex="-1"
									hidden
									id="quantity-popover-info-{{ card_product_selected_variant.id }}"
								>
									{%- if has_qty_rules -%}
										<div class="quantity__rules caption no-js-hidden">
											{%- if quantity_rule.increment > 1 -%}
												<span class="divider">
													{{- 'products.product.quantity.multiples_of' | t: quantity: quantity_rule.increment -}}
												</span>
											{%- endif -%}
											{%- if quantity_rule.min > 1 -%}
												<span class="divider">
													{{- 'products.product.quantity.min_of' | t: quantity: quantity_rule.min -}}
												</span>
											{%- endif -%}
											{%- if quantity_rule.max != null -%}
												<span class="divider">
													{{- 'products.product.quantity.max_of' | t: quantity: quantity_rule.max -}}
												</span>
											{%- endif -%}
										</div>
									{%- endif -%}
									<button
										class="button-close button button--tertiary large-up-hide"
										type="button"
										aria-label="{{ 'accessibility.close' | t }}"
									>
										{{- 'icon-close.svg' | inline_asset_content -}}
									</button>
									{%- if card_product_selected_variant.quantity_price_breaks.size > 0 -%}
										<volume-pricing class="parent-display">
											<ul class="list-unstyled">
												<li>
													<span>{{ card_product_selected_variant.quantity_rule.min }}+</span>
													{%- assign price = card_product_selected_variant.price | money_with_currency -%}
													<span>{{ 'sections.quick_order_list.each' | t: money: price }}</span>
												</li>
												{%- for price_break in card_product_selected_variant.quantity_price_breaks -%}
													<li>
														<span>
															{{- price_break.minimum_quantity -}}
															<span aria-hidden="true">+</span>
														</span>
														{%- assign price = price_break.price | money_with_currency -%}
														<span>{{ 'sections.quick_order_list.each' | t: money: price }}</span>
													</li>
												{%- endfor -%}
											</ul>
										</volume-pricing>
									{%- endif -%}
								</div>
								</quantity-popover>
							{%- endif -%}
						{%- endif -%}

						{%- if card_product.options_with_values.size > 0
							and card_product.metafields.custom.combined_listings_produit_parent.value == blank
						-%}
							{%- assign color_option_size = 0 -%}
							{%- for option in card_product.options_with_values -%}
								{%- liquid
									assign show_color = false

									# Traitement du nom de l'option en minuscules
									assign option_name_downcase = option.name | downcase

									# Divise le nom de l'option en tableau de mots uniques
									assign option_name_array = option_name_downcase | split: ' ' | uniq

									# Récupère les traductions des noms d'options pour les pieds
									assign options_names_for_foot_translated = 'products.product.options_names_for_foot' | t | downcase | replace: ', ', ','
									assign options_names_for_foot = options_names_for_foot_translated | split: ',' | uniq

									# Récupère les traductions des noms d'options pour les couleurs
									assign options_names_for_color_translated = 'products.product.options_names_for_color' | t | downcase | replace: ', ', ','
									assign options_names_for_color = options_names_for_color_translated | split: ',' | uniq

									for translation in options_names_for_foot
										assign has_foot_in_array = option_name_array | find: translation
										if has_foot_in_array
											assign has_foot_in_array = true
											break
										endif
									endfor

									if has_foot_in_array
										continue
									endif

									for translation in options_names_for_color
										assign has_color_in_array = option_name_array | find: translation
										if has_color_in_array
											assign has_color_in_array = true
											break
										endif
									endfor

									if has_color_in_array
										assign show_color = true
										assign color_option_size = color_option_size | plus: 1
									endif

									if color_option_size > 1
										assign show_color = false
									endif

									assign counter_color = 0
								-%}

								{%- if show_color and hide_color_swatches != true -%}
									<div class="card__product-colors">
										<ul class="list-unstyled" aria-label="{{ 'accessibility.product.colors' | t }}">
											{%- for value in option.values -%}
												{%- liquid
													# Récupère la variante
													assign value_variant = value.variant

													# Récupère la position de l'option actuelle
													assign option_current = 'option' | append: option.position

													# Récupère la première variante pour l'option actuelle correspondant à la valeur actuelle
													assign first_variant_with_value_option = card_product.variants | where: option_current, value | first

													# Assigne la variante par défaut si aucune correspondance trouvée
													if value_variant == blank and first_variant_with_value_option != blank
														assign value_variant = first_variant_with_value_option
													endif

													assign value_variant_color_hexa = blank
													assign value_variant_color_image = blank
													assign value_variant_color_label = blank

													# Assigne les valeurs si la variante est trouvée
													if value_variant != blank
														# Assigne la couleur si elle est définie
														if value_variant.metafields.custom.color.value.color.value != blank
															assign value_variant_color_hexa = value_variant.metafields.custom.color.value.color.value
														endif

														# Assigne l'image si elle est définie
														if value_variant.metafields.custom.color.value.image.value != blank
															assign value_variant_color_image = value_variant.metafields.custom.color.value.image.value
														endif

														# Assigne le label si il est défini
														if value_variant.metafields.custom.color.value.label.value != blank
															assign value_variant_color_label = value_variant.metafields.custom.color.value.label.value
														endif
													endif

													if value.swatch == blank
														assign object_color = null | default: image: value_variant_color_image, label: value_variant_color_label, color: value_variant_color_hexa
														assign swatch = object_color
													endif
												-%}
												{%- if counter_color <= 5 -%}
													{%- liquid
														assign variant_image = blank
														if value_variant != blank and value_variant.product.featured_image != blank
															assign variant_image = value_variant.product.featured_image
														elsif value_variant.featured_image != blank
															assign variant_image = value_variant.featured_image
														elsif card_product.featured_image != blank
															assign variant_image = card_product.featured_image
														elsif value_variant_color_image != blank
															assign variant_image = value_variant_color_image
														endif
													-%}

													{%- if swatch.color != blank or variant_image != blank -%}
														<li
															class="card__product-color{% if forloop.index == 1 %} selected{% endif %}"
															{% if swatch.color != blank %}
																style="--product-color: {{ swatch.color }}"
															{% endif %}
															{% if variant_image != blank %}
																data-variant-image="{{ variant_image | image_url: width: 500 }}"
															{% endif %}
														>
															<a
																href="{{ value.product_url }}"
																aria-label="{{ value.name }}"
																title="{{ value.name }}"
															>
																<span class="visually-hidden">{{ value.name }}</span>
															</a>
														</li>
														{%- assign counter_color = counter_color | plus: 1 -%}
													{%- endif -%}
												{%- endif -%}
											{%- endfor -%}
											{%- if counter_color > 5 and show_color -%}
												<li class="card__product-color card__product-color--more">
													<a
														href="{% if is_variant and variant %}{{ variant.url }}{% else %}{{ card_product.url }}{% endif %}"
														aria-label="{{ 'accessibility.product.more_colors' | t }}"
														title="{{ 'accessibility.product.more_colors' | t }}"
													>
														<span class="visually-hidden">
															{{ 'accessibility.product.more_colors' | t }}
														</span>
													</a>
												</li>
											{%- endif -%}
										</ul>
									</div>
								{%- endif -%}
							{%- endfor -%}
						{%- endif -%}
					</div>
				</div>
				{% assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id %}
				{% if quick_add == 'standard' %}
					<div class="quick-add no-js-hidden">
						{%- liquid
							assign qty_rules = false
							if card_product_selected_variant.quantity_rule.min > 1 or card_product_selected_variant.quantity_rule.max != null or card_product_selected_variant.quantity_rule.increment > 1
								assign qty_rules = true
							endif
						-%}
						{%- if card_product.variants_count > 1 or qty_rules -%}
							<modal-opener data-modal="#QuickAdd-{{ card_product.id }}">
								<button
									id="{{ product_form_id }}-submit"
									type="submit"
									name="add"
									class="quick-add__submit button button--full-width button--secondary{% if horizontal_quick_add %} card--horizontal__quick-add animate-arrow{% endif %}"
									aria-haspopup="dialog"
									aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
									data-product-url="{{ card_product.url }}"
								>
									{{ 'products.product.choose_options' | t }}
									{%- if horizontal_quick_add -%}
										<span class="icon-wrap">
											{{- 'icon-arrow.svg' | inline_asset_content -}}
										</span>
									{%- endif -%}
									{%- render 'loading-spinner' -%}
								</button>
							</modal-opener>
							<quick-add-modal id="QuickAdd-{{ card_product.id }}" class="quick-add-modal">
								<div
									role="dialog"
									aria-label="{{ 'products.product.choose_product_options' | t: product_name: card_product.title | escape }}"
									aria-modal="true"
									class="quick-add-modal__content global-settings-popup"
									tabindex="-1"
								>
									<button
										id="ModalClose-{{ card_product.id }}"
										type="button"
										class="quick-add-modal__toggle"
										aria-label="{{ 'accessibility.close' | t }}"
									>
										{{- 'icon-close.svg' | inline_asset_content -}}
									</button>
									<div id="QuickAddInfo-{{ card_product.id }}" class="quick-add-modal__content-info"></div>
								</div>
							</quick-add-modal>
						{%- else -%}
							<product-form data-section-id="{{ section.id }}">
								{%- form 'product',
									card_product,
									id: product_form_id,
									class: 'form',
									novalidate: 'novalidate',
									data-type: 'add-to-cart-form'
								-%}
									<input
										type="hidden"
										name="id"
										value="{{ card_product_selected_variant.id }}"
										class="product-variant-id"
										{% if card_product_selected_variant.available == false %}
											disabled
										{% endif %}
									>
									<button
										id="{{ product_form_id }}-submit"
										type="submit"
										name="add"
										class="quick-add__submit button button--full-width button--secondary{% if horizontal_quick_add %} card--horizontal__quick-add{% endif %}"
										aria-haspopup="dialog"
										aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
										aria-live="polite"
										data-sold-out-message="true"
										{% if card_product_selected_variant.available == false %}
											disabled
											aria-disabled="true"
										{% endif %}
									>
										<span>
											{%- if card_product_selected_variant.available -%}
												{{ 'products.product.add_to_cart' | t }}
											{%- else -%}
												{{ 'products.product.sold_out' | t }}
											{%- endif -%}
										</span>
										<span class="sold-out-message hidden">
											{{ 'products.product.sold_out' | t }}
										</span>
										{%- if horizontal_quick_add -%}
											<span class="icon-wrap">
												{{- 'icon-plus.svg' | inline_asset_content -}}
											</span>
										{%- endif -%}
										{%- render 'loading-spinner' -%}
									</button>
								{%- endform -%}
							</product-form>
						{%- endif -%}
					</div>
				{% elsif quick_add == 'bulk' %}
					{% if card_product.variants_count == 1 %}
						<quick-add-bulk
							data-min="{{ card_product_selected_variant.quantity_rule.min }}"
							id="quick-add-bulk-{{ card_product_selected_variant.id }}-{{ section.id }}"
							class="quick-add-bulk"
							data-index="{{ card_product_selected_variant.id }}"
						>
							{% if card_product_selected_variant.available == false %}
								<button
									id="{{ product_form_id }}-submit"
									type="submit"
									name="add"
									class="quick-add__submit button button--full-width button--secondary"
									aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
									data-sold-out-message="true"
									disabled
								>
									<span>{{ 'products.product.sold_out' | t }}</span>
									<span class="sold-out-message hidden">
										{{ 'products.product.sold_out' | t }}
									</span>
								</button>
							{% else %}
								{% render 'quantity-input', variant: card_product_selected_variant, min: 0 %}
							{% endif %}
						</quick-add-bulk>
					{% else %}
						<div class="quick-add no-js-hidden">
							{%- liquid
								assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id
								assign qty_rules = false
								if card_product_selected_variant.quantity_rule.min > 1 or card_product_selected_variant.quantity_rule.max != null or card_product_selected_variant.quantity_rule.increment > 1
									assign qty_rules = true
								endif
							-%}
							<modal-opener
								id="QuickBulk-{{ card_product.id }}-{{ section_id }}"
								data-modal="#QuickAddBulk-{{ card_product.id }}-{{ section.id }}"
							>
								<button
									id="{{ product_form_id }}-submit"
									type="submit"
									name="add"
									class="quick-add__submit button button--full-width button--secondary"
									aria-haspopup="dialog"
									aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
									data-product-url="{{ card_product.url }}"
								>
									{{ 'products.product.choose_options' | t }}
									{%- render 'loading-spinner' -%}
								</button>
							</modal-opener>
							<modal-dialog
								id="QuickAddBulk-{{ card_product.id }}-{{ section_id }}"
								class="quick-add-modal color-{{ section.settings.color_scheme }}"
							>
								<div
									role="dialog"
									aria-label="{{ 'products.product.choose_product_options' | t: product_name: card_product.title | escape }}"
									aria-modal="true"
									class="quick-add-modal__content quick-add-modal__content--bulk global-settings-popup"
									tabindex="-1"
								>
									<button
										id="ModalClose-{{ card_product.id }}"
										type="button"
										class="quick-add-modal__toggle"
										aria-label="{{ 'accessibility.close' | t }}"
									>
										{{- 'icon-close.svg' | inline_asset_content -}}
									</button>
									<div
										id="QuickAddInfo-{{ card_product.id }}"
										class="quick-add-modal__content-info quick-add-modal__content-info--bulk"
									>
										<div class="quick-add__content-info__media">
											<div class="quick-add__info">
												{%- if card_product_featured_media -%}
													<div
														class="quick-add__product-media"
													>
														<div class="quick-add__product-container global-media-settings">
															{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
															<picture>
																<source
																	media="(max-width: 749px)"
																	srcset="{{ card_product_mobile_primary_media | image_url: width: 533 }}"
																>
																<img
																	srcset="
																		{%- if card_product_featured_media.width >= 165 -%}{{ card_product_featured_media | image_url: width: 165 }} 165w,{%- endif -%}
																		{%- if card_product_featured_media.width >= 360 -%}{{ card_product_featured_media | image_url: width: 360 }} 360w,{%- endif -%}
																		{%- if card_product_featured_media.width >= 533 -%}{{ card_product_featured_media | image_url: width: 533 }} 533w,{%- endif -%}
																		{%- if card_product_featured_media.width >= 720 -%}{{ card_product_featured_media | image_url: width: 720 }} 720w,{%- endif -%}
																		{%- if card_product_featured_media.width >= 940 -%}{{ card_product_featured_media | image_url: width: 940 }} 940w,{%- endif -%}
																		{%- if card_product_featured_media.width >= 1066 -%}{{ card_product_featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
																		{{ card_product_featured_media | image_url }} {{ card_product_featured_media.width }}w
																	"
																	src="{{ card_product_featured_media | image_url: width: 533 }}"
																	sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
																	alt="{{ card_product_featured_media.alt | escape }}"
																	class="motion-reduce"
																	{% unless lazy_load == false %}
																		loading="lazy"
																	{% endunless %}
																	width="{{ card_product_featured_media.width }}"
																	height="{{ card_product_featured_media.height }}"
																>
															</picture>
															{% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
														</div>
													</div>
												{%- endif -%}
												<a
													{% if card_product == blank %}
														role="link" aria-disabled="true"
													{% else %}
														href="{% if is_variant and variant %}{{ variant.url }}{% else %}{{ card_product.url }}{% endif %}"
													{% endif %}
													class="link product__view-details animate-arrow small-hide medium-hide"
												>
													{{ 'products.product.view_full_details' | t -}}
													{{- 'icon-arrow.svg' | inline_asset_content -}}
												</a>
											</div>
											<div class="quick-add-modal__content-info--bulk-details large-up-hide">
												<a
													href="{% if is_variant and variant %}{{ variant.url }}{% else %}{{ card_product.url }}{% endif %}"
													class="full-unstyled-link"
												>
													<{{ card_product_tag }}>{{ card_product.title | escape }}</{{ card_product_tag }}>
												</a>
												{% render 'price',
													product: card_product,
													price_class: '',
													show_compare_at_price: true,
													show_badges: false,
													is_bundle: is_bundle
												%}
												{%- if card_product.quantity_price_breaks_configured? -%}
													<div class="card__information-volume-pricing-note">
														<span class="caption">{{ 'products.product.volume_pricing.note' | t }}</span>
													</div>
												{%- endif -%}
											</div>
										</div>
										<div>
											<div class="quick-add-modal__content-info--bulk-details small-hide medium-hide">
												<a
													href="{% if is_variant and variant %}{{ variant.url }}{% else %}{{ card_product.url }}{% endif %}"
													class="full-unstyled-link"
												>
													<{{ card_product_tag }}>{{ card_product.title | escape }}</{{ card_product_tag }}>
												</a>
												{% render 'price',
													product: card_product,
													price_class: '',
													show_compare_at_price: true,
													show_badges: true,
													is_bundle: is_bundle
												%}
												{%- if card_product.quantity_price_breaks_configured? -%}
													<div class="card__information-volume-pricing-note">
														<span class="caption">{{ 'products.product.volume_pricing.note' | t }}</span>
													</div>
												{%- endif -%}
											</div>
											<bulk-modal
												id="QuickBulkModal-{{ card_product.id }}-{{ section_id }}"
												data-url="{{ card_product.url }}"
												data-section-id="{{ section_id }}"
												data-product-id="{{ card_product.id }}"
											></bulk-modal>
										</div>
									</div>
								</div>
							</modal-dialog>
						</div>
					{% endif %}
				{% endif %}
			</div>
		</div>
		{%- comment -%}
			Bloc post-card claims pour `is_horizontal_layout_menu` non pack-new uniquement.
			Pack-new rend les claims INLINE dans `.card-information` (cf. branche
			au-dessus) → on skip ce bloc pour éviter la duplication. Les autres
			templates (matelas/sommier/packs legacy) gardent leur claims post-card.
		{%- endcomment -%}
		{%- if is_horizontal_layout_menu and card_product.template_suffix != 'pack-new' -%}
			{%- if card_product.metafields.custom.liste_des_caracteristiques_du_matelas.value != blank -%}
				<div class="card__product-claims card__product-claims--position-horizontal">
					<ul class="card__product-claims__list{% if claims_position == 'horizontal' %} card__product-claims__list--horizontal{% endif %}">
						{%- for claim in card_product.metafields.custom.liste_des_caracteristiques_du_matelas.value -%}
							{%- if claim.texte_court.value != blank or claim.image_miniature.value != blank -%}
								<li class="card__product-claims__item">
									{%- if claim.image_miniature.value != blank -%}
										<div class="card__product-claims__item-image">
											{{ claim.image_miniature.value | image_url: width: 40 | image_tag: loading: 'lazy' }}
										</div>
									{%- endif -%}
									{%- if claim.texte_court.value != blank -%}
										<div class="card__product-claims__item-text">
											{{ claim.texte_court.value }}
										</div>
									{%- endif -%}
								</li>
							{%- endif -%}
						{%- endfor -%}
					</ul>
				</div>
			{%- endif -%}
		{%- endif -%}
	</div>
{%- else -%}
	{%- liquid
		assign ratio = 1
		assign placeholder = true
		if media_aspect_ratio == 'portrait'
			assign ratio = 0.7
			if show_menu_image
				assign ratio = 0.87
			endif
		endif
	-%}
	<div class="card-wrapper product-card-wrapper underline-links-hover">
		<div
			class="
				card card--{{ settings.card_style }}
				{% if extend_height %} card--extend-height{% endif %}
				{% if image_shape and image_shape != 'default' %} card--shape{% endif %}
				{% if settings.card_style == 'card' %} color-{{ settings.card_color_scheme }} gradient{% endif %}
			"
			style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
		>
			<div
				class="card__inner{% if settings.card_style == 'standard' %} color-{{ settings.card_color_scheme }} gradient{% endif %} ratio"
			>
				<div
					class="card__media {% if image_shape and image_shape != 'default' %} shape--{{ image_shape }} color-{{ settings.card_color_scheme }} gradient{% endif %}"
				>
					<div
						class="media media--transparent"
					>
						{%- if placeholder_image -%}
							{{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
						{%- else -%}
							{{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
						{% endif %}
					</div>
				</div>
			</div>
			<div class="card__content">
				<div class="card__information">
					<h3 class="card__heading card__heading--placeholder{% if settings.card_style == 'standard' %} h5{% endif %}">
						<a role="link" aria-disabled="true" class="full-unstyled-link">
							{{ 'onboarding.product_title' | t }}
						</a>
					</h3>
					<div class="card-information">
						{%- if show_vendor -%}
							<span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
							<div class="caption-with-letter-spacing light">{{ 'products.product.vendor' | t }}</div>
						{%- endif -%}
						{% render 'price', placeholder: placeholder, show_compare_at_price: true %}
					</div>
				</div>
			</div>
		</div>
	</div>
{%- endif -%}
