{% comment %}
	Renders a product card for bundle selection

	Accepts:
	- product_bundle: {Object} product object
	- selected_variant: {Object} variant object
	- step_number: {Number} bundle step number
	- current_custom_position: {Number} current custom position for the bundle
	- parent_option_size_cleaned: {String} cleaned parent option for synchronization
	- current_index: {Number} current product index in loop
	- first_available_index: {Number} index of first available item
	- step_has_available_items: {Boolean} whether the step has any available items
	- block: {Object} block object for configuration
	- product_form_id: {String} form ID

	Usage:
	{% render 'card-bundle-product',
		product_bundle: product_bundle,
		selected_variant: selected_variant,
		step_number: i,
		current_custom_position: current_custom_position,
		parent_option_size_cleaned: parent_option_size_cleaned,
		current_index: current_index,
		first_available_index: first_available_index,
		step_has_available_items: step_has_available_items,
		block: block,
		product_form_id: product_form_id
	%}
{% endcomment %}

{%- liquid
	comment
		INITIALISATION DES VARIABLES DE LA CARTE PRODUIT

		Cette section prépare toutes les variables nécessaires pour afficher
		une carte de produit bundle avec sa logique de synchronisation complexe
	endcomment
	assign selected_product_bundle_title = blank
	assign selected_product_bundle_image = blank
	assign selected_product_bundle_features = blank
	assign bundle_product_variant = blank
	assign product_price_to_use = blank
	assign product_price_surplus = 0
	assign has_matching_option = false
	assign has_matching_size = true

	comment
		PRÉPARATION DES TRADUCTIONS POUR DÉTECTION D'OPTIONS

		Même système que dans les cartes variantes pour reconnaître
		automatiquement les types d'options et appliquer les bonnes règles
	endcomment
	assign options_names_for_foot_translated = 'products.product.options_names_for_foot' | t | downcase | replace: ', ', ','
	assign options_names_for_foot = options_names_for_foot_translated | split: ',' | uniq
	assign options_names_for_size_value_except_translated = 'products.product.options_names_for_size_value_except' | t | downcase | replace: ', ', ','
	assign options_names_for_size_value_except = options_names_for_size_value_except_translated | split: ',' | uniq
	assign options_names_for_size_value_strict_except_translated = 'products.product.options_names_for_size_value_strict_except' | t | downcase | replace: ', ', ','
	assign options_names_for_size_value_strict_except = options_names_for_size_value_strict_except_translated | split: ',' | uniq
	assign options_names_for_size_translated = 'products.product.options_names_for_size' | t | downcase | replace: ', ', ','
	assign options_names_for_size = options_names_for_size_translated | split: ',' | uniq

	assign options_names_for_version_translated = 'products.product.options_names_for_version' | t | downcase | replace: ', ', ','
	assign options_names_for_version = options_names_for_version_translated | split: ',' | uniq
	assign options_version_labels_to_show_translated = 'products.product.options_version_labels_to_show' | t | replace: ', ', ','
	assign options_version_labels_to_show = options_version_labels_to_show_translated | split: ',' | uniq

	# Format par défaut (Monobloc) : suffixe transparent dans la normalisation et la chaîne ALT
	assign default_format_lc = 'products.product.default_format_for_size_value' | t | downcase | strip

	# Filtre hardcodé "sommier tapissier bleu" (demande BO). Actif si :
	# - on est en contexte pack-new (`is_pack_new`)
	# - le produit "sommier" (handle) est listé dans une étape du metaobject pack
	#   (`has_sommier_tapissier_in_bundle`, calculé en amont dans product-bundle.liquid)
	# - le produit courant de cette card EST le sommier tapissier OU l'un de ses
	#   enfants combined listing (sommier-beige, sommier-noir-anthracite, etc.) —
	#   au switch couleur du picker, le JS fetch l'URL de l'enfant, et le snippet
	#   est rappelé avec `product_bundle = sommier-noir-anthracite` (handle child).
	#   Sans ce 2e check, le filtre se désactive au moindre changement de couleur.
	# Quand actif :
	# - bloque la couleur sommier "Bleu" (option1) → toute la couleur disparaît
	# - bloque les pieds bleus "15 cm - Pieds Bleus" / "20 cm - Pieds Bleus"
	#   (option3) sur les autres couleurs (Beige / Noir / Gris)
	# Hors contexte (PDP sommier standalone, packs non new-pack, autres produits
	# du bundle) : pas d'impact, le sommier reste accessible avec toutes ses
	# options.
	assign apply_sommier_blue_filter = false
	if is_pack_new and has_sommier_tapissier_in_bundle
		assign product_bundle_parent_handle = product_bundle.metafields.custom.combined_listings_produit_parent.value.handle
		if product_bundle.handle == 'sommier' or product_bundle_parent_handle == 'sommier'
			assign apply_sommier_blue_filter = true
		endif
	endif

	comment
		TRAITEMENT PRINCIPAL DU PRODUIT BUNDLE

		Cette section gère la logique complexe pour un produit avec variantes multiples :
		- Synchronisation avec le produit parent
		- Sélection de la variante appropriée
		- Vérification de correspondance des dimensions
	endcomment
	if product_bundle != blank
		comment
			SYNCHRONISATION AVEC LE PRODUIT PARENT

			Pour les produits configurés avec variantes multiples :
			1. On récupère les options du produit parent (ex: taille sélectionnée)
			2. On cherche la variante correspondante dans le produit bundle
			3. Cela permet d'avoir la même taille/option entre parent et bundle
		endcomment

		if product_bundle.has_only_default_variant == false
			comment
				RECHERCHE DE LA VARIANTE CORRESPONDANTE DANS LE PRODUIT BUNDLE

				Le produit parent a une variante sélectionnée (ex: taille M)
				On cherche la même option dans le produit bundle
			endcomment

			comment
				DÉTECTION DES POSITIONS D'OPTIONS DANS LE PRODUIT BUNDLE

				Identifie automatiquement les positions des options taille et pieds
				pour appliquer la synchronisation appropriée
			endcomment
			assign bundle_option_position_size_array = blank
			assign bundle_option_position_foot_array = blank
			assign bundle_option_position_version_array = blank

			unless product_bundle.has_only_default_variant
				for option in product_bundle.options_with_values
					# Traitement du nom de l'option en minuscules pour comparaison
					assign option_name_downcase = option.name | downcase
					assign option_name_array = option_name_downcase | split: ' ' | uniq

					# Vérification si cette option concerne les pieds
					for translation in options_names_for_foot
						assign has_foot_in_array = option_name_array | find: translation
						if has_foot_in_array
							assign has_foot_in_array = true
							break
						endif
					endfor

					if has_foot_in_array
						assign bundle_option_position_foot_array = option.position | minus: 1
					else
						# Recherche de l'option taille si ce n'est pas une option pieds
						for option_name in option_name_array
							if options_names_for_size contains option_name
								assign bundle_option_position_size_array = option.position | minus: 1
								break
							endif

							# Recherche de l'option version
							if options_names_for_version contains option_name
								assign bundle_option_position_version_array = option.position | minus: 1
								break
							endif
						endfor
					endif
				endfor
			endunless

			# Point de départ : variante sélectionnée ou première disponible
			assign bundle_product_variant = product_bundle.selected_or_first_available_variant
			assign has_changed_option_for_hidden = false

			comment
				FILTRAGE PAR VERSION (PLUS/STANDARD)
				Pour option 1-3 : filtre avec where
				Pour option 4 : pas de pre-filtrage, vérification manuelle dans les boucles
			endcomment
			assign bundle_variants_pool = product_bundle.variants
			assign hide_variant_version = false
			if products_bundle_option_version != blank and products_bundle_option_version != 'Aucun' and bundle_option_position_version_array != blank
				assign hide_variant_version = true
				assign version_position = bundle_option_position_version_array | plus: 1
				if version_position == 1
					assign bundle_variants_pool = product_bundle.variants | where: 'option1', products_bundle_option_version
				elsif version_position == 2
					assign bundle_variants_pool = product_bundle.variants | where: 'option2', products_bundle_option_version
				elsif version_position == 3
					assign bundle_variants_pool = product_bundle.variants | where: 'option3', products_bundle_option_version
				endif

				comment
					Sélectionner la première variante disponible dans le pool filtré
					Pour option4, on vérifie manuellement dans la boucle
				endcomment
				if bundle_variants_pool != blank and bundle_variants_pool.size > 0
					for filtered_variant in bundle_variants_pool
						if version_position == 4
							if filtered_variant.options[3] != products_bundle_option_version
								continue
							endif
						endif
						assign filtered_variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if filtered_variant.option1 == 'Bleu'
								assign filtered_variant_is_blue_blocked = true
							endif
							if filtered_variant.option3 == '15 cm - Pieds Bleus'
								assign filtered_variant_is_blue_blocked = true
							endif
							if filtered_variant.option3 == '20 cm - Pieds Bleus'
								assign filtered_variant_is_blue_blocked = true
							endif
						endif
						if filtered_variant.available and filtered_variant.metafields.custom.hidden_variant.value != true and filtered_variant_is_blue_blocked != true
							assign bundle_product_variant = filtered_variant
							break
						endif
					endfor
				endif
			endif

			comment
				VÉRIFICATION ET REMPLACEMENT DES VARIANTES CACHÉES

				Si la variante sélectionnée a le métafield hidden_variant à true,
				on cherche une variante alternative disponible et non cachée
			endcomment
			assign bundle_variant_is_blue_blocked = false
			if apply_sommier_blue_filter
				if bundle_product_variant.option1 == 'Bleu'
					assign bundle_variant_is_blue_blocked = true
				endif
				if bundle_product_variant.option3 == '15 cm - Pieds Bleus'
					assign bundle_variant_is_blue_blocked = true
				endif
				if bundle_product_variant.option3 == '20 cm - Pieds Bleus'
					assign bundle_variant_is_blue_blocked = true
				endif
			endif
			if bundle_product_variant.metafields.custom.hidden_variant.value == true or bundle_variant_is_blue_blocked
				if bundle_product_variant.options.size == 1
					assign candidate_variants_all = bundle_variants_pool
				elsif bundle_product_variant.options.size == 2
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1]
				elsif bundle_product_variant.options.size == 3
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
					assign candidate_variants_matching_two_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
				elsif bundle_product_variant.options.size == 4
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1]
					assign candidate_variants_matching_two_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
					assign candidate_variants_matching_three_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
				endif

				assign valid_variant_bundle_found = false
				if valid_variant_bundle_found == false and candidate_variants_matching_three_options != blank
					for variant in candidate_variants_matching_three_options
						comment
							Pour option4, on doit filtrer manuellement car where: 'option4' n'existe pas en Liquid
						endcomment
						if variant.options[3] != bundle_product_variant.options[3]
							continue
						endif

						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '20 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
						endif
						if variant_available and variant.metafields.custom.hidden_variant.value != true and variant_is_blue_blocked != true
							assign bundle_product_variant = variant
							assign valid_variant_bundle_found = true
							break
						endif
					endfor
				endif

				if valid_variant_bundle_found == false and candidate_variants_matching_two_options != blank
					for variant in candidate_variants_matching_two_options
						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '20 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
						endif
						if variant_available and variant.metafields.custom.hidden_variant.value != true and variant_is_blue_blocked != true
							assign bundle_product_variant = variant
							assign valid_variant_bundle_found = true
							if candidate_variants_matching_three_options != blank
								assign has_changed_option_for_hidden = true
							endif
							break
						endif
					endfor
				endif

				if valid_variant_bundle_found == false and candidate_variants_matching_first_options != blank
					for variant in candidate_variants_matching_first_options
						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '20 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
						endif
						if variant_available and variant.metafields.custom.hidden_variant.value != true and variant_is_blue_blocked != true
							assign bundle_product_variant = variant
							assign valid_variant_bundle_found = true
							if candidate_variants_matching_two_options != blank
								assign has_changed_option_for_hidden = true
							endif
							break
						endif
					endfor
				endif

				if valid_variant_bundle_found == false and candidate_variants_all != blank
					for variant in candidate_variants_all
						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '20 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
						endif
						if variant_available and variant.metafields.custom.hidden_variant.value != true and variant_is_blue_blocked != true
							assign bundle_product_variant = variant
							assign valid_variant_bundle_found = true
							if candidate_variants_matching_first_options != blank
								assign has_changed_option_for_hidden = true
							endif
							break
						endif
					endfor
				endif
			endif

			comment
				VÉRIFICATION ET REMPLACEMENT DES VARIANTES CACHÉES

				Si la variante sélectionnée a le métafield hidden_variant à true,
				on cherche une variante alternative disponible et non cachée
			endcomment
			assign bundle_variant_is_blue_blocked = false
			if apply_sommier_blue_filter
				if bundle_product_variant.option1 == 'Bleu'
					assign bundle_variant_is_blue_blocked = true
				endif
				if bundle_product_variant.option3 == '15 cm - Pieds Bleus'
					assign bundle_variant_is_blue_blocked = true
				endif
				if bundle_product_variant.option3 == '20 cm - Pieds Bleus'
					assign bundle_variant_is_blue_blocked = true
				endif
			endif
			if bundle_product_variant.metafields.custom.hidden_variant.value == true or bundle_variant_is_blue_blocked
				if bundle_product_variant.options.size == 1
					assign candidate_variants_all = bundle_variants_pool
				elsif bundle_product_variant.options.size == 2
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1]
				elsif bundle_product_variant.options.size == 3
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
					assign candidate_variants_matching_two_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
				elsif bundle_product_variant.options.size == 4
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1]
					assign candidate_variants_matching_two_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
					assign candidate_variants_matching_three_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
				endif

				assign valid_variant_bundle_found = false
				if valid_variant_bundle_found == false and candidate_variants_matching_three_options != blank
					for variant in candidate_variants_matching_three_options
						comment
							Pour option4, on doit filtrer manuellement car where: 'option4' n'existe pas en Liquid
						endcomment
						if variant.options[3] != bundle_product_variant.options[3]
							continue
						endif

						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '20 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
						endif
						if variant_available and variant.metafields.custom.hidden_variant.value != true and variant_is_blue_blocked != true
							assign bundle_product_variant = variant
							assign valid_variant_bundle_found = true
							break
						endif
					endfor
				endif

				if valid_variant_bundle_found == false and candidate_variants_matching_two_options != blank
					for variant in candidate_variants_matching_two_options
						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
