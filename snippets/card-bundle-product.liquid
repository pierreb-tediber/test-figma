		comment
			RÉCUPÉRATION DES INFORMATIONS D'AFFICHAGE DU PRODUIT

			Extrait titre, image et caractéristiques avec priorité aux metafields
			personnalisés puis fallback vers les données standard
		endcomment
		if bundle_product_variant.metafields.custom.pack_information.value != blank
			# Priorité aux informations spécifiques du pack
			assign selected_product_bundle_title = bundle_product_variant.metafields.custom.pack_information.value.title.value
			assign selected_product_bundle_image = bundle_product_variant.metafields.custom.pack_information.value.image.value
			assign selected_product_bundle_features = bundle_product_variant.metafields.custom.pack_information.value.caracteristiques.value
		elsif product_bundle.metafields.custom.pack_information.value != blank
			# Fallback vers les informations du produit parent
			assign selected_product_bundle_title = product_bundle.metafields.custom.pack_information.value.title.value
			assign selected_product_bundle_image = product_bundle.metafields.custom.pack_information.value.image.value
			assign selected_product_bundle_features = product_bundle.metafields.custom.pack_information.value.caracteristiques.value
		else
			# Fallback vers les données standard avec gestion des combined listings
			if product_bundle.metafields.custom.combined_listings_produit_parent.value != blank
				assign selected_product_bundle_title = product_bundle.metafields.custom.combined_listings_produit_parent.value.title
			else
				assign selected_product_bundle_title = product_bundle.title
			endif

			# Image : priorité
			# 1. (pack-new uniquement) `couleurs.image_dans_le_pack` — visuel dédié
			#    quand la variante est montée dans un pack
			# 2. `couleurs.image_de_la_variante` (fallback)
			# 3. `product_bundle.featured_image` (fallback ultime)
			if is_pack_new and bundle_product_variant.metafields.custom.color.value.image_dans_le_pack.value != blank
				assign selected_product_bundle_image = bundle_product_variant.metafields.custom.color.value.image_dans_le_pack.value
			elsif bundle_product_variant.metafields.custom.color.value.image_de_la_variante.value != blank
				assign selected_product_bundle_image = bundle_product_variant.metafields.custom.color.value.image_de_la_variante.value
			else
				assign selected_product_bundle_image = product_bundle.featured_image
			endif
			assign selected_product_bundle_features = blank
		endif

		comment
			RÉCUPÉRATION DE LA DATE DE DISPONIBILITÉ DU PRODUIT BUNDLE

			Extrait la date de disponibilité du produit bundle
		endcomment
		assign selected_product_bundle_date_dispo = blank
		if bundle_product_variant.metafields.custom.date_de_dispo.value != blank
			assign selected_product_bundle_date_dispo = bundle_product_variant.metafields.custom.date_de_dispo.value
		endif

		comment
			CALCULS DE PRIX ET SURPLUS POUR CE PRODUIT

			Détermine le prix à utiliser et calcule le supplément
			par rapport au prix de référence de l'étape
		endcomment
		comment
			Récupération du prix à utiliser : prix normal
		endcomment
		assign product_price_to_use = bundle_product_variant.price
		assign product_compare_at_price_to_use = bundle_product_variant.compare_at_price | default: bundle_product_variant.price
		assign product_price_to_use_ref = bundle_product_variant.price
		assign product_compare_at_price_to_use_ref = bundle_product_variant.compare_at_price | default: bundle_product_variant.price

		comment
			Calcul du surplus par rapport au prix de référence avec application des réductions
		endcomment
		assign discount_amount = product_price_to_use | times: discount_value | divided_by: 100
		assign product_price_to_use = product_price_to_use | minus: discount_amount
		assign product_price_surplus = product_price_to_use | minus: reference_price

		# Applique la réduction en pourcentage au prix orignal
		assign discount_amount_compare_at_price = product_compare_at_price_to_use | times: discount_value | divided_by: 100
		assign product_compare_at_price_to_use = product_compare_at_price_to_use | minus: discount_amount_compare_at_price
		assign product_compare_at_price_surplus = product_compare_at_price_to_use | minus: reference_price_compare_at_price
	endif

	comment
		GESTION DES CAS D'OPTION CORRESPONDANTE NON TROUVÉE

		Détecte les cas où une synchronisation était recherchée
		mais aucune variante compatible n'a été trouvée
	endcomment
	assign has_matching_option_but_no_found = false
	if has_matching_option == true and has_matching_size == false
		assign has_matching_option_but_no_found = true
	endif

	comment
		VÉRIFICATION FINALE DE DISPONIBILITÉ DU PRODUIT/VARIANTE

		Applique la logique complète de disponibilité à la variante
		représentative sélectionnée pour ce produit
	endcomment
	assign check_against_inventory = true
	if bundle_product_variant.inventory_management != 'shopify' or bundle_product_variant.inventory_policy == 'continue'
		assign check_against_inventory = false
	endif

	assign quantity_rule_soldout = false
	if bundle_product_variant.quantity_rule.min > bundle_product_variant.inventory_quantity and check_against_inventory
		assign quantity_rule_soldout = true
	endif

	assign product_bundle_available = true
	if bundle_product_variant.available == false or quantity_rule_soldout or bundle_product_variant == null or has_matching_option_but_no_found
		assign product_bundle_available = false
	endif

	assign bundle_variant_is_blue_blocked = false
	if apply_sommier_blue_filter
		if bundle_product_variant.option1 == 'Bleu'
			assign bundle_variant_is_blue_blocked = true
		endif
		if bundle_product_variant.option3 == '15 cm - Pieds Bleus'
			assign bundle_variant_is_blue_blocked = true
		endif
		if bundle_product_variant.option3 == '20 cm - Pieds Bleus'
			assign bundle_variant_is_blue_blocked = true
		endif
	endif
	if bundle_product_variant.metafields.custom.hidden_variant.value == true or bundle_variant_is_blue_blocked
		assign product_bundle_available = false
	endif

	comment
		LOGIQUE DE SÉLECTION PAR DÉFAUT

		Détermine si ce produit doit être pré-sélectionné selon
		sa position et la disponibilité de l'étape
	endcomment
	assign product_should_be_checked = false
	assign product_should_be_checked_last = false

	if current_index == first_available_index and step_has_available_items and product_bundle_available
		assign product_should_be_checked = true
	endif

	if has_item_visible == false and product_should_be_checked == false
		assign product_should_be_checked_last = true
	endif

	comment
		CONSTRUCTION DE LA CHAÎNE D'OPTIONS POUR CE PRODUIT

		Crée la chaîne d'identification unique basée sur la variante
		représentative sélectionnée avec application des règles de nettoyage
	endcomment
	assign variant_option_string = selected_product_bundle_title

	for option in bundle_product_variant.options
		assign option_value = option
		assign option_name_downcase = option.name | downcase
		assign option_name_array = option_name_downcase | split: ' ' | uniq

		# Traitement spécial selon le type d'option détecté
		if bundle_option_position_size_array == forloop.index0
			# Options de taille : application des règles d'exception
			assign has_value_except = false
			assign has_value_except_strict = false

			for value_strict_except in options_names_for_size_value_strict_except
				if option_name_downcase == value_strict_except
					assign has_value_except_strict = true
					break
				endif
			endfor

			for option_name in option_name_array
				if options_names_for_size_value_except contains option_name
					assign has_value_except = true
					break
				endif
			endfor

			# Si pas d'exception : extrait le type après le tiret
			unless has_value_except == true or has_value_except_strict == true
				assign option_parts = option_value | split: '-'
				assign type_part = blank

				if option_parts.size > 1
					assign type_part_raw = option_parts[1] | strip
					assign type_part_raw_lc = type_part_raw | downcase
					if type_part_raw_lc == default_format_lc
						assign type_part = blank
					else
						assign type_part = type_part_raw
					endif
				endif

				assign option_value = type_part | default: blank
			endunless
		elsif bundle_option_position_foot_array == forloop.index0
			# Options de pieds : extrait toujours le type après le tiret
			assign option_parts = option_value | split: '-'
			assign type_part = blank

			if option_parts.size > 1
				assign type_part = option_parts[1] | strip
			endif

			assign option_value = type_part | default: blank
		endif

		# Ignore les valeurs par défaut et vides
		if option_value == 'Default Title' or option_value == blank
			continue
		endif

		# Ajout de l'option à la chaîne finale
		assign variant_option_string = variant_option_string | append: '|' | append: option_value
	endfor

	# Vérifie si la variante est cachée
	assign product_bundle_variant_hidden = false
	assign bundle_variant_is_blue_blocked = false
	if apply_sommier_blue_filter
		if bundle_product_variant.option1 == 'Bleu'
			assign bundle_variant_is_blue_blocked = true
		endif
		if bundle_product_variant.option3 == '15 cm - Pieds Bleus'
			assign bundle_variant_is_blue_blocked = true
		endif
		if bundle_product_variant.option3 == '20 cm - Pieds Bleus'
			assign bundle_variant_is_blue_blocked = true
		endif
	endif
	if bundle_product_variant.metafields.custom.hidden_variant.value == true or bundle_variant_is_blue_blocked
		assign product_bundle_variant_hidden = true
	endif

	# Génération d'un ID unique pour ce produit bundle dans cette étape
	assign unique_id = section.id | append: '-bundle-' | append: step_number | append: '-' | append: selected_product_bundle_id

	# Sous-titre pack-new solo : "{titre} • {dim}" affiché au-dessus de la card.
	# On strip un éventuel suffixe " - Monobloc/Bibloc" de la dim pour ne garder
	# que la dimension "140 x 190 cm" attendue.
	assign show_solo_subtitle = false
	if is_pack_new and is_solo_in_step
		assign show_solo_subtitle = true
	endif
	assign solo_subtitle_dim = blank
	if show_solo_subtitle and bundle_option_position_size_array != blank
		assign solo_subtitle_size_value = bundle_product_variant.options[bundle_option_position_size_array]
		assign solo_subtitle_dim = solo_subtitle_size_value | split: ' - ' | first | strip
	endif

	# Modifier de classe pour la card en contexte pack-new solo : passe l'image en
	# grand au top + masque la ligne titre/caret legacy via CSS.
	assign bundle_card_layout_modifier = ''
	if show_solo_subtitle
		assign bundle_card_layout_modifier = ' product__variant-selects__bundle__card--pack-new-solo'
	endif
-%}

{%- comment -%}
	Subtitle solo "{titre} {version} • {dim}" : déplacé dans product-bundle.liquid
	(au-dessus de `__bundle__container`) pour homogénéiser le DOM entre matelas
	(card-bundle-variant) et sommier (card-bundle-product). Cf. la branche
	`elsif solo_subtitle_title != blank` au-dessus de la container render.
{%- endcomment -%}

<div class="product__variant-selects__bundle__item">
	{%- if show_solo_subtitle -%}
		{%- comment -%}
			Modal gallery pack-new : `<dialog>` natif appelé via `showModal()` →
			placée en top-layer (échappe à tout containing block transformé, ce qui
			était bloquant avec position:fixed sur `<div>` à cause du transform sur
			`.product__info-wrapper.scroll-trigger`).
			Chaque fetch de variante re-rend ce dialog avec une liste media
			fraîchement filtrée par alt-text — pas de bind JS à `media-gallery`.
			Close : bouton avec onclick `.close()` natif + clic backdrop (`<form
			method="dialog">` ferme aussi par Esc).
		{%- endcomment -%}
		{%- liquid
			# Détection du contexte AJAX "ouverture de la modal" : quand le flag
			# `gallery_modal=1` est présent dans la query string, on rend les images.
			# Sinon (page load OU refresh de variant via section_id=card-bundle-product
			# sans le flag), on ne rend qu'un spinner — 0 image dans le DOM → 0 requête
			# réseau au load page (iso `product-media-modal.liquid#use_lazy_loading`).
			capture content_for_query_string_gallery
				echo content_for_header
			endcapture
			assign gallery_current_url = content_for_query_string_gallery | split: '"pageurl":"' | last | split: '"' | first | split: '.myshopify.com' | last | replace: '\/', '/' | replace: '%20', ' ' | replace: '&', '&'
			assign gallery_is_modal_fetch = false
			if gallery_current_url contains 'gallery_modal=1'
				assign gallery_is_modal_fetch = true
			endif

			# URL de fetch que `<bundle-gallery-modal>` JS appelle au 1er clic.
			# Reprend le pattern des refresh de variant (section_id=card-bundle-product)
			# en ajoutant le flag `gallery_modal=1` pour signaler à la même section
			# qu'il faut rendre les `<img>` réels dans `[data-modal-content]`.
			# `isPackNew` + `isSoloInStep` sont nécessaires pour que la section
			# template re-injecte ces flags au snippet (sinon `show_solo_subtitle`
			# devient false côté serveur et le `<bundle-gallery-modal>` n'est même
			# pas rendu dans la réponse). `variant` pré-sélectionne la variante
			# pour alignement avec la sélection courante (combined listings).
			assign gallery_fetch_url = product_bundle.url | append: '?section_id=card-bundle-product&gallery_modal=1&isPackNew=true&isSoloInStep=true&variant=' | append: bundle_product_variant.id

			# Pour les combined listings (parent → enfants), `product_bundle.media`
			# ne contient que les images du parent (souvent peu nombreuses). On
			# bascule sur le premier produit enfant (iso main-product.liquid).
			assign gallery_media = product_bundle.media
			if product_bundle.metafields.custom.combined_listings_premier_produit_enfant.value.media != blank
				assign gallery_media = product_bundle.metafields.custom.combined_listings_premier_produit_enfant.value.media
			endif
			assign gallery_current_lang = localization.language.iso_code
			assign gallery_visible_count = 0

			# variant_option_string format ici = "{titre}|{option1}|{option2}|..."
			# Les media alt côté admin sont saisis sans le titre en préfixe
			# (ex. "Beige|Pieds Hêtre clair|Plus"). On strip donc le 1er segment
			# (titre) pour matcher l'alt simple sans préfixe.
			assign gallery_variant_string_no_title = variant_option_string
			assign gallery_variant_string_parts = variant_option_string | split: '|'
			if gallery_variant_string_parts.size > 1
				assign gallery_variant_string_no_title = ''
				for gallery_part in gallery_variant_string_parts
					if forloop.first
						continue
					endif
					if gallery_variant_string_no_title == ''
						assign gallery_variant_string_no_title = gallery_part
					else
						assign gallery_variant_string_no_title = gallery_variant_string_no_title | append: '|' | append: gallery_part
					endif
				endfor
			endif
		-%}
		<bundle-gallery-modal
			id="bundle-gallery-modal-{{ unique_id }}"
			data-fetch-url="{{ gallery_fetch_url }}"
		>
			<dialog
				data-modal-dialog
				class="product__variant-selects__bundle__card__gallery-modal"
				aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
			>
				<form method="dialog" class="product__variant-selects__bundle__card__gallery-modal__close-form">
					<button
						type="submit"
						class="product__variant-selects__bundle__card__gallery-modal__close"
						aria-label="{{ 'accessibility.close' | t }}"
					>
						{{- 'icon-close.svg' | inline_asset_content -}}
					</button>
				</form>
				<div
					class="product__variant-selects__bundle__card__gallery-modal__content"
					data-modal-content
				>
					{%- if gallery_is_modal_fetch -%}
						{%- for media in gallery_media -%}
							{%- liquid
								# Logique iso main-product : featured de la variante toujours
								# visible ; alt #lang#value parsé et comparé à variant_option_string ;
								# alt sans # toujours visible (lifestyle / packaging / etc.).
								assign gallery_is_visible = false
								if bundle_product_variant.featured_media and media.id == bundle_product_variant.featured_media.id
									assign gallery_is_visible = true
								endif
								if media.alt contains '#'
									assign gallery_alt_parts = media.alt | split: '#'
									assign gallery_localized_alt = ''
									for i in (0..gallery_alt_parts.size)
										assign gallery_part = gallery_alt_parts[i]
										if gallery_part == gallery_current_lang
											assign gallery_next = i | plus: 1
											if gallery_next < gallery_alt_parts.size
												assign gallery_localized_alt = gallery_alt_parts[gallery_next]
												break
											endif
										endif
									endfor
									if gallery_localized_alt != ''
										# Compare avec la string sans le titre (les alt admin
										# n'incluent pas le titre en préfixe).
										if gallery_localized_alt == gallery_variant_string_no_title
											assign gallery_is_visible = true
										endif
									else
										if media.alt == gallery_variant_string_no_title
											assign gallery_is_visible = true
										endif
									endif
								else
									assign gallery_is_visible = true
								endif
							-%}
							{%- if gallery_is_visible -%}
								{%- assign gallery_visible_count = gallery_visible_count | plus: 1 -%}
								<div class="product__variant-selects__bundle__card__gallery-modal__item">
									{{
										media
										| image_url: width: 1600
										| image_tag:
											loading: 'eager',
											width: media.width,
											height: media.height,
											alt: selected_product_bundle_title
									}}
								</div>
							{%- endif -%}
						{%- endfor -%}
					{%- else -%}
						{%- comment -%}
							Spinner visible immédiatement à l'ouverture (sans `hidden`)
							— remplacé par le contenu fetché dans `<bundle-gallery-modal>.#ensureContentLoaded()`.
						{%- endcomment -%}
						<div class="product__variant-selects__bundle__card__gallery-modal__loading">
							{%- render 'loading-spinner', class: 'loading__spinner' -%}
						</div>
					{%- endif -%}
				</div>
			</dialog>
		</bundle-gallery-modal>
	{%- endif -%}

	<product-bundle-item
		data-section="card-bundle-product"
		data-url="{{ product_bundle.url }}"
	>
		{% comment %}
			Input radio caché pour la logique de sélection
			Contient les données de la variante représentative sélectionnée
		{% endcomment %}
		<input
			type="radio"
			class="product__variant-selects__bundle__radio visually-hidden{% if product_should_be_checked_last %} product__variant-selects__bundle__radio--unavailable-last{% endif %}"
			id="bundle-item-{{ step_number }}-product-{{ product_bundle.id }}"
			name="bundle_items[{{ step_number }}]"
			value="product:{{ product_bundle.id }}:{{ bundle_product_variant.id }}"
			data-bundle-item="product"
			data-product-id="{{ product_bundle.id }}"
			data-variant-id="{{ bundle_product_variant.id }}"
			data-variant-sku="{{ bundle_product_variant.sku }}"
			data-title="{{ product_bundle.title | append: ' ' | append: bundle_product_variant.title }}"
			data-parent-option-size-cleaned="{{ parent_option_size_cleaned }}"
			data-step-number="{{ step_number }}"
			data-parent-section-id="{{ section_id }}"
			data-reference-price="{{ reference_price }}"
			data-reference-price-compare-at-price="{{ reference_price_compare_at_price }}"
			data-current-custom-position="{{ current_custom_position }}"
			data-current-item-index="{{ current_index }}"
			data-unique-id="{{ unique_id }}"
			data-first-available-index="{{ first_available_index }}"
			data-step-has-available-items="{{ step_has_available_items }}"
			data-has-item-visible="{{ has_item_visible }}"
			data-image-alt-string="{{ variant_option_string }}"
			data-available="{{ product_bundle_available }}"
			data-variant-hidden="{{ product_bundle_variant_hidden }}"
			data-discount-value="{{ discount_value }}"
			data-price="{{ product_price_to_use_ref }}"
			data-compare-at-price="{{ product_compare_at_price_to_use_ref }}"
			data-price-eco-part="{{ bundle_product_variant.metafields.custom.exo_tax.value | default: 0 | times: 100 }}"
			data-no-price-surplus="{{ no_price_surplus }}"
			data-date-dispo="{{ selected_product_bundle_date_dispo }}"
			data-products-bundle-option-version="{{ products_bundle_option_version }}"
			data-is-pack-new="{{ is_pack_new }}"
			data-is-solo-in-step="{{ is_solo_in_step }}"
			data-hide-extras="{{ hide_extras }}"
			data-has-sommier-tapissier-in-bundle="{{ has_sommier_tapissier_in_bundle }}"
			{% if product_should_be_checked or product_should_be_checked_last or selected_variant != blank %}
				checked
			{% endif %}
			{% if product_bundle_available == false and selected_variant == blank %}
				disabled
			{% endif %}
		>

		<div class="product__variant-selects__bundle__item__inner">
			<label
				for="bundle-item-{{ step_number }}-product-{{ product_bundle.id }}"
				class="product__variant-selects__bundle__card{% if product_bundle_available == false and selected_variant == blank %} product__variant-selects__bundle__card--unavailable{% endif %}{% unless step_has_available_items %} product__variant-selects__bundle__card--disabled{% endunless %}{{ bundle_card_layout_modifier }}"
				data-bundle-item="product"
				data-product-id="{{ product_bundle.id }}"
				data-variant-id="{{ bundle_product_variant.id }}"
			>
				<div class="product__variant-selects__bundle__card__inner">
					{%- if selected_product_bundle_image != blank -%}
						{%- comment -%}
							Width adaptée au contexte :
							- pack-new solo : image pleine largeur (~326px), width 800 pour
							  couvrir Retina sans pixéliser. Wrapper en <button> pour ouvrir
							  la modal au clic sur l'image entière (`showModal()` natif sur
							  `<dialog>` → top-layer, échappe au containing block créé par
							  `.product__info-wrapper.scroll-trigger` transformé).
							- legacy : thumbnail 81px, 162px (2x), simple span.
						{%- endcomment -%}
						{%- assign card_image_width = 162 -%}
						{%- if show_solo_subtitle -%}
							{%- assign card_image_width = 800 -%}
						{%- endif -%}
						{%- if show_solo_subtitle -%}
							<button
								type="button"
								class="product__variant-selects__bundle__card__image product__variant-selects__bundle__card__image--gallery-trigger"
								onclick="document.getElementById('bundle-gallery-modal-{{ unique_id }}').open()"
								aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
							>
								{{
									selected_product_bundle_image
									| image_url: width: card_image_width
									| image_tag: loading: 'lazy', alt: selected_product_bundle_title
								}}
								<span
									class="product__variant-selects__bundle__card__image__zoom"
									aria-hidden="true"
								>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none">
										<circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1"/>
										<path d="M14 14 L10.5 10.5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
										<path d="M7 5v4M5 7h4" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
									</svg>
								</span>
							</button>
						{%- else -%}
							<span class="product__variant-selects__bundle__card__image">
								{{
									selected_product_bundle_image
									| image_url: width: card_image_width
									| image_tag: loading: 'lazy', alt: selected_product_bundle_title
								}}
							</span>
						{%- endif -%}
					{%- endif -%}
					<span class="product__variant-selects__bundle__card__text-wrapper">
						<span class="product__variant-selects__bundle__card__text-wrapper-inner">
							<span class="product__variant-selects__bundle__card__label">
								<span class="product__variant-selects__bundle__card__label__title">
									{{ selected_product_bundle_title }}
									{%- if hide_variant_version and bundle_option_position_version_array != blank -%}
										{%- if options_version_labels_to_show contains products_bundle_option_version -%}
											<span class="product__variant-selects__bundle__card__label__version">{{ products_bundle_option_version }}</span>
										{%- endif -%}
									{%- endif -%}
								</span>
								{% comment %}
									Affichage des caractéristiques du produit si disponibles
								{% endcomment %}
								{%- if selected_product_bundle_features != blank -%}
									<span class="product__variant-selects__bundle__card__label__features">
										{%- for feature in selected_product_bundle_features -%}
											<span class="product__variant-selects__bundle__card__label__feature">
												{{ feature }}
											</span>
										{%- endfor -%}
									</span>
								{%- endif -%}
							</span>
							{% comment %}
								Messages d'état selon la disponibilité et la correspondance
							{% endcomment %}
							{%- if product_bundle_variant_hidden == true -%}
								<span class="product__variant-selects__bundle__card__stock-status">
									{{ 'products.product.unavailable_short' | t }}
								</span>
							{%- elsif has_matching_size == false and selected_variant == blank -%}
								<span class="product__variant-selects__bundle__card__stock-status">
									{{ 'products.product.unavailable_bundle' | t }}
								</span>
							{%- elsif product_bundle_available == false -%}
								<span class="product__variant-selects__bundle__card__stock-status">
									{{ 'products.product.sold_out' | t }}
								</span>
							{%- endif -%}
							{% comment %}
								Affichage du surplus de prix si positif et produit disponible
							{% endcomment %}
							{%- if product_bundle_available == true -%}
								{%- if product_price_surplus > 0 and no_price_surplus == false -%}
									<span class="product__variant-selects__bundle__card__price-surplus">
										<span class="product__variant-selects__bundle__card__price-surplus--current{% if product_compare_at_price_surplus > 0 and product_compare_at_price_to_use > product_price_to_use %} product__variant-selects__bundle__card__price-surplus--current--compare-price{% endif %}">
											{{ product_price_surplus | money | prepend: '+' }}
										</span>
										{%- if product_compare_at_price_surplus > 0
											and product_compare_at_price_to_use > product_price_to_use
										-%}
											<span class="product__variant-selects__bundle__card__price-surplus--compare">
												{{ product_compare_at_price_surplus | money | prepend: '+' }}
											</span>
										{%- endif -%}
									</span>
								{%- endif -%}
							{%- endif -%}
						</span>
						{% comment %}
							Icône de configuration si le produit a des variantes ou est disponible
						{% endcomment %}
						{%- if product_bundle_available == true or has_matching_size == true -%}
							<span class="product__variant-selects__bundle__card__text-wrapper-inner__right">
								<span class="svg-wrapper">
									{{- 'icon-caret.svg' | inline_asset_content -}}
								</span>
							</span>
						{%- endif -%}
					</span>
				</div>
			</label>
			{% comment %}
				SECTION DE CONFIGURATION DU PRODUIT

				Si le produit a des variantes multiples, affiche le sélecteur
				de variantes intégré pour permettre la configuration
			{% endcomment %}
			{%- if product_bundle.has_only_default_variant == false -%}
				<div class="product__variant-selects__bundle__config">
					<div class="product__variant-selects__bundle__list">
						{% render 'product-bundle-picker',
							product: product_bundle,
							current_variant: bundle_product_variant,
							has_changed_option_for_hidden: has_changed_option_for_hidden,
							block: block,
							product_form_id: product_form_id,
							current_custom_position: current_custom_position,
							unique_id: unique_id,
							reference_price: reference_price,
							hide_variant_size: has_matching_size,
							has_matching_option: has_matching_option,
							hide_custom_position: true,
							discount_value: discount_value,
							hide_variant_version: hide_variant_version,
							products_bundle_option_version: products_bundle_option_version,
							bundle_option_position_version_array: bundle_option_position_version_array,
							is_pack_new: is_pack_new,
							hide_extras: hide_extras,
							has_sommier_tapissier_in_bundle: has_sommier_tapissier_in_bundle
						%}
					</div>
				</div>
			{%- endif -%}
		</div>
	</product-bundle-item>
</div>
