				elsif bundle_product_variant.options.size == 2
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1]
				elsif bundle_product_variant.options.size == 3
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
					assign candidate_variants_matching_two_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
				elsif bundle_product_variant.options.size == 4
					assign candidate_variants_all = bundle_variants_pool
					assign candidate_variants_matching_first_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1]
					assign candidate_variants_matching_two_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
					assign candidate_variants_matching_three_options = bundle_variants_pool | where: 'option1', bundle_product_variant.options[0] | where: 'option2', bundle_product_variant.options[1] | where: 'option3', bundle_product_variant.options[2]
				endif

				assign valid_variant_bundle_found = false
				if valid_variant_bundle_found == false and candidate_variants_matching_three_options != blank
					for variant in candidate_variants_matching_three_options
						comment
							Pour option4, on doit filtrer manuellement car where: 'option4' n'existe pas en Liquid
						endcomment
						if variant.options[3] != bundle_product_variant.options[3]
							continue
						endif

						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '20 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
							endif
						endif
						if variant_available and variant.metafields.custom.hidden_variant.value != true and variant_is_blue_blocked != true
							assign bundle_product_variant = variant
							assign valid_variant_bundle_found = true
							break
						endif
					endfor
				endif

				if valid_variant_bundle_found == false and candidate_variants_matching_two_options != blank
					for variant in candidate_variants_matching_two_options
						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
