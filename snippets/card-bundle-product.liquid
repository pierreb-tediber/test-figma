						côtés n'a pas de suffixe format (ex. parent pack-lit-5-etoiles
						"200×200 cm" sans suffixe vs tapissier "200×200 cm - Bibloc"
						bibloc-only). Match strict ailleurs (legacy intact).
					endcomment
					assign size_match_card_product = false
					if parent_option_size_cleaned == variant_option_size_cleaned
						assign size_match_card_product = true
					elsif is_pack_new
						assign parent_has_format_cp = false
						if parent_option_size_cleaned contains '-'
							assign parent_has_format_cp = true
						endif
						if parent_has_format_cp == false or variant_type_part == blank
							assign parent_dim_only_cp = parent_option_size_cleaned | split: '-' | first
							assign variant_dim_only_cp = variant_option_size_cleaned | split: '-' | first
							if parent_dim_only_cp == variant_dim_only_cp
								assign size_match_card_product = true
							endif
						endif
					endif
					if size_match_card_product
						comment
							PROTECTION ANTI-MISMATCH SUR selected_variant

							selected_variant vient de product_bundle.selected_or_first_available_variant.
							Quand le fetch contient des option_values invalides pour ce produit
							(typiquement pour un combined listing child), Shopify fallback
							sur la 1re variante du produit qui peut avoir une taille différente
							du parent (ex: sommier-gris 1re variante = 80x190, parent pack = 140x190).
							On ne respecte selected_variant que si ses DIMENSIONS match.

							Comparaison sur les dimensions seules (sans le suffix format
							Monobloc/Bibloc) — sinon un selected_variant Bibloc serait
							rejeté en faveur du loop variant Monobloc (le 1er à matcher
							quand le pack n'expose pas le format). Cf. bug "Bibloc revert
							vers Monobloc" sur axome-pack.
						endcomment
						assign selected_variant_size_matches = false
						if selected_variant != blank and bundle_option_position_size_array != blank
							assign sv_size = selected_variant.options[bundle_option_position_size_array]
							assign sv_dim_only = sv_size | split: ' - ' | first | strip
							assign variant_dim_only = variant.options[bundle_option_position_size_array] | split: ' - ' | first | strip
							if sv_dim_only == variant_dim_only
								assign selected_variant_size_matches = true
							endif
						endif

						if selected_variant_size_matches
							# Priorité à la variante explicitement passée (préserve les choix pieds/version)
							assign bundle_product_variant = selected_variant
							assign has_matching_size = true
							break
						else
							# selected_variant absente ou taille incorrecte : on prend variant (taille garantie OK)
							assign check_against_inventory = true
							if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
								assign check_against_inventory = false
							endif

							assign quantity_rule_soldout = false
							if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
								assign quantity_rule_soldout = true
							endif

							assign variant_available = true
							if variant.available == false or quantity_rule_soldout or variant == null
								assign variant_available = false
							endif

							assign has_matching_size = true

							if variant_available
								assign bundle_product_variant = variant
								break
							endif
						endif
					endif
				endfor
			endif
		else
			comment
