					endif

					assign variant_option_size = variant.options[bundle_option_position_size_array]

					comment
						NORMALISATION DES DIMENSIONS DE CETTE VARIANTE

						Applique le même algorithme de nettoyage que pour le produit parent
						pour permettre une comparaison exacte des dimensions
					endcomment
					assign variant_option_size_cleaned = blank
					if variant_option_size != blank
						assign variant_option_size_parts = variant_option_size | split: '-'
						assign variant_dimensions_part = variant_option_size_parts[0] | strip
						assign variant_type_part = blank

						if variant_option_size_parts.size > 1
							assign variant_type_part_raw = variant_option_size_parts[1] | strip
							assign variant_type_part_raw_lc = variant_type_part_raw | downcase
							if variant_type_part_raw_lc == default_format_lc
								assign variant_type_part = blank
							else
								assign variant_type_part = variant_type_part_raw
							endif
						endif

						assign variant_option_size_no_units = variant_dimensions_part | replace: 'cm', '' | replace: 'mm', '' | replace: 'CM', '' | replace: 'MM', '' | downcase | strip
						assign variant_dimensions_array = variant_option_size_no_units | split: 'x'

						if variant_dimensions_array.size >= 2
							assign variant_dimension_1 = variant_dimensions_array[0] | strip
							assign variant_dimension_2 = variant_dimensions_array[1] | strip
							assign variant_option_size_cleaned = variant_dimension_1 | append: 'x' | append: variant_dimension_2
						else
							assign variant_option_size_cleaned = variant_dimensions_array | join: 'x'
						endif

						if variant_type_part != blank
							assign variant_option_size_cleaned = variant_option_size_cleaned | append: '-' | append: variant_type_part
						endif
					endif

					comment
						VALIDATION ET SÉLECTION DE LA VARIANTE COMPATIBLE

						Si les dimensions correspondent, on vérifie la disponibilité
						et on sélectionne cette variante comme représentante du produit.

