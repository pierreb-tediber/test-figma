							assign valid_variant_bundle_found = true
							break
						endif
					endfor
				endif

				if valid_variant_bundle_found == false and candidate_variants_matching_first_options != blank
					for variant in candidate_variants_matching_first_options
						comment
							VÉRIFICATION DE DISPONIBILITÉ COMPLÈTE

							Même logique que dans le reste du fichier pour garantir
							qu'on sélectionne une variante réellement disponible
						endcomment
						assign check_against_inventory = true
						if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
							assign check_against_inventory = false
						endif

						assign quantity_rule_soldout = false
						if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
							assign quantity_rule_soldout = true
						endif

						assign variant_available = true
						if variant.available == false or quantity_rule_soldout or variant == null
							assign variant_available = false
						endif

						comment
							Sélectionner cette variante si elle est disponible ET non cachée
						endcomment
						assign variant_is_blue_blocked = false
						if apply_sommier_blue_filter
							if variant.option1 == 'Bleu'
								assign variant_is_blue_blocked = true
							endif
							if variant.option3 == '15 cm - Pieds Bleus'
								assign variant_is_blue_blocked = true
