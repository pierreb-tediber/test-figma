{% comment %}
	Renders product variant-picker

	Accepts:
	- product: {Object} product object.
	- block: {Object} passing the block information.
	- product_form_id: {String} Id of the product form to which the variant picker is associated.
	- show_variant_color: {Boolean} Whether to show the variant color option.
	- show_variant_size: {Boolean} Whether to show the variant size option.

	Usage:
	{% render 'product-variant-upsell-picker', product: product, block: block, product_form_id: product_form_id, show_variant_color: show_variant_color, show_variant_size: show_variant_size %}
{% endcomment %}

{%- unless product.has_only_default_variant -%}
	{%- liquid
		if product_selected_variant == blank
			assign product_selected_variant = product.selected_or_first_available_variant
		endif

		assign class_hidden = 'hidden visually-hidden'
		assign section_id = 'card-product-upsell'
		assign picker_type = 'variant_dropdown'

		# Récupère les traductions des noms d'options pour les tailles
		assign options_names_for_size_translated = 'products.product.options_names_for_size' | t | downcase | replace: ', ', ','
		assign options_names_for_size = options_names_for_size_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les couleurs
		assign options_names_for_color_translated = 'products.product.options_names_for_color' | t | downcase | replace: ', ', ','
		assign options_names_for_color = options_names_for_color_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les styles
		assign options_names_for_style_translated = 'products.product.options_names_for_style' | t | downcase | replace: ', ', ','
		assign options_names_for_style = options_names_for_style_translated | split: ',' | uniq

		# Récupère les traductions des noms d'options pour les formes
		assign options_names_for_shape_translated = 'products.product.options_names_for_shape' | t | downcase | replace: ', ', ','
		assign options_names_for_shape = options_names_for_shape_translated | split: ',' | uniq

		# Format par défaut (Monobloc) : suffixe masqué à l'affichage dans le picker taille
		assign default_format_lc = 'products.product.default_format_for_size_value' | t | downcase | strip
	-%}

	<variant-selects-upsell
		id="variant-selects-{{ section_id }}"
		data-section="{{ section_id }}"
		class="product__variant-selects"
		{{ block.shopify_attributes }}
	>
		{%- liquid
			# Assigne les valeurs par défaut
			assign selected_variant_price = blank
			assign selected_variant_color_hexa = blank
			assign selected_variant_color_image = blank
			assign selected_variant_color_label = blank

			# Assigne les valeurs si la variante est trouvée
			if product_selected_variant != blank
				# Assigne le prix si il est défini
				assign selected_variant_price = product_selected_variant.price

				# Assigne le prix de référence si il est définie
				if product_selected_variant.compare_at_price != blank
					assign selected_variant_compare_at_price = product_selected_variant.compare_at_price
				else
					assign selected_variant_compare_at_price = product_selected_variant.price
				endif

				# Assigne la couleur si elle est définie
				if product_selected_variant.metafields.custom.color.value.color.value != blank
					assign selected_variant_color_hexa = product_selected_variant.metafields.custom.color.value.color.value
				endif

				# Assigne l'image si elle est définie
				if product_selected_variant.metafields.custom.color.value.image.value != blank
					assign selected_variant_color_image = product_selected_variant.metafields.custom.color.value.image.value
				endif

				# Assigne l'image si elle est définie
				if product_selected_variant.metafields.custom.color.value.image_de_la_variante.value != blank
					assign selected_variant_color_image = product_selected_variant.metafields.custom.color.value.image_de_la_variante.value
				endif

				# Assigne le label si il est défini
				if product_selected_variant.metafields.custom.color.value.label.value != blank
					assign selected_variant_color_label = product_selected_variant.metafields.custom.color.value.label.value
				endif
			endif
		-%}

		{%- for option in product.options_with_values -%}
			{%- liquid
				# Assigne les valeurs par défaut
				assign hide_information = true

				# Traitement du nom de l'option en minuscules
				assign option_name_downcase = option.name | downcase

				# Divise le nom de l'option en tableau de mots uniques
				assign option_name_array = option_name_downcase | split: ' ' | uniq

				# Analyse chaque mot du nom de l'option pour déterminer le type de sélecteur approprié
				for option_name in option_name_array
					# Si l'option est liée à une couleur
					if options_names_for_color contains option_name
						assign picker_type = 'swatch_variant_dropdown'
						if show_variant_color
							assign hide_information = false
						endif
						break
					endif

					# Si l'option est liée à une forme
					if options_names_for_shape contains option_name
						assign picker_type = 'swatch_variant_dropdown'
						break
					endif

					# Si l'option est liée à une taille
					if options_names_for_size contains option_name
						assign picker_type = 'variant_dropdown'
						assign show_size_information_price = true
						if show_variant_size
							assign hide_information = false
						endif
						break
					endif

					# Si l'option est liée à un style
					if options_names_for_style contains option_name
						assign picker_type = 'swatch_variant_dropdown'
						break
					endif
				endfor

				# Calcule la valeur sélectionnée pour cette option basée sur la variante spécifique
				assign current_option_selected_value = blank
				if product_selected_variant != blank
					assign option_index = option.position | minus: 1
					# Si la valeur sélectionnée pour cette option est différente de la valeur de la variante sélectionnée, on assigne la valeur de la variante sélectionnée
					if selected_variant.options[option_index] != option.selected_value
						assign current_option_selected_value = product_selected_variant.options[option_index]
					endif
				endif

				if current_option_selected_value == blank
					assign current_option_selected_value = option.selected_value
				endif

				# Détection option taille (pour masquage suffixe " - Monobloc" à l'affichage)
				assign option_name_array_size_check = option.name | downcase | split: ' ' | uniq
				assign current_is_size = false
				for option_name in option_name_array_size_check
					if options_names_for_size contains option_name
						assign current_is_size = true
						break
					endif
				endfor

				# Valeur affichée du sélecteur (texte uniquement) : strippe " - Monobloc" si option taille
				assign current_option_selected_value_display = current_option_selected_value
				if current_is_size
					assign current_value_parts_display = current_option_selected_value | split: ' - '
					if current_value_parts_display.size > 1
						assign current_value_format_display_lc = current_value_parts_display | last | strip | downcase
						if current_value_format_display_lc == default_format_lc or current_value_format_display_lc == 'bibloc'
							assign current_option_selected_value_display = current_value_parts_display | first | strip
						endif
					endif
				endif

				# Hide the option picker
				assign product_parent = product.metafields.custom.combined_listings_premier_produit_enfant.value
				if product_parent != blank
					assign options_need_hide = product_parent.metafields.custom.hide_options.value | compact
				else
					assign options_need_hide = product.metafields.custom.hide_options.value | compact
				endif
				if options_need_hide.size > 0
					for option_need_hide in options_need_hide
						assign option_need_hide_downcase = option_need_hide | downcase
						if option_name_downcase == option_need_hide_downcase
							assign hide_information = true
							break
						endif
					endfor
				endif
			-%}

			{%- if picker_type == 'button' -%}
				<fieldset class="js product-form__input product-form__input--pill product__variant-selects__pill{% if hide_information %} {{ class_hidden }}{% endif %}">
					<legend class="form__label product__variant-selects__label product__variant-selects__pill__label {{ class_hidden }}">
						{{ option.position | append: '. ' -}}
						{%- if template.suffix == 'pack-new' -%}
							{{- option.name -}}
						{%- else -%}
							{{- 'products.product.product_option_name_choose' | t: option_name: option_name_downcase }}
						{%- endif -%}
					</legend>
					{%- render 'product-upsell-options',
						product: product,
						option: option,
						position: option.position,
						custom_position: option.position,
						block: block,
						picker_type: picker_type,
						section_id: section_id,
						selected_variant: product_selected_variant,
						has_changed_option_for_hidden: has_changed_option_for_hidden,
						matching_with_color: matching_with_color,
						matching_with_size: matching_with_size,
						option_position_color: option_position_color,
						option_position_size: option_position_size,
						parent_option_value_matching_color: parent_option_value_matching_color,
						parent_option_value_matching_size: parent_option_value_matching_size,
					-%}
				</fieldset>
			{%- elsif picker_type == 'variant_dropdown' or picker_type == 'swatch_variant_dropdown' -%}
				<div class="product-form__input product-form__input--dropdown product__variant-selects__dropdown product__variant-selects__dropdown--{{ picker_type }}{% if hide_information %} {{ class_hidden }}{% endif %}">
					<variant-dropdown class="variant-dropdown">
						<label
							class="form__label product__variant-selects__label product__variant-selects__dropdown__label {{ class_hidden }}"
							id="label-{{ section_id }}-{{ forloop.index0 }}"
							for="Option-Upsell-{{ section_id }}-{{ forloop.index0 }}"
						>
							{{ option.position | append: '. ' -}}
							{%- if template.suffix == 'pack-new' -%}
							{{- option.name -}}
						{%- else -%}
							{{- 'products.product.product_option_name_choose' | t: option_name: option_name_downcase }}
						{%- endif -%}
						</label>

						<div class="variant-dropdown__container">
							<button
								type="button"
								class="variant-dropdown__selected"
								aria-haspopup="listbox"
								aria-expanded="false"
								aria-labelledby="label-{{ section_id }}-{{ forloop.index0 }}"
								id="variant-dropdown-button-{{ section_id }}-{{ forloop.index0 }}"
							>
								<span class="variant-dropdown__selected__left">
									{%- if picker_type == 'swatch_variant_dropdown'
										and selected_variant_color_image != blank
										or selected_variant_color_hexa != blank
									-%}
										<span class="variant-dropdown__selected__swatch">
											{%- if selected_variant_color_image != blank -%}
												{{
													selected_variant_color_image
													| image_url: width: 50
													| image_tag: loading: 'lazy', alt: selected_variant_color_label
												}}
											{%- else -%}
												<span
													class="variant-dropdown__selected__swatch__color"
													style="background-color: {{ selected_variant_color_hexa }};"
												></span>
											{%- endif -%}
										</span>
									{%- endif -%}
									<span class="variant-dropdown__selected__text">{{ current_option_selected_value_display }}</span>
								</span>

								<span class="variant-dropdown__selected__right">
									<span class="variant-dropdown__selected__price{% if selected_variant_compare_at_price > selected_variant_price %} variant-dropdown__selected__price--compare-price{% endif %}">
										{%- if picker_type == 'swatch_variant_dropdown' -%}
											{{ 'products.product.product_option_name_choose_swatch' | t }}
										{%- else -%}
											<span class="variant-dropdown__selected__price--last">
												{{ selected_variant_price | money }}
											</span>
											{%- if selected_variant_compare_at_price > selected_variant_price -%}
												<s class="variant-dropdown__selected__price--regular">
													{{ selected_variant_compare_at_price | money }}
												</s>
											{%- endif -%}
										{%- endif -%}
									</span>
									<span class="svg-wrapper">
										{{- 'icon-caret.svg' | inline_asset_content -}}
									</span>
								</span>
							</button>

							<ul
								class="variant-dropdown__options"
								role="listbox"
								aria-labelledby="label-{{ section_id }}-{{ forloop.index0 }}"
								aria-hidden="true"
								id="variant-dropdown-options-{{ section_id }}-{{ forloop.index0 }}"
							>
								{%- render 'product-upsell-options',
									product: product,
									option: option,
									position: option.position,
									custom_position: option.position,
									block: block,
									picker_type: picker_type,
									section_id: section_id,
									show_size_information_price: show_size_information_price,
									selected_variant: product_selected_variant,
									has_changed_option_for_hidden: has_changed_option_for_hidden,
									matching_with_color: matching_with_color,
									matching_with_size: matching_with_size,
									option_position_color: option_position_color,
									option_position_size: option_position_size,
									parent_option_value_matching_color: parent_option_value_matching_color,
									parent_option_value_matching_size: parent_option_value_matching_size,
								-%}
							</ul>

							<div class="select visually-hidden" aria-hidden="true">
								<select
									id="Option-Upsell-{{ section_id }}-{{ forloop.index0 }}"
									class="select__select"
									name="options[{{ option.name | escape }}]"
									form="{{ product_form_id }}"
									aria-hidden="true"
									tabindex="-1"
								>
									{%- render 'product-upsell-options',
										product: product,
										option: option,
										position: option.position,
										custom_position: option.position,
										block: block,
										picker_type: 'dropdown',
										section_id: section_id,
										selected_variant: product_selected_variant,
										has_changed_option_for_hidden: has_changed_option_for_hidden,
										matching_with_color: matching_with_color,
										matching_with_size: matching_with_size,
										option_position_color: option_position_color,
										option_position_size: option_position_size,
										parent_option_value_matching_color: parent_option_value_matching_color,
										parent_option_value_matching_size: parent_option_value_matching_size,
									-%}
								</select>
							</div>
						</div>
					</variant-dropdown>
				</div>
			{%- else -%}
				<div class="product-form__input product-form__input--dropdown product__variant-selects__dropdown{% if hide_information %} {{ class_hidden }}{% endif %}">
					<label
						class="form__label product__variant-selects__label product__variant-selects__dropdown__label {{ class_hidden }}"
						for="Option-Upsell-{{ section_id }}-{{ forloop.index0 }}"
					>
						{{ option.position | append: '. ' -}}
						{%- if template.suffix == 'pack-new' -%}
							{{- option.name -}}
						{%- else -%}
							{{- 'products.product.product_option_name_choose' | t: option_name: option_name_downcase }}
						{%- endif -%}
					</label>
					<div class="select">
						{%- if picker_type == 'swatch_dropdown' -%}
							<span
								data-selected-value
								class="dropdown-swatch"
							>
								{%- render 'swatch', swatch: current_option_selected_value.swatch, shape: 'square' -%}
							</span>
						{%- endif -%}
						<select
							id="Option-Upsell-{{ section_id }}-{{ forloop.index0 }}"
							class="select__select"
							name="options[{{ option.name | escape }}]"
							form="{{ product_form_id }}"
						>
							{%- render 'product-upsell-options',
								product: product,
								option: option,
								position: option.position,
								custom_position: option.position,
								block: block,
								picker_type: picker_type,
								section_id: section_id,
								selected_variant: product_selected_variant,
								has_changed_option_for_hidden: has_changed_option_for_hidden,
								matching_with_color: matching_with_color,
								matching_with_size: matching_with_size,
								option_position_color: option_position_color,
								option_position_size: option_position_size,
								parent_option_value_matching_color: parent_option_value_matching_color,
								parent_option_value_matching_size: parent_option_value_matching_size,
							-%}
						</select>
						<span class="svg-wrapper">
							{{- 'icon-caret.svg' | inline_asset_content -}}
						</span>
					</div>
				</div>
			{%- endif -%}
		{%- endfor -%}

		<script type="application/json" data-selected-variant>
			{{ product_selected_variant | json }}
		</script>
	</variant-selects-upsell>
{%- endunless -%}
