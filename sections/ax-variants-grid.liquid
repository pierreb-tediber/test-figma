<div id="VariantsGridContainer" data-id="{{ section.id }}">
	{%- liquid
		assign hide_section = false

		if collection.filters != empty
			for filter in collection.filters
				if filter.active_values.size > 0
					assign hide_section = true
				endif
			endfor
		endif

		if collection.sort_by != blank
			assign hide_section = true
		endif
	-%}

	{% unless hide_section %}
		{%- style -%}
			.section-{{ section.id }}-padding {
			  padding-top: {{ section.settings.mob_padding_top }}px;
			  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
			}

			.section-{{ section.id }}-padding #variants-grid {
			  margin: 0;
			}

			@media screen and (min-width: 750px) {
			  .section-{{ section.id }}-padding {
			    padding-top: {{ section.settings.padding_top }}px;
			    padding-bottom: {{ section.settings.padding_bottom }}px;
			  }
			}
		{%- endstyle -%}

		{%- liquid
			assign variants_list = collection.metafields.custom.variants_list.value
			assign variants_list_2 = collection.metafields.custom.variants_list_2.value

			if variants_list_2 != blank
				assign variants_list = variants_list | concat: variants_list_2
			endif

			assign pushs = collection.metafields.custom.push_variants.value
			assign total_push = 0

			if pushs != blank
				assign total_push = pushs.size
			endif

			assign adjusted_products_per_page = section.settings.product_per_page | minus: total_push
		-%}

		{% if variants_list != blank %}
			<div
				class="variants-grid gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
				data-ax-section="variantsGrid"
			>
				<div class="page-width">
					<variants-grid data-url="{{ collection.url }}?section_id={{ section.id }}" data-section-id="{{ section.id }}">
						<div
							class="variants-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
							{% if settings.animations_reveal_on_scroll %}
								data-cascade
							{% endif %}
						>
							{%- paginate variants_list by adjusted_products_per_page -%}
								<ul
									id="variants-grid"
									data-id="{{ section.id }}"
									class="grid variants-grid grid--2-col-tablet-down grid--4-col-desktop"
								>
									{%- liquid
										assign skip_card_product_styles = false
										assign display_index = 1
									-%}

									{%- for variant in variants_list -%}
										{%- liquid
											assign skip_card_product_styles = false
											assign display_index = 1

											if pushs != blank
												for push in pushs
													assign push_position = push.position.value
													if forloop.parentloop.index == push_position
														render 'product-list-push', push: push, index: display_index, lazy_load: true, list: true
														assign display_index = display_index | plus: 1
														continue
													endif
												endfor
											endif
										-%}

										<li
											class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
											{% if settings.animations_reveal_on_scroll %}
												data-cascade
												style="--animation-order: {{ display_index }};"
											{% endif %}
										>
											{% render 'card-product',
												card_product: variant.product,
												media_aspect_ratio: 'portrait',
												image_shape: 'default',
												show_secondary_image: false,
												show_vendor: false,
												show_rating: false,
												lazy_load: true,
												skip_styles: skip_card_product_styles,
												quick_add: false,
												section_id: section.id,
												is_variant: true,
												variant: variant,
												strong_lazy_load: true,
												no_hn: true
											%}
										</li>
										{%- liquid
											assign display_index = display_index | plus: 1
											assign skip_card_product_styles = true
										-%}
									{%- endfor -%}
								</ul>
								{%- if paginate.pages > 1 -%}
									{% render 'pagination', paginate: paginate, anchor: '#variants-grid', obfuscate: true %}
								{%- endif -%}
							{%- endpaginate -%}
						</div>
					</variants-grid>
				</div>
			</div>
		{% endif %}
	{% endunless %}
</div>

{% schema %}
	{
		"name": "Ax variants grid",
		"tag": "section",
		"class": "section ax-variants-grid",
		"enabled_on": {
			"templates": ["collection"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Produits"
			},
			{
				"type": "range",
				"id": "product_per_page",
				"label": "Variantes par page",
				"min": 1,
				"max": 28,
				"step": 1,
				"default": 12
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"presets": [
			{
				"name": "Ax variants grid"
			}
		]
	}
{% endschema %}
