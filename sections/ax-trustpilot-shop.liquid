{{ 'bundle.trustpilot-shop.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.mob_padding_top }}px;
	  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}

{%- liquid
	assign display_type = section.settings.display_type
-%}

<div
	class="trustpilot-shop section-{{ section.id }}-padding"
	data-ax-section="trustpilotShop"
>
	<div class="page-width{% if section.settings.restrict_width %} page-width--restricted-width{% endif %}">
		{%- if display_type == 'carousel' -%}
			<!-- TrustBox widget - Slider -->
			<div
				class="trustpilot-widget"
				data-locale="fr-FR"
				data-template-id="54ad5defc6454f065c28af8b"
				data-businessunit-id="5a5cdcedf3b8320001d06ddf"
				data-style-height="240px"
				data-style-width="100%"
				data-star-color="#218252"
				data-token="5aedf25f-6919-462a-a198-0180f937c5d6"
				data-stars="4,5"
				data-review-languages="fr"
			>
				<a href="https://fr.trustpilot.com/review/www.tediber.com" target="_blank" rel="noopener"></a>
			</div>
			<!-- End TrustBox widget -->
		{%- elsif display_type == 'grid' -%}
			<!-- TrustBox widget - Grid -->
			<div
				class="trustpilot-widget"
				data-locale="fr-FR"
				data-template-id="539adbd6dec7e10e686debee"
				data-businessunit-id="5a5cdcedf3b8320001d06ddf"
				data-style-height="1600px"
				data-style-width="100%"
				data-token="b7eb42b6-4cdb-4de0-ba1b-50576ff3d2c6"
				data-stars="4,5"
				data-review-languages="fr"
			>
				<a href="https://fr.trustpilot.com/review/www.tediber.com" target="_blank" rel="noopener"></a>
			</div>
			<!-- End TrustBox widget -->
		{%- else -%}
			<!-- TrustBox widget - List -->
			<div
				class="trustpilot-widget"
				data-locale="fr-FR"
				data-template-id="539ad60defb9600b94d7df2c"
				data-businessunit-id="5a5cdcedf3b8320001d06ddf"
				data-style-height="600px"
				data-style-width="100%"
				data-star-color="#218252"
				data-token="d5e7e6f9-04cd-4eb3-b1c9-626b378e53e7"
				data-stars="4,5"
				data-review-languages="fr"
			>
				<a href="https://fr.trustpilot.com/review/www.tediber.com" target="_blank" rel="noopener"></a>
			</div>
			<!-- End TrustBox widget -->
		{%- endif -%}
	</div>
</div>

{% schema %}
	{
		"name": "Ax trustpilot shop",
		"tag": "section",
		"class": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"limit": 1,
		"settings": [
			{
				"type": "checkbox",
				"id": "restrict_width",
				"label": "Restreindre la largeur",
				"default": false
			},
			{
				"type": "header",
				"content": "Affichage"
			},
			{
				"type": "select",
				"id": "display_type",
				"options": [
					{
						"value": "list",
						"label": "Liste"
					},
					{
						"value": "carousel",
						"label": "Carousel"
					},
					{
						"value": "grid",
						"label": "Grille"
					}
				],
				"default": "list",
				"label": "Type d'affichage",
				"info": "Liste (500px de hauteur), Carousel (240px de hauteur) ou Grille (500px de hauteur)"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [],
		"presets": [
			{
				"name": "Ax trustpilot shop"
			}
		]
	}
{% endschema %}
