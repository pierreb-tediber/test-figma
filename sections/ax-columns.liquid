{{ 'bundle.columns.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.mob_padding_top }}px;
	  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}

<div
	class="columns gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
	data-ax-section="columnsSection"
	aria-label="{{ 'accessibility.columns.section_title' | t }}"
>
	<div class="page-width">
		<ul class="columns__wrapper grid grid--1-col grid--{{ section.blocks.size }}-col-desktop list-unstyled">
			{% for block in section.blocks %}
				<li class="grid__item columns__item gradient color-{{ block.settings.color_scheme }}">
					{% if block.settings.link != blank %}
						<a href="{{ block.settings.link }}" class="columns__item-wrapper full-unstyled-link">
					{% else %}
						<div class="columns__item-wrapper">
					{% endif %}
					<div class="columns__item-header">
						{% if block.settings.title != blank %}
							<div class="columns__item-title">{{ block.settings.title }}</div>
						{% endif %}
						{% if block.settings.button_text != blank %}
							<div class="columns__item-button ax-link reversed">
								{{ block.settings.button_text }}
							</div>
						{% endif %}
					</div>

					{% if block.settings.text != blank %}
						<div class="columns__item-content{% if block.settings.truncate_text %} columns__item-content--truncate{% endif %}">
							{{ block.settings.text }}
						</div>
					{% endif %}

					{% if block.settings.link != blank %}
						</a>
					{% else %}
						</div>
					{% endif %}
				</li>
			{% endfor %}
		</ul>
	</div>
</div>

{% schema %}
	{
		"name": "Ax columns",
		"tag": "section",
		"class": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [
			{
				"type": "column",
				"name": "Colonne",
				"limit": 4,
				"settings": [
					{
						"type": "header",
						"content": "Contenu"
					},
					{
						"type": "text",
						"id": "title",
						"label": "Titre"
					},
					{
						"type": "richtext",
						"id": "text",
						"label": "Texte"
					},
					{
						"type": "checkbox",
						"id": "truncate_text",
						"label": "Tronquer le texte",
						"default": true
					},
					{
						"type": "text",
						"id": "button_text",
						"label": "Texte du bouton"
					},
					{
						"type": "url",
						"id": "link",
						"label": "Lien"
					},
					{
						"type": "header",
						"content": "Couleur"
					},
					{
						"type": "color_scheme",
						"id": "color_scheme",
						"label": "Couleur",
						"default": "background-1"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax columns",
				"blocks": []
			}
		]
	}
{% endschema %}
