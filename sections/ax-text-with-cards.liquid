{% if section.blocks.size > 0 %}
	{{ 'bundle.text-with-cards.css' | asset_url | stylesheet_tag }}

	{%- style -%}
		.section-{{ section.id }}-padding {
		  padding-top: {{ section.settings.mob_padding_top }}px;
		  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
		  margin-top: {{ section.settings.mob_margin_top }}px;
		  margin-bottom: {{ section.settings.mob_margin_bottom }}px;

			--background-section-color: {{ section.settings.color_scheme.settings.background }};
		}

		@media screen and (min-width: 750px) {
		  .section-{{ section.id }}-padding {
		    padding-top: {{ section.settings.padding_top }}px;
		    padding-bottom: {{ section.settings.padding_bottom }}px;
		    margin-top: {{ section.settings.margin_top }}px;
		    margin-bottom: {{ section.settings.margin_bottom }}px;
		  }
		}
	{%- endstyle -%}

	{%- liquid
		assign lazy_load = false

		if section.index > 1
			assign lazy_load = true
		endif
	-%}

	<div
		class="text-with-cards gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="textWithCards"
		role="region"
		aria-labelledby="TextWithCardsHeading-{{ section.id }}"
	>
		<div class="page-width">
			<div
				class="text-with-cards__wrapper grid grid--1-col grid--2-col-desktop{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
				{% if settings.animations_reveal_on_scroll %}
					data-cascade
				{% endif %}
			>
				<div
					class="text-with-cards__content grid__item"
					{% if settings.animations_reveal_on_scroll %}
						data-cascade
						style="--animation-order: 1;"
					{% endif %}
				>
					{% render 'section-heading',
						heading: section.settings.heading,
						subheading: section.settings.subheading,
						description: section.settings.description,
						heading_size: 'h2',
						text_alignment: 'left'
					%}
				</div>
				<div
					class="text-with-cards__cards grid grid--1-col grid--2-col-desktop grid__item"
					role="list"
				>
					{% for block in section.blocks %}
						<div
							class="text-with-cards__card grid__item gradient color-{{ block.settings.color_scheme }}"
							role="listitem"
							{% if settings.animations_reveal_on_scroll %}
								data-cascade
								style="--animation-order: {{ forloop.index | plus: 1 }};"
							{% endif %}
						>
							{% if block.settings.image != blank %}
								<div class="text-with-cards__card-image">
									<div class="media media--transparent">
										{% capture media_image %}
											{{ block.settings.image | image_url: width: 300 | image_tag: 
												alt: block.settings.image.alt 
											}}
										{% endcapture %}
										{% if lazy_load %}
											{{ media_image | replace: 'src="', 'lazy-src="' | replace: 'srcset="', 'lazy-srcset="' }}
										{% else %}
											{{ media_image }}
										{% endif %}
									</div>
								</div>
							{% endif %}

							{% if block.settings.title != blank or block.settings.description != blank %}
								<div class="text-with-cards__card-content">
									{% if block.settings.title != blank %}
										<div
											id="Card-{{ block.id }}-title"
											class="text-with-cards__card-title"
										>
											{{ block.settings.title }}
										</div>
									{% endif %}
									{% if block.settings.description != blank %}
										<div
											id="Card-{{ block.id }}-description"
											class="text-with-cards__card-description"
										>
											{{ block.settings.description }}
										</div>
									{% endif %}
								</div>
							{% endif %}
						</div>
					{% endfor %}
				</div>
			</div>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax text with cards",
		"tag": "section",
		"class": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "richtext",
				"id": "heading",
				"label": "Titre",
				"default": "<p>Titre</p>"
			},
			{
				"type": "text",
				"id": "subheading",
				"label": "Sur-titre",
				"default": "Sur-titre"
			},
			{
				"type": "richtext",
				"id": "description",
				"label": "Texte"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Marges intérieures"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			},
			{
				"type": "header",
				"content": "Marges extérieures"
			},
			{
				"type": "range",
				"id": "mob_margin_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Margin top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_margin_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Margin bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "margin_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Margin top",
				"default": 0
			},
			{
				"type": "range",
				"id": "margin_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Margin bottom",
				"default": 0
			}
		],
		"blocks": [
			{
				"type": "card",
				"name": "Card",
				"settings": [
					{
						"type": "header",
						"content": "Image"
					},
					{
						"type": "image_picker",
						"id": "image",
						"label": "Image"
					},
					{
						"type": "header",
						"content": "Contenu"
					},
					{
						"type": "text",
						"id": "title",
						"label": "Titre",
						"default": "Titre"
					},
					{
						"type": "richtext",
						"id": "description",
						"label": "Description"
					},
					{
						"type": "header",
						"content": "Couleur"
					},
					{
						"type": "color_scheme",
						"id": "color_scheme",
						"label": "Couleur",
						"default": "background-1"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax text with cards",
				"blocks": []
			}
		]
	}
{% endschema %}
