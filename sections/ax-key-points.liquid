{{ 'bundle.key-points.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.mob_padding_top }}px;
	  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}

{%- liquid
	assign key_points = blank
	assign key_points_blocks = false
	if section.settings.products_key_points != blank
		assign key_points = section.settings.products_key_points
	elsif section.blocks != blank
		assign key_points = section.blocks | where: 'type', 'key_point'
		assign key_points = key_points | map: 'settings'
		assign key_points_blocks = true
	endif

	assign image = section.settings.image | default: blank
-%}

{% if image != blank and key_points != blank %}
	<div
		class="key-points gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="keyPoints"
		role="region"
		aria-labelledby="KeyPointsHeading-{{ section.id }}"
	>
		<div class="page-width">
			<div class="key-points__wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
				<div class="key-points__image">
					<div
						class="media media--transparent"
						{% if image.alt == blank %}
							aria-hidden="true"
						{% endif %}
					>
						{% if image != blank %}
							{% capture media_image %}
								{{ image | image_url: width: 1000 | image_tag: alt: image.alt }}
							{% endcapture %}
							{{ media_image | replace: 'src="', 'lazy-src="' | replace: 'srcset="', 'lazy-srcset="' }}
						{% endif %}
					</div>
				</div>
				<div class="key-points__content">
					<div class="key-points__content-wrapper">
						{% if section.settings.heading %}
							<h2 id="KeyPointsHeading-{{ section.id }}" class="key-points__title h2">
								{{ section.settings.heading }}
							</h2>
						{% endif %}
						{% for key_point in key_points limit: 3 %}
							<div class="key-points__item">
								<h3 id="KeyPointItem-{{ section.id }}-{{ forloop.index }}" class="key-points__item-title">
									{{ key_point.title }}
								</h3>
								<div
									class="key-points__item-content"
									aria-labelledby="KeyPointItem-{{ section.id }}-{{ forloop.index }}"
								>
									{% if key_points_blocks %}
										{{ key_point.content }}
									{% else %}
										{{ key_point.content | metafield_tag }}
									{% endif %}
								</div>
							</div>
						{% endfor %}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax points clés",
		"tag": "section",
		"class": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "text",
				"id": "heading",
				"label": "Titre"
			},
			{
				"type": "image_picker",
				"id": "image",
				"label": "Image"
			},
			{
				"type": "metaobject_list",
				"id": "products_key_points",
				"label": "Points clés produit",
				"metaobject_type": "key_points",
				"limit": 3,
				"info": "Sélectionnez le metaobjet à afficher, prend le dessus sur les blocs"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [
			{
				"type": "key_point",
				"name": "Point clé",
				"limit": 3,
				"settings": [
					{
						"type": "text",
						"id": "title",
						"label": "Titre"
					},
					{
						"type": "richtext",
						"id": "content",
						"label": "Contenu"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax points clés",
				"blocks": []
			}
		]
	}
{% endschema %}
