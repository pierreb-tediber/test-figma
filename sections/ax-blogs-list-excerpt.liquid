{% if section.blocks != blank %}
	{{ 'bundle.blogs-list-excerpt.css' | asset_url | stylesheet_tag }}

	<script>
		window.assetsUrl.js.push({ blogsListExcerpt: "{{ 'bundle.blogs-list-excerpt.js' | asset_url }}" });
	</script>

	{%- style -%}
		.section-{{ section.id }}-padding {
		  padding-top: {{ section.settings.mob_padding_top }}px;
		  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
		}

		@media screen and (min-width: 750px) {
		  .section-{{ section.id }}-padding {
		    padding-top: {{ section.settings.padding_top }}px;
		    padding-bottom: {{ section.settings.padding_bottom }}px;
		  }
		}
	{%- endstyle -%}

	<div
		class="blogs-list-excerpt-excerpt gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="blogsListExcerpt"
	>
		<div class="page-width">
			<nav>
				<ul class="blogs-list-excerpt__wrapper grid grid--1-col grid--2-col-desktop list-unstyled">
					{%- for blog in section.blocks -%}
						<li class="blogs-list-excerpt__item grid__item">
							{% render 'blog-card-horizontal',
								blog: blog.settings.blog,
								color_scheme: section.settings.color_scheme_card
							%}
						</li>
					{%- endfor -%}
				</ul>
			</nav>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax blogs list excerpt",
		"tag": "section",
		"class": "section ax-blogs-list-excerpt",
		"enabled_on": {
			"templates": ["blog", "page", "article"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme_card",
				"label": "Color scheme card",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [
			{
				"type": "blog",
				"name": "Blog",
				"settings": [
					{
						"type": "blog",
						"id": "blog",
						"label": "Blog"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax blogs list excerpt",
				"blocks": []
			}
		]
	}
{% endschema %}
