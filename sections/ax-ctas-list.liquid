{% if section.blocks != blank %}
	{{ 'bundle.ctas-list.css' | asset_url | stylesheet_tag }}

	<script>
		window.assetsUrl.js.push({ ctasList: "{{ 'bundle.ctas-list.js' | asset_url }}" });
	</script>

	{%- style -%}
		.section-{{ section.id }}-padding {
		  padding-top: {{ section.settings.mob_padding_top }}px;
		  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
		}

		@media screen and (min-width: 750px) {
		  .section-{{ section.id }}-padding {
		    padding-top: {{ section.settings.padding_top }}px;
		    padding-bottom: {{ section.settings.padding_bottom }}px;
		  }
		}
	{%- endstyle -%}

	<div
		class="ctas-list gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="ctasList"
	>
		<div class="page-width">
			{%- render 'section-heading',
				heading: section.settings.heading,
				heading_size: 'h3',
				subheading: blank,
				description: blank,
				heading_picto: blank,
				heading_picto_size: blank,
				picto: blank,
				picto_size: blank,
				text_alignment: 'center'
			-%}

			<nav>
				<ul class="ctas-list__wrapper list-unstyled">
					{%- for cta in section.blocks -%}
						<li class="ctas-list__item">
							{%- if section.settings.obfuscate_links -%}
								<span
									data-obflink="{{ cta.settings.url | base64_encode }}"
									class="ctas-list__link full-unstyled-link button"
									aria-label="{{ cta.settings.title }}"
								>
									{{ cta.settings.title }}
								</span>
							{%- else -%}
								<a
									href="{{ cta.settings.url }}"
									class="ctas-list__link full-unstyled-link button"
									aria-label="{{ cta.settings.title }}"
								>
									{{ cta.settings.title }}
								</a>
							{%- endif -%}
						</li>
					{%- endfor -%}
				</ul>
			</nav>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax ctas list",
		"tag": "section",
		"class": "section ax-ctas-list",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "inline_richtext",
				"id": "heading",
				"label": "Heading"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			},
			{
				"type": "header",
				"content": "Liens"
			},
			{
				"type": "checkbox",
				"id": "obfuscate_links",
				"label": "Obfusquer les liens",
				"default": true
			}
		],
		"blocks": [
			{
				"type": "cta",
				"name": "CTA",
				"settings": [
					{
						"type": "text",
						"id": "title",
						"label": "Titre"
					},
					{
						"type": "url",
						"id": "url",
						"label": "Lien"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax ctas list",
				"blocks": []
			}
		]
	}
{% endschema %}
