{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
	  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}

{%- liquid
	assign page_title = page.title | escape
	if section.settings.custom_h1 != blank
		assign page_title = section.settings.custom_h1
	endif
-%}

{%- if section.settings.show_content -%}
	<div class="page-width section-{{ section.id }}-padding">
		<div class="page-width page-width-full page-width-desktop">
			<h1
				class="main-page-title page-title center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %} {{ section.settings.h1_size }}{% if section.settings.h1_no_margin %} no-margin{% endif %}"
			>
				{{ page_title }}
			</h1>
			<div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
				{{ page.content }}
			</div>
		</div>
	</div>
{%- else -%}
	<h1 class="visually-hidden">{{ page.title }}</h1>
{%- endif -%}

{% schema %}
	{
		"name": "t:sections.main-page.name",
		"tag": "section",
		"class": "section",
		"settings": [
			{
				"type": "paragraph",
				"content": "Ne pas cacher la section, pour avoir un h1 sur la page"
			},
			{
				"type": "checkbox",
				"id": "show_content",
				"label": "Show page content",
				"default": true
			},
			{
				"type": "richtext",
				"id": "custom_h1",
				"label": "H1 personnalisé"
			},
			{
				"type": "select",
				"id": "h1_size",
				"label": "Taille de l'H1",
				"options": [
					{
						"value": "h1",
						"label": "H1"
					},
					{
						"value": "h2",
						"label": "H2"
					},
					{
						"value": "h3",
						"label": "H3"
					}
				],
				"default": "h1"
			},
			{
				"type": "checkbox",
				"id": "h1_no_margin",
				"label": "H1 sans marge",
				"default": false
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "t:sections.all.padding.padding_top",
				"default": 36
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "t:sections.all.padding.padding_bottom",
				"default": 36
			}
		]
	}
{% endschema %}
