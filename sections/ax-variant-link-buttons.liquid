{{ 'bundle.variant-link-buttons.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.mob_padding_top }}px;
	  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}

{%- liquid
	assign variants_ctas = collection.metafields.custom.variants_cta | default: blank
-%}

{% if variants_ctas != blank %}
	<div
		class="variant-link-buttons gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="variantLinkButtons"
	>
		<div class="page-width">
			<h2 class="visually-hidden">{{ 'templates.collection.seo.title' | t: collection_name: collection.title }}</h2>

			{%- render 'section-heading',
				heading: section.settings.heading,
				heading_size: 'h2',
				heading_class: 'h4',
				subheading: blank,
				description: blank,
				heading_picto: blank,
				heading_picto_size: blank,
				picto: blank,
				picto_size: blank,
				text_alignment: 'center'
			-%}

			<nav>
				<ul class="variant-link-buttons__wrapper list-unstyled" role="list">
					{%- for variant in variants_ctas.value -%}
						<li class="variant-link-buttons__item">
							<h3 class="h4">
								<a
									href="{{ variant.lien }}"
									class="variant-link-buttons__link full-unstyled-link button"
									aria-label="{{ variant.valeur }}"
								>
									{{ variant.valeur }}
								</a>
							</h3>
						</li>
					{%- endfor -%}
				</ul>
			</nav>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax variant link buttons ",
		"tag": "section",
		"class": "section ax-variant-link-buttons",
		"enabled_on": {
			"templates": ["collection"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "inline_richtext",
				"id": "heading",
				"label": "Heading"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [],
		"presets": [
			{
				"name": "Ax variant link buttons ",
				"blocks": []
			}
		]
	}
{% endschema %}
