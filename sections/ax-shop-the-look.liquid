{{ 'bundle.shop-the-look.css' | asset_url | stylesheet_tag }}

<script>
	window.assetsUrl.js.push({ ShopTheLook: "{{ 'bundle.shop-the-look.js' | asset_url }}" });
</script>

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.mob_padding_top }}px;
	  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}

<shop-the-look
	class="shop-the-look color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
	data-ax-section="ShopTheLook"
	role="region"
	aria-label="{% if section.settings.heading != blank %}{{ section.settings.heading | strip_html }}{% else %}{{ 'sections.ax_shop_the_look.section_title' | t }}{% endif %}"
>
	<div class="shop-the-look__container" style="--gradient-opacity: {{ section.settings.gradient | divided_by: 100.0 }}">
		<div class="shop-the-look__content">
			{%- render 'section-heading',
				heading: section.settings.heading,
				subheading: section.settings.subheading,
				description: section.settings.description,
				text_alignment: 'left',
				heading_size: 'h2'
			-%}
			{%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
				{%- assign link_style = 'small-hide medium-hide ' | append: section.settings.link_style -%}
				{%- render 'link-style',
					link_label: section.settings.button_text,
					link_url: section.settings.button_link,
					link_style: link_style,
					link_target: section.settings.link_blank,
					link_attributes: section.shopify_attributes
				-%}
			{%- endif -%}
		</div>
		<div class="media media--transparent shop-the-look__image-global">
			{%- if section.settings.image != blank -%}
				{%- capture slides_html -%}
				{% assign skip_card_product_styles = false %}
				{%- for block in section.blocks -%}
					{% liquid
						assign current_product = block.settings.product
						if block.settings.combined_product != blank
							for combined_product in block.settings.combined_product limit: 1
								assign current_product = combined_product
							endfor
						endif
					%}
					{%- if current_product != blank and block.settings.display_on != 'desktop_only' -%}
						{% liquid
							assign lazy_load = false
							assign product = current_product
							if forloop.index > 2
								assign lazy_load = true
							endif
						%}
						<div
							class="swiper-slide shop-the-look__modal-slide grid__item"
							data-product-id="{{ product.id }}"
						>
							<ul class="shop-the-look__modal-product list-unstyled">
								<li class="shop-the-look__modal-info">
									{% render 'card-product',
										card_product: product,
										media_aspect_ratio: 'square',
										image_shape: 'default',
										show_secondary_image: true,
										show_vendor: false,
										show_rating: false,
										lazy_load: lazy_load,
										skip_styles: skip_card_product_styles,
										quick_add: true,
										section_id: section.id,
										view_product: false,
										no_hn: true
									%}
								</li>
								{%- assign skip_card_product_styles = true -%}
							</ul>
						</div>
					{%- endif -%}
				{%- endfor -%}
			{%- endcapture -%}
				{% liquid
					assign img_alt = section.settings.image.alt | default: section.settings.heading | escape
					assign loading = 'lazy'
					assign fetchpriority = 'low'
					assign lazyload = true
					if section.index == 1
						assign loading = 'eager'
						assign fetchpriority = 'high'
						assign lazyload = false
					endif
				%}
				<picture
					class="shop-the-look__image-container"
				>
					{%- capture media_image -%}
						{%- if section.settings.image_mobile != blank -%}
							<source
								media="(max-width: 750px)"
								srcset="{{ section.settings.image_mobile | image_url: width: 750 }} 1x, {{ section.settings.image_mobile | image_url: width: 1500 }} 2x"
							>
							<source
								media="(max-width: 990px)"
								srcset="{{ section.settings.image_mobile | image_url: width: 990 }} 1x, {{ section.settings.image_mobile | image_url: width: 1980 }} 2x"
							>
						{%- endif -%}
						{{
							section.settings.image
							| image_url: width: 2000
							| image_tag:
								loading: loading,
								sizes: '100vw',
								widths: '375, 550, 750, 1100, 1500, 2000, 3200',
								class: 'shop-the-look__image',
								fetchpriority: fetchpriority,
								alt: img_alt
							}}
					{%- endcapture -%}
					{%- if lazyload -%}
						{{ media_image | replace: 'srcset=', 'lazy-srcset=' | replace: 'src=', 'lazy-src=' }}
					{%- else -%}
						{{ media_image }}
					{%- endif -%}
				</picture>
			{%- else -%}
				{{- 'image' | placeholder_svg_tag: 'placeholder' -}}
			{%- endif -%}
		</div>
		{%- for block in section.blocks -%}
			{% liquid
				assign current_product = block.settings.product
				if block.settings.combined_product != blank
					for combined_product in block.settings.combined_product limit: 1
						assign current_product = combined_product
					endfor
				endif
			%}

			<div
				class="shop-the-look__hotspot{%- if block.settings.display_on == 'desktop_only' %} small-hide{%- elsif block.settings.display_on == 'mobile_only' %} not-small-hide{%- endif -%}"
				style="
					--desktop-left: {{ block.settings.position_left }}%;
					--desktop-top: {{ block.settings.position_top }}%;
					--mobile-left: {{ block.settings.mobile_position_left }}%;
					--mobile-top: {{ block.settings.mobile_position_top }}%;
				"
				{{ block.settings.shopify_attributes }}
				data-product-id="{{ current_product.id }}"
				role="button"
				aria-label="{{ current_product.title | escape }} - {{ 'products.product.view_product' | t }}"
				tabindex="0"
			>
				{% if current_product != blank %}
					<button
						class="shop-the-look__hotspot-button"
						type="button"
						aria-label="{{ current_product.title | escape }}"
					>
						<span class="visually-hidden">{{ current_product.title }}</span>
					</button>
					<div
						class="shop-the-look__product-card"
						role="region"
						aria-label="{{ current_product.title | escape }}"
					>
						{% render 'card-product',
							card_product: current_product,
							media_aspect_ratio: 'portrait',
							image_shape: 'default',
							show_secondary_image: true,
							show_vendor: false,
							show_rating: false,
							lazy_load: lazy_load,
							skip_styles: skip_card_product_styles,
							quick_add: 'none',
							section_id: section.id,
							horizontal_class: true,
							horizontal_quick_add: true,
							view_product: true,
							no_hn: true
						%}
					</div>
				{% endif %}
			</div>
		{%- endfor -%}

		{%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
			{%- render 'link-style',
				link_label: section.settings.button_text,
				link_url: section.settings.button_link,
				link_style: 'button button-primary large-hide',
				link_target: section.settings.link_blank,
				link_attributes: section.shopify_attributes
			-%}
		{%- endif -%}
	</div>

	{%- if section.blocks.size > 0 -%}
		<div
			class="shop-the-look__modal"
			role="dialog"
			aria-modal="true"
			aria-labelledby="modal-title-{{ section.id }}"
		>
			<div class="shop-the-look__modal-overlay" aria-hidden="true"></div>
			<div
				class="shop-the-look__modal-content"
				data-slides-html="{{ slides_html | base64_encode }}"
			>
				{% if section.settings.modal_title != blank %}
					<div id="modal-title-{{ section.id }}" class="shop-the-look__modal-title h3">
						{{ section.settings.modal_title }}
					</div>
				{% endif %}

				<button
					type="button"
					class="shop-the-look__modal-close"
					aria-label="{{ 'accessibility.close' | t }}"
				>
					<span class="visually-hidden">{{ 'accessibility.close' | t }}</span>
					{{- 'icon-close.svg' | inline_asset_content -}}
				</button>

				{% capture swiper_options %}
					{
						"loop": false,
						"effect": "slide",
						"grabCursor": false,
						"speed": 240,
						"slideInView": "auto",
						"slidesToMove": 1
					}
				{% endcapture %}
				<div
					id="Swiper-{{ section.id }}"
					class="shop-the-look__modal-slider swiper"
					data-options="{{ swiper_options | escape }}"
					role="region"
					aria-label="{{ 'products.product.related_products' | t }}"
				>
					<div class="swiper-wrapper grid grid--1-7-col grid--3-col-tablet" data-slides role="list">
						{% comment %}
							Les slides seront générées en JS
						{% endcomment %}
					</div>
				</div>
			</div>
		</div>
	{%- endif -%}
</shop-the-look>

{% schema %}
	{
		"name": "Ax shop the look",
		"tag": "section",
		"class": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "image_picker",
				"id": "image",
				"label": "Image principale"
			},
			{
				"type": "image_picker",
				"id": "image_mobile",
				"label": "Image mobile"
			},
			{
				"type": "range",
				"id": "gradient",
				"min": 0,
				"max": 100,
				"step": 1,
				"label": "Transparence de l'overlay",
				"default": 25
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "inline_richtext",
				"id": "subheading",
				"label": "Sur-titre"
			},
			{
				"type": "richtext",
				"id": "heading",
				"label": "Titre"
			},
			{
				"type": "richtext",
				"id": "description",
				"label": "Description"
			},
			{
				"type": "text",
				"id": "button_text",
				"label": "Texte du bouton"
			},
			{
				"type": "url",
				"id": "button_link",
				"label": "Lien du bouton"
			},
			{
				"type": "checkbox",
				"id": "link_blank",
				"label": "Lien _blank",
				"info": "Ouvrir ce lien dans une nouvelle fenêtre",
				"default": false
			},
			{
				"type": "select",
				"id": "link_style",
				"options": [
					{
						"value": "button button--primary",
						"label": "Primary"
					},
					{
						"value": "button button--secondary",
						"label": "Secondary"
					},
					{
						"value": "ax-link",
						"label": "Link"
					},
					{
						"value": "ax-link reversed",
						"label": "Link inversé"
					},
					{
						"value": "underlined-link",
						"label": "Underline link"
					}
				],
				"default": "button button--primary",
				"label": "Style du bouton"
			},
			{
				"type": "header",
				"content": "Mobile"
			},
			{
				"type": "text",
				"id": "modal_title",
				"label": "Titre de la modale"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 36
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 36
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 52
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 52
			}
		],
		"blocks": [
			{
				"type": "product",
				"name": "Produit",
				"settings": [
					{
						"type": "product",
						"id": "product",
						"label": "Produit"
					},
					{
						"type": "product_list",
						"id": "combined_product",
						"label": "Produit combiné"
					},
					{
						"type": "range",
						"id": "position_left",
						"min": 10,
						"max": 90,
						"step": 1,
						"unit": "%",
						"label": "Position horizontale",
						"default": 50
					},
					{
						"type": "range",
						"id": "position_top",
						"min": 0,
						"max": 100,
						"step": 1,
						"unit": "%",
						"label": "Position verticale",
						"default": 50
					},
					{
						"type": "range",
						"id": "mobile_position_left",
						"min": 10,
						"max": 90,
						"step": 1,
						"unit": "%",
						"label": "Position mobile horizontale",
						"default": 50
					},
					{
						"type": "range",
						"id": "mobile_position_top",
						"min": 0,
						"max": 100,
						"step": 1,
						"unit": "%",
						"label": "Position mobile verticale",
						"default": 50
					},
					{
						"type": "select",
						"id": "display_on",
						"label": "Afficher sur",
						"options": [
							{
								"value": "both",
								"label": "Mobile et Desktop"
							},
							{
								"value": "desktop_only",
								"label": "Desktop uniquement"
							},
							{
								"value": "mobile_only",
								"label": "Mobile uniquement"
							}
						],
						"default": "both"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax shop the look",
				"blocks": [
					{
						"type": "product",
						"settings": {
							"product": "product-1"
						}
					}
				]
			}
		]
	}
{% endschema %}
