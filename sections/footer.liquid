{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'bundle.footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

<script>
	window.assetsUrl.js.push({ 'footer': "{{ "bundle.footer.js" | asset_url }}" });
</script>

{%- style -%}
	.footer {
	margin-top: {{ section.settings.margin_top | times: 0.5 | round: 0 }}px;
	}

	.section-{{ section.id }}-padding {
	padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
	padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
	}

	@media screen and (min-width: 750px) {
	  .footer {
	    margin-top: {{ section.settings.margin_top }}px;
	  }

	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}

<footer
	class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
	data-ax-section="footer"
>
	{%- liquid
		assign has_social_icons = true
		if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
			assign has_social_icons = false
		endif

		if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
			assign brand_empty = true
		endif

		if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
			assign only_empty_brand = true
		endif
	-%}
	{%- if section.blocks.size > 0
		or section.settings.newsletter_enable
		or section.settings.show_social
		and has_social_icons == true
		or section.settings.enable_follow_on_shop
	-%}
		{%- unless only_empty_brand -%}
			<div class="footer__content-top page-width">
				{%- if section.blocks.size > 0 -%}
					{%- liquid
						assign footer_grid_class = 'grid--4-col-desktop'
						if section.blocks.size == 9
							assign footer_grid_class = 'grid--3-col-desktop'
						elsif section.blocks.size > 5
							assign footer_grid_class = 'grid--3-col-desktop'
						endif
					-%}
					<div
						class="footer__blocks-wrapper grid grid--1-col grid--2-col-tablet {{ footer_grid_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
						{% if settings.animations_reveal_on_scroll %}
							data-cascade
						{% endif %}
					>
						{%- for block in section.blocks -%}
							{% if block.type == 'b2b' %}
								{% continue %}
							{% endif %}

							<div
								class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
								{{ block.shopify_attributes }}
								{% if settings.animations_reveal_on_scroll %}
									data-cascade
									style="--animation-order: {{ forloop.index }};"
								{% endif %}
							>
								{%- if block.settings.heading != blank and block.type != 'link_list' -%}
									<div class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</div>
								{%- endif -%}

								{%- case block.type -%}
									{%- when '@app' -%}
										{% render block %}
									{%- when 'text' -%}
										<div class="footer-block__details-content rte">
											{{ block.settings.subtext }}
										</div>
									{%- when 'link_list' -%}
										{%- if block.settings.menu != blank and block.settings.heading != blank -%}
											<details class="link-list first-list details-animate" open>
												<summary class="footer-block__heading">
													<div class="inline-richtext">{{- block.settings.heading | escape -}}</div>
													<span class="medium-hide medium-up-hide extra-large-hide">
														<span class="svg-wrapper">
															{{- 'icon-caret.svg' | inline_asset_content -}}
														</span>
													</span>
												</summary>
												<ul class="footer-block__details-content list-unstyled details__content">
													{%- for link in block.settings.menu.links -%}
														<li>
															<a
																href="{{ link.url }}"
																class="link link--text list-menu__item list-menu__item--link"
															>
																<span class="link-list__item-text">{{ link.title | escape }}</span>
															</a>
														</li>
													{%- endfor -%}
												</ul>
											</details>
										{%- endif -%}
									{%- when 'brand_information' -%}
										<div class="footer-block__brand-info">
											{%- if settings.brand_image != blank -%}
												{%- liquid
													assign brand_image_height = settings.brand_image_width | divided_by: settings.brand_image.aspect_ratio
													assign img_alt = settings.brand_image.alt | default: shop.name
												-%}
												<div
													class="footer-block__image-wrapper"
													style="max-width: min(100%, {{ settings.brand_image_width }}px);"
												>
													{{
														settings.brand_image
														| image_url: width: 1100
														| image_tag:
															loading: 'lazy',
															alt: img_alt,
															widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
															height: brand_image_height,
															width: settings.brand_image_width
													}}
												</div>
											{%- endif -%}
											{%- if settings.brand_headline != blank -%}
												<div class="footer-block__heading rte">{{ settings.brand_headline }}</div>
											{%- endif -%}
											{%- if settings.brand_description != blank -%}
												<div class="rte">{{ settings.brand_description }}</div>
											{%- endif -%}
											{%- if block.settings.show_social and has_social_icons -%}
												{%- render 'social-icons', class: 'footer__list-social' -%}
											{%- endif -%}
										</div>
									{%- when 'image' -%}
										<div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
											{%- if block.settings.image != blank -%}
												{%- liquid
													assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760
													assign img_alt = settings.image.alt | default: shop.name
												-%}
												<div
													class="footer-block__image-wrapper"
													style="max-width: min(100%, {{ block.settings.image_width }}px);"
												>
													<img
														srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
														src="{{ block.settings.image | image_url: width: 760 }}"
														alt="{{ img_alt }}"
														loading="lazy"
														width="{{ block.settings.image.width }}"
														height="{{ block.settings.image.height }}"
													>
												</div>
											{%- else -%}
												{{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
											{%- endif -%}
										</div>
									{%- when 'newsletter' -%}
										<div class="footer-block__details-content footer-block--newsletter">
											<div class="footer-block__newsletter">
												{%- if block.settings.newsletter_heading != blank -%}
													<div
														class="footer-block__heading inline-richtext"
													>
														{{ block.settings.newsletter_heading }}
													</div>
												{%- endif -%}
												{%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
													<input type="hidden" name="contact[tags]" value="newsletter">
													<div class="newsletter-form__field-wrapper">
														<div class="field">
															<input
																id="NewsletterForm--{{ section.id }}"
																type="email"
																name="contact[email]"
																class="field__input"
																value="{{ form.email }}"
																aria-required="true"
																autocorrect="off"
																autocapitalize="off"
																autocomplete="email"
																{% if form.errors %}
																	autofocus
																	aria-invalid="true"
																	aria-describedby="ContactFooter-error"
																{% elsif form.posted_successfully? %}
																	aria-describedby="ContactFooter-success"
																{% endif %}
																placeholder="{{ 'newsletter.label' | t }}"
																required
															>
															<label
																class="field__label"
																for="NewsletterForm--{{ section.id }}"
															>
																{{ 'newsletter.label' | t }}
															</label>
															<button
																type="submit"
																class="newsletter-form__button field__button"
																name="commit"
																id="Subscribe"
																aria-label="{{ 'newsletter.button_label' | t }}"
															>
																<span class="svg-wrapper">
																	{{- 'icon-arrow.svg' | inline_asset_content -}}
																</span>
															</button>
														</div>
														{%- if form.errors -%}
															<small
																class="newsletter-form__message form__message"
																id="ContactFooter-error"
															>
																<span class="svg-wrapper">
																	{{- 'icon-error.svg' | inline_asset_content -}}
																</span>
																{{- form.errors.translated_fields.email | capitalize }}
																{{ form.errors.messages.email -}}
															</small>
														{%- endif -%}
													</div>
													{%- if form.posted_successfully? -%}
														<div
															class="newsletter-form__message newsletter-form__message--success form__message h4"
															id="ContactFooter-success"
															tabindex="-1"
															autofocus
														>
															<span class="svg-wrapper">
																{{- 'icon-success.svg' | inline_asset_content -}}
															</span>
															{{- 'newsletter.success' | t }}
														</div>
													{%- endif -%}
												{%- endform -%}
											</div>
										</div>
								{%- endcase -%}
							</div>
						{%- endfor -%}
					</div>
				{%- endif -%}

				{%- liquid
					assign footer_grid_class = 'grid--4-col-desktop'

					# Logic pour le footer dynamique
					assign current_url_formatted = request.path | replace: '/', '_'
					assign dynamic_footer_found = false
					assign dynamic_footer_entry = null

					# Récupération du metaobject seo_footer_dynamique
					assign seo_footer_metaobjects = metaobjects.seo_footer_dynamique

					if seo_footer_metaobjects[current_url_formatted]
						assign dynamic_footer_found = true
						assign dynamic_footer_entry = seo_footer_metaobjects[current_url_formatted]
					endif
				-%}

				{%- if dynamic_footer_found and dynamic_footer_entry and dynamic_footer_entry.contenu.value -%}
					<div class="footer__content-middle">
						<details class="details-animate">
							<summary class="footer__content-middle-heading">
								<span class="svg-wrapper">
									{{- 'icon-arrow.svg' | inline_asset_content }}
								</span>
							</summary>

							<div
								class="footer__blocks-wrapper grid grid--1-col grid--2-col-tablet {{ footer_grid_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
								{% if settings.animations_reveal_on_scroll %}
									data-cascade
								{% endif %}
							>
								{%- liquid
									# Récupération et validation du contenu JSON
									assign json_content = dynamic_footer_entry.contenu.value
									assign box_content = json_content['box-1']

									# Vérification que les données existent avant calcul
									if box_content and box_content.size > 0
										# Calcul optimisé
										assign number_of_links = box_content.size | divided_by: 2
										assign links_per_column = section.settings.dynamic_footer_links_per_column | default: 8
										assign number_of_columns = number_of_links | divided_by: links_per_column | ceil | plus: 1
									endif
								-%}

								{%- if box_content and number_of_links > 0 -%}
									{%- for column in (1..number_of_columns) -%}
										{%- liquid
											assign start_index = column | minus: 1 | times: links_per_column | plus: 1
											assign end_index = column | times: links_per_column
											if end_index > number_of_links
												assign end_index = number_of_links
											endif
										-%}

										<div class="footer-block grid__item">
											<div class="footer-block__details-content">
												<ul class="footer-block__details-content list-unstyled details__content">
													{%- for i in (start_index..end_index) -%}
														{%- liquid
															assign text_key = 'text-' | append: i
															assign link_key = 'link-' | append: i
															assign link_text = box_content[text_key]
															assign link_url = box_content[link_key]
														-%}
														{%- if link_text and link_url -%}
															<li>
																<a href="{{ link_url }}" class="link link--text list-menu__item list-menu__item--link">
																	<span class="link-list__item-text">{{ link_text }}</span>
																</a>
															</li>
														{%- endif -%}
													{%- endfor -%}
												</ul>
											</div>
										</div>
									{%- endfor -%}
								{%- endif -%}
							</div>
						</details>
					</div>
				{%- endif -%}

				{%- if section.settings.newsletter_enable
					or shop.features.follow_on_shop?
					and section.settings.enable_follow_on_shop
				-%}
					<div
						class="footer-block--newsletter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
						{% if settings.animations_reveal_on_scroll %}
							data-cascade
						{% endif %}
					>
						{%- if section.settings.newsletter_enable -%}
							<div class="footer-block__newsletter">
								{%- if section.settings.newsletter_heading != blank -%}
									<div class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</div>
								{%- endif -%}
								{%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
									<input type="hidden" name="contact[tags]" value="newsletter">
									<div class="newsletter-form__field-wrapper">
										<div class="field">
											<input
												id="NewsletterForm--{{ section.id }}"
												type="email"
												name="contact[email]"
												class="field__input"
												value="{{ form.email }}"
												aria-required="true"
												autocorrect="off"
												autocapitalize="off"
												autocomplete="email"
												{% if form.errors %}
													autofocus
													aria-invalid="true"
													aria-describedby="ContactFooter-error"
												{% elsif form.posted_successfully? %}
													aria-describedby="ContactFooter-success"
												{% endif %}
												placeholder="{{ 'newsletter.label' | t }}"
												required
											>
											<label class="field__label" for="NewsletterForm--{{ section.id }}">
												{{ 'newsletter.label' | t }}
											</label>
											<button
												type="submit"
												class="newsletter-form__button field__button"
												name="commit"
												id="Subscribe"
												aria-label="{{ 'newsletter.button_label' | t }}"
											>
												<span class="svg-wrapper">
													{{- 'icon-arrow.svg' | inline_asset_content -}}
												</span>
											</button>
										</div>
										{%- if form.errors -%}
											<small class="newsletter-form__message form__message" id="ContactFooter-error">
												<span class="svg-wrapper">
													{{- 'icon-error.svg' | inline_asset_content -}}
												</span>
												{{- form.errors.translated_fields.email | capitalize }}
												{{ form.errors.messages.email -}}
											</small>
										{%- endif -%}
									</div>
									{%- if form.posted_successfully? -%}
										<div
											class="newsletter-form__message newsletter-form__message--success form__message h4"
											id="ContactFooter-success"
											tabindex="-1"
											autofocus
										>
											<span class="svg-wrapper">
												{{- 'icon-success.svg' | inline_asset_content -}}
											</span>
											{{- 'newsletter.success' | t }}
										</div>
									{%- endif -%}
								{%- endform -%}
							</div>
						{%- endif -%}

						{%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
							<div class="footer__follow-on-shop">
								{{ shop | login_button: action: 'follow' }}
							</div>
						{%- endif -%}
					</div>
				{%- endif -%}
			</div>
		{%- endunless -%}
	{%- endif -%}

	<div
		class="footer__content-bottom{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
		{% if settings.animations_reveal_on_scroll %}
			data-cascade
		{% endif %}
	>

		{%- for block in section.blocks -%}
			{% if block.type == 'b2b' %}
				<div class="footer__content-bottom-wrapper page-width">
					<div class="footer__b2b" style="{% if block.settings.background_color %}background-color: {{ block.settings.background_color }}{% endif %}">
						{% if block.settings.image %}
							{{ block.settings.image | image_url: height: 48, width: 144 | image_tag: height: 48, width: 144, loading: 'lazy', fetchpriority: 'low', alt: "b2b icon", class: 'footer__b2b-icon' | replace: 'src="', 'lazy-src="' | replace: 'srcset="', 'lazy-srcset="' }}
						{% endif %}
						<p class="h4 footer__b2b-heading inline-richtext">{{ block.settings.heading }}</p>
						<a href="{{ block.settings.button_url }}" {% if block.settings.target_blank %}target="_blank"{% endif %} class="button footer__b2b-button">
							{{ block.settings.button_text | uppercase }}
							&nbsp;
							<span class="svg-wrapper">
								{{- 'icon-arrow.svg' | inline_asset_content -}}
							</span>
						</a>
					</div>
				</div>
			{% endif %}
		{%- endfor -%}
		
		<div class="footer__content-bottom-wrapper page-width">
			{%- if section.settings.enable_country_selector
				and localization.available_countries.size > 1
				or section.settings.enable_language_selector
				and localization.available_languages.size > 1
			-%}
				<div class="footer__column footer__localization isolate">
					{%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
						<localization-form>
							{%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
								<div>
									<div
										class="caption-large text-body"
										id="FooterCountryLabel"
									>
										{{ 'localization.country_label' | t }}
									</div>
									{%- render 'country-localization', localPosition: 'FooterCountry' -%}
								</div>
							{%- endform -%}
						</localization-form>
					{%- endif -%}

					{%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
						<localization-form>
							{%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
								<div>
									<div class="caption-large text-body" id="FooterLanguageLabel">
										{{ 'localization.language_label' | t }}
									</div>
									{%- render 'language-localization', localPosition: 'FooterLanguage' -%}
								</div>
							{%- endform -%}
						</localization-form>
					{%- endif -%}
				</div>
			{%- endif -%}

			{%- if section.settings.show_social and has_social_icons -%}
				<div class="footer__column footer__column--social">
					{%- render 'social-icons', class: 'footer__list-social' -%}
					{%- if section.settings.ambassador_url != blank -%}
						<a href="{{ section.settings.ambassador_url }}" class="footer__ambassador" target="_blank" rel="noopener noreferrer">
							{{ 'sections.footer.ambassador' | t }}
						</a>
					{%- endif -%}
				</div>
			{%- endif -%}

			{%- if section.settings.payment_enable -%}
				<div class="footer__column footer__column--info">
					<div class="footer__payment">
						<span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
						<ul class="list list-payment" role="list">
							{%- for type in shop.enabled_payment_types -%}
								<li class="list-payment__item">
									{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
								</li>
							{%- endfor -%}
							<li class="list-payment__item">
								<span class="badge-payment">{{ 'sections.cart.badge_1' | t }}</span>
							</li>
							<li class="list-payment__item">
								<span class="badge-payment">{{ 'sections.cart.badge_2' | t }}</span>
							</li>
						</ul>
					</div>
				</div>
			{%- endif -%}
		</div>
		<div class="footer__content-bottom-wrapper page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
			<div class="footer__copyright caption">
				{%- if section.settings.show_policy -%}
					<ul class="policies list-unstyled">
						{% if section.settings.policies_menu != blank %}
							{%- for link in section.settings.policies_menu.links -%}
								<li>
									<small class="copyright__content">
										<a href="{{ link.url }}">{{ link.title | escape }}</a>
									</small>
								</li>
							{%- endfor -%}
						{%- else -%}
							{%- for policy in shop.policies -%}
								{%- if policy != blank -%}
									<li>
										<small class="copyright__content">
											<a href="{{ policy.url }}">{{ policy.title | escape }}</a>
										</small>
									</li>
								{%- endif -%}
							{%- endfor -%}
						{%- endif -%}
						{% if section.settings.accessibility_url != blank %}
							<li>
								<small class="copyright__content">
									<a href="{{ section.settings.accessibility_url }}">{{ section.settings.accessibility_text | default: 'Accessibility' }}</a>
								</small>
							</li>
						{% endif %}
					</ul>
				{%- endif -%}
				
			</div>
		</div>
	</div>
</footer>

{% schema %}
	{
		"name": "Ax Footer",
		"class": "section-footer",
		"blocks": [
			{
				"type": "@app"
			},
			{
				"type": "link_list",
				"name": "t:sections.footer.blocks.link_list.name",
				"settings": [
					{
						"type": "inline_richtext",
						"id": "heading",
						"default": "t:sections.footer.blocks.link_list.settings.heading.default",
