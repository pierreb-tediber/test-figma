{% if section.blocks != blank %}
	{{ 'bundle.blogs-list.css' | asset_url | stylesheet_tag }}

	<script>
		window.assetsUrl.js.push({ blogsList: "{{ 'bundle.blogs-list.js' | asset_url }}" });
	</script>

	{%- style -%}
		.section-{{ section.id }}-padding {
		  padding-top: {{ section.settings.mob_padding_top }}px;
		  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
		}

		@media screen and (min-width: 750px) {
		  .section-{{ section.id }}-padding {
		    padding-top: {{ section.settings.padding_top }}px;
		    padding-bottom: {{ section.settings.padding_bottom }}px;
		  }
		}
	{%- endstyle -%}

	<div
		class="blogs-list gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="blogsList"
	>
		<div class="page-width">
			{%- render 'section-heading',
				heading: section.settings.heading,
				heading_size: 'h3',
				subheading: blank,
				description: blank,
				heading_picto: blank,
				heading_picto_size: blank,
				picto: blank,
				picto_size: blank,
				text_alignment: 'center'
			-%}

			<nav>
				<ul class="blogs-list__wrapper list-unstyled">
					{%- for blog in section.blocks -%}
						<li class="blogs-list__item">
							<span
								data-obflink="{{ blog.settings.blog.url | base64_encode }}"
								class="blogs-list__link full-unstyled-link button"
								aria-label="{{ blog.settings.blog.title }}"
							>
								{{ blog.settings.blog.title }}
							</span>
						</li>
					{%- endfor -%}
				</ul>
			</nav>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax blogs list",
		"tag": "section",
		"class": "section ax-blogs-list",
		"enabled_on": {
			"templates": ["page", "blog", "article"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "inline_richtext",
				"id": "heading",
				"label": "Heading"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [
			{
				"type": "blog",
				"name": "Blog",
				"settings": [
					{
						"type": "blog",
						"id": "blog",
						"label": "Blog"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax blogs list",
				"blocks": []
			}
		]
	}
{% endschema %}
