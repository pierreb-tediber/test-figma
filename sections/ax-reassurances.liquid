{{ 'bundle.reassurances.css' | asset_url | stylesheet_tag }}

<script>
	window.assetsUrl.js.push({"reassurances": "{{ "bundle.reassurances.js" | asset_url }}"});
</script>

{%- liquid
	assign lazy_load = false
	if section.index > 1
		assign lazy_load = true
	endif
-%}

{% capture swiper-options %}
    {
    "slideInView": "auto",
    "slidesToMove": 2,
    "loop": {% if section.settings.loop %}true{% else %}false{% endif %},
    "autoplay": {% if section.settings.autoplay %}true{% else %}false{% endif %},
    "speed": {{ section.settings.speed }},
    "grabCursor": false,
    "effect": "slide",
    "blockLength": {{ section.blocks.size }},
    "stackMobile": {{ section.settings.stack_mobile }},
    "freeModeMobile": false
    }
{% endcapture %}

{%- style -%}
	.section-{{ section.id }}-padding {
	padding-top: {{ section.settings.padding_top }}px;
	padding-bottom: {{ section.settings.padding_bottom }}px;
	margin-top: {{ section.settings.margin_top }}px;
	margin-bottom: {{ section.settings.margin_bottom }}px;
	}

	@media (max-width: 750px) {
		.section-{{ section.id }}-padding {
	padding-top: {{ section.settings.mob_padding_top }}px;
	padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	margin-top: {{ section.settings.mob_margin_top }}px;
	margin-bottom: {{ section.settings.mob_margin_bottom }}px;
	}
	}
{%- endstyle -%}

{%- liquid
	assign has_metafields = false
	assign template_object = null

	# Associer dynamiquement l'objet correct en fonction du template
	case template.name
		when 'product'
			assign template_object = product
		when 'collection'
			assign template_object = collection
		when 'page'
			assign template_object = page
		when 'blog'
			assign template_object = blog
		when 'article'
			assign template_object = article
			# Ajouter d'autres types de template au besoin
	endcase

	# Vérifier si l'objet du template a le metafield nécessaire
	if template_object != null and template_object.metafields.custom.reassurance != blank
		assign count = 0
		for item in template_object.metafields.custom.reassurance.value
			assign count = count | plus: 1
		endfor
		assign has_metafields = true
	endif
-%}

<div
	class="reassurances gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding{% if section.settings.border_top_mobile %} border-top-mobile{% endif %}{% if section.settings.border_bottom_mobile %} border-bottom-mobile{% endif %}"
	data-ax-section="reassurances"
	role="region"
	aria-label="{% if section.settings.heading != blank %}{{ section.settings.heading }}{% else %}{{ 'sections.ax_reassurances.heading' | t }}{% endif %}"
>
	<div class="page-width{% if section.settings.restricted_width %} page-width--restricted-width{% endif %}">
		<reassurances-component>
			{%- if section.settings.heading != blank -%}
				<h2 class="visually-hidden">{{ section.settings.heading }}</h2>
			{%- endif -%}
			<div
				id="Swiper-{{ section.id }}"
				class="swiper reassurances__content{% if section.settings.stack_mobile %} stack-mobile{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
				{% if settings.animations_reveal_on_scroll %}
					data-cascade
				{% endif %}
				data-options="{{ swiper-options | escape }}"
				role="region"
				aria-roledescription="carousel"
				aria-label="{{ 'general.slider.name' | t }}"
			>
				{%- liquid
					if section.blocks.size == 2
						assign grid_class = 'grid--2-col-tablet'
					elsif section.blocks.size == 3
						assign grid_class = 'grid--3-col-tablet grid--3-col-desktop'
					elsif section.blocks.size == 4
						assign grid_class = 'grid--2-col-tablet grid--4-col-desktop'
					elsif section.blocks.size == 5
						assign grid_class = 'grid--3-col-tablet grid--5-col-desktop'
					elsif section.blocks.size == 6
						assign grid_class = 'grid--3-col-tablet grid--6-col-desktop'
					endif
				-%}
				<div
					class="swiper-wrapper grid{% if section.settings.stack_mobile %} grid--1-col{% else %} grid--2-col{% endif %} {{ grid_class }}{% if section.settings.buttons %} has-btn-swiper{% endif %}"
					role="list"
				>
					{%- for block in section.blocks -%}
						{%- liquid
							assign source = block.settings.metaobject
							if has_metafields and forloop.index <= count and template_object != null
								assign metaobject_index = forloop.index0
								for item in template_object.metafields.custom.reassurance.value
									if forloop.index0 == metaobject_index
										assign source = item
										break
									endif
								endfor
							endif

							assign has_img = false
							if source.image != blank
								assign has_img = true
								assign img_alt = source.image.alt | default: source.heading
							endif
							assign icon_width = block.settings.width | default: 40
						-%}
						<div
							class="reassurances__item swiper-slide grid__item center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
							{% if settings.animations_reveal_on_scroll %}
								data-cascade style="--animation-order: {{ forloop.index }};"
							{% endif %}
							role="listitem"
						>
							{%- if source.url != blank and source.popin_content == blank -%}
								<a
									href="{{ source.url }}"
									class="reassurances__link full-unstyled-link"
									aria-label="{{ source.heading | escape }}"
								>
							{%- endif -%}
							<div
								class="reassurances__media media"
								style="--icon-width: {{ icon_width }}px; --icon-margin-bottom: {{ block.settings.margin_bottom }}px;"
							>
								{%- if has_img -%}
									{% capture media_item %}
										{{
											source.image
											| image_url: width: icon_width
											| image_tag: widths: '20, 30, 40, 50, 60, 80, 100', class: 'icon', loading: 'lazy', alt: img_alt, role: 'img'
										}}
									{% endcapture %}
									{%- if lazy_load -%}
										{{ media_item | replace: 'srcset=', 'lazy-srcset=' | replace: 'src=', 'lazy-src=' }}
									{%- else -%}
										{{ media_item }}
									{%- endif -%}
								{%- else -%}
									{{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
								{%- endif -%}
							</div>

							{%- if source.heading != blank -%}
								<h3 class="reassurances__heading">
									{{ source.heading | newline_to_br }}
								</h3>
							{%- endif -%}

							{%- if section.settings.show_content -%}
								<div class="reassurances__content">
									{{ source.text | newline_to_br }}
								</div>
							{%- endif -%}

							{%- if source.button_text != blank -%}
								{%- if source.popin_content != blank -%}
									<modal-opener data-modal="#PopupModal-{{ block.id }}">
										<button
											class="reassurances__subheading ax-link reversed{% if source.popin_content == blank %} ax-link--disabled{% endif %}"
											type="button"
											aria-label="{{ 'sections.video.load_video' | t: description: block.settings.description | escape }}"
											aria-haspopup="dialog"
											data-media-id="{{ block.settings.video_url.id }}"
										>
											{{ source.button_text }}
										</button>
									</modal-opener>
								{%- else -%}
									<div class="reassurances__subheading reassurances__popin-btn ax-link reversed">
										{{ source.button_text }}
									</div>
								{%- endif -%}
							{%- endif -%}

							{%- if source.url != blank and source.popin_content == blank -%}
								</a>
							{%- endif -%}
						</div>

						{% if source.popin_content != blank and source.button_text != blank and source.url == blank %}
							<modal-dialog
								id="PopupModal-{{ block.id }}"
								class="modal-dialog gradient color-{{ section.settings.color_scheme_popin }}"
							>
								<div
									class="modal-dialog__content reassurances__popin-wrapper"
									role="dialog"
									aria-label="{{ source.heading | escape }}"
									aria-modal="true"
									tabindex="-1"
								>
									<div class="modal-dialog__header reassurances__popin-header">
										<div class="modal-dialog__header-title reassurances__popin-title h4">{{ source.heading }}</div>
										<button
											id="ModalClose-{{ block.id }}"
											type="button"
											class="modal-dialog__toggle reassurances__popin-close"
											aria-label="{{ 'accessibility.close' | t }}"
										>
											<span class="svg-wrapper">
												{{- 'icon-close.svg' | inline_asset_content -}}
											</span>
										</button>
									</div>
									<div class="reassurances__popin-content">
										{{ source.popin_content | newline_to_br }}
									</div>
								</div>
							</modal-dialog>
						{% endif %}
					{%- endfor -%}
				</div>

				{%- if section.settings.pagination -%}
					<div
						class="swiper-pagination"
						role="tablist"
						aria-label="{{ 'general.slider.pagination' | t }}"
					></div>
				{%- endif -%}
			</div>
		</reassurances-component>
	</div>
</div>

{% schema %}
	{
		"name": "Ax Reassurances",
		"tag": "section",
		"class": "section ax-section ax-reassurances",
		"max_blocks": 6,
		"disabled_on": {
			"groups": ["header"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Titre"
			},
			{
				"type": "text",
				"id": "heading",
				"label": "Titre",
				"default": "Nos engagements",
				"info": "Masqué, utilisé pour le SEO"
			},
			{
				"type": "header",
				"content": "Paramètres globaux"
			},
			{
				"type": "checkbox",
				"id": "restricted_width",
				"label": "Largeur restreinte",
				"default": false
			},
			{
				"type": "checkbox",
				"id": "stack_mobile",
				"label": "Empiler en mobile",
				"default": false
			},
			{
				"type": "checkbox",
				"id": "border_top_mobile",
				"label": "Afficher une bordure en haut sur mobile",
				"default": false
			},
			{
				"type": "checkbox",
				"id": "border_bottom_mobile",
				"label": "Afficher une bordure en bas sur mobile",
				"default": false
			},
			{
				"type": "header",
				"content": "Paramètres du contenu"
			},
			{
				"type": "checkbox",
				"id": "show_content",
				"label": "Afficher le contenu des reassurances (hors popin)",
				"default": false
			},
			{
				"type": "header",
				"content": "Paramètres du slider mobile"
			},
			{
				"type": "checkbox",
				"id": "autoplay",
				"label": "Autoplay",
				"default": false
			},
			{
				"type": "range",
				"id": "speed",
				"label": "Vitesse de transition",
				"default": 300,
				"step": 100,
				"min": 100,
				"max": 3000
			},
			{
				"type": "checkbox",
				"id": "loop",
				"label": "Slider infini",
				"default": false
			},
			{
				"type": "checkbox",
				"id": "pagination",
				"label": "Afficher la pagination",
				"default": true
			},
			{
				"type": "header",
				"content": "Couleurs"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "t:sections.all.colors.label",
				"default": "background-1"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme_popin",
				"label": "Couleur du popin",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Marges internes"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			},
			{
				"type": "header",
				"content": "Marges externes"
			},
			{
				"type": "range",
				"id": "mob_margin_top",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "(Mobile) Margin top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_margin_bottom",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "(Mobile) Margin bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "margin_top",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "Margin top",
				"default": 0
			},
			{
				"type": "range",
				"id": "margin_bottom",
				"min": 0,
				"max": 100,
				"step": 2,
				"unit": "px",
				"label": "Margin bottom",
				"default": 0
			}
		],
		"blocks": [
			{
				"type": "reassurance",
				"name": "Reassurance",
				"settings": [
					{
						"type": "metaobject",
						"id": "metaobject",
						"label": "Metaobjet",
						"info": "Sélectionnez le metaobjet à lier à la reassurance",
						"metaobject_type": "reassurance"
					},
					{
						"type": "header",
						"content": "Paramètres de l'image"
					},
					{
						"type": "range",
						"id": "width",
						"min": 20,
						"max": 100,
						"step": 2,
						"unit": "px",
						"label": "Largeur de l'image",
						"default": 80
					},
					{
						"type": "range",
						"id": "margin_bottom",
						"min": 0,
						"max": 100,
						"step": 2,
						"unit": "px",
						"label": "Marge en bas",
						"default": 16
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax Reassurances",
				"category": "Axome",
				"blocks": [
					{
						"type": "reassurance"
					},
					{
						"type": "reassurance"
					},
					{
						"type": "reassurance"
					},
					{
						"type": "reassurance"
					}
				]
			}
		]
	}
{% endschema %}
