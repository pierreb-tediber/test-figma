{{ 'bundle.cards-links.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.mob_padding_top }}px;
	  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}
{%- endstyle -%}
{%- liquid
	assign lazy_load = false
	if section.index > 1
		assign lazy_load = true
	endif

	assign number_of_cards = section.blocks.size
-%}

<div
	class="cards-links gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
	data-ax-section="cardslinksSection"
	aria-labelledby="section-heading-{{ section.id }}"
>
	{%- if section.settings.heading != blank -%}
		{%- render 'section-heading', heading: section.settings.heading, text_alignment: 'center', heading_size: 'h2' -%}
	{%- endif -%}

	<ul
		class="cards-links__container{% if number_of_cards == 5 %} cards-links__container--full{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
		{% if settings.animations_reveal_on_scroll %}
			data-cascade
		{% endif %}
	>
		{%- for block in section.blocks -%}
			<li
				{% if settings.animations_reveal_on_scroll %}
					data-cascade
					style="--animation-order: {{ forloop.index }};"
				{% endif %}
			>
				{% style %}
					#card-{{ block.id }} {
						border-color: {{ block.settings.border_color }};
					}
				{% endstyle %}
				<div id="card-{{ block.id }}" class="cards-links__card gradient color-{{ block.settings.color_scheme }}">
					{%- if block.settings.image != blank -%}
						{%- assign img_alt = block.settings.image.alt | default: block.settings.image.title | strip_html -%}
						<div class="cards-links__card-image">
							{% capture media_image %}
									{{ block.settings.image | image_url: width: 130 | image_tag: width: block.settings.image.width, height: block.settings.image.height, loading: lazy_load, alt: img_alt }}
								{% endcapture %}
							{%- if lazy_load -%}
								{{ media_image | replace: 'src=', 'lazy-src=' | replace: 'srcset=', 'lazy-srcset=' }}
							{%- else -%}
								{{ media_image }}
							{%- endif -%}
						</div>
					{%- endif -%}
					<div class="cards-links__card-content">
						{%- if block.settings.heading != blank -%}
							<h3 class="cards-links__card-heading h3" id="card-heading-{{ block.id }}">
								{%- if block.settings.link != blank -%}
									{%- liquid
										assign card_link = block.settings.link
										# Vérifier si le lien ne contient pas déjà shop.url ET n'est pas un lien externe
										unless card_link contains shop.url or card_link contains 'http'
											# Si c'est un lien relatif, ajouter l'URL du shop
											if card_link contains '/'
												assign card_link = shop.url | append: card_link
											else
												assign card_link = shop.url | append: '/' | append: card_link
											endif
										endunless
									-%}
									<a
										href="{{ card_link }}"
										class="full-unstyled-link"
										{%- if block.settings.heading != blank -%}
											{%- assign clean_title = block.settings.heading | strip_html -%}
											aria-label="{{ 'accessibility.card_link.label' | t: title: clean_title }}"
										{%- else -%}
											aria-label="{{ 'accessibility.card_link.default' | t }}"
										{%- endif -%}
										{% if block.settings.link_blank %}
											target="_blank"
											rel="noopener"
											aria-label="{{ 'accessibility.card_link.blank' | t: title: clean_title }}"
										{% endif %}
									>
										{{ block.settings.heading }}
									</a>
								{%- else -%}
									{{ block.settings.heading }}
								{%- endif -%}
							</h3>
						{%- endif -%}
						{%- if block.settings.link_text != blank -%}
							<span class="ax-link reversed" aria-hidden="true">{{ block.settings.link_text }}</span>
						{%- endif -%}
					</div>
				</div>
			</li>
		{%- endfor -%}
	</ul>

	{%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
		{%- render 'link-style',
			link_label: section.settings.button_text,
			link_url: section.settings.button_link,
			link_style: section.settings.link_style,
			link_target: section.settings.link_blank,
			link_attributes: section.shopify_attributes
		-%}
	{%- endif -%}
</div>

{% schema %}
	{
		"name": "Ax cards links",
		"tag": "section",
		"class": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "richtext",
				"id": "heading",
				"label": "Titre",
				"default": "<p>Titre</p>"
			},
			{
				"type": "text",
				"id": "button_text",
				"label": "Texte du bouton"
			},
			{
				"type": "url",
				"id": "button_link",
				"label": "Lien du bouton"
			},
			{
				"type": "checkbox",
				"id": "link_blank",
				"label": "Lien _blank",
				"info": "Ouvrir ce lien dans une nouvelle fenêtre",
				"default": false
			},
			{
				"type": "select",
				"id": "link_style",
				"options": [
					{
						"value": "button button--primary",
						"label": "Primary"
					},
					{
						"value": "button button--secondary",
						"label": "Secondary"
					},
					{
						"value": "ax-link",
						"label": "Link"
					},
					{
						"value": "ax-link reversed",
						"label": "Link inversé"
					},
					{
						"value": "underlined-link",
						"label": "Underline link"
					}
				],
				"default": "button button--primary",
				"label": "Style du bouton"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [
			{
				"type": "card",
				"name": "Card",
				"limit": 5,
				"settings": [
					{
						"type": "header",
						"content": "Contenu"
					},
					{
						"type": "image_picker",
						"id": "image",
						"label": "Image"
					},
					{
						"type": "richtext",
						"id": "heading",
						"label": "Titre",
						"default": "<p>Titre</p>"
					},
					{
						"type": "text",
						"id": "link_text",
						"label": "Texte du lien",
						"default": "Lien"
					},
					{
						"type": "url",
						"id": "link",
						"label": "Lien"
					},
					{
						"type": "checkbox",
						"id": "link_blank",
						"label": "Lien _blank",
						"info": "Ouvrir ce lien dans une nouvelle fenêtre",
						"default": false
					},
					{
						"type": "header",
						"content": "Couleur"
					},
					{
						"type": "color_scheme",
						"id": "color_scheme",
						"label": "Couleur",
						"default": "background-1"
					},
					{
						"type": "color",
						"id": "border_color",
						"label": "Couleur de la bordure",
						"default": "#010C27"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax cards links",
				"blocks": [
					{
						"type": "card"
					},
					{
						"type": "card"
					},
					{
						"type": "card"
					},
					{
						"type": "card"
					},
					{
						"type": "card"
					}
				]
			}
		]
	}
{% endschema %}
