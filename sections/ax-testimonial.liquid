{{ 'component-testimonial.css' | asset_url | stylesheet_tag }}
{{ 'bundle.testimonial.css' | asset_url | stylesheet_tag }}

{%- style -%}
	 	.section-{{ section.id }}-padding {
	   	padding-top: {{ section.settings.padding_top }}px;
	   	padding-bottom: {{ section.settings.padding_bottom }}px;
	}

	@media screen and (max-width: 989px) {
		.section-{{ section.id }}-padding {
				padding-top: {{ section.settings.mobile_padding_top }}px;
				padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
		}
	}

	{%- if section.settings.overlay -%}
		#shopify-section-{{ section.id }} .testimonial__media::before { background: rgba(0, 0, 0,
			{{ section.settings.overlay_opacity }});
		}
	{%- endif -%}

	{%- if section.settings.mobile_layout == 'text_first' -%}
		@media screen and (max-width: 989px) {
			#shopify-section-{{ section.id }} .testimonial__grid {
				display: flex;
				flex-direction: column;
			}
			#shopify-section-{{ section.id }} .testimonial__media-item {
				order: 2;
			}
			#shopify-section-{{ section.id }} .testimonial__text-item {
				order: 1;
			}
		}
	{%- endif -%}
{%- endstyle -%}

{%- liquid
	assign fetch_priority = 'high'
	assign loading = 'eager'
	assign lazy_load = false
	if section.index > 1
		assign fetch_priority = 'auto'
		assign loading = 'lazy'
		assign lazy_load = true
	endif
	if section.settings.color_scheme == section.settings.section_color_scheme
		assign remove_color_classes = true
	endif

	assign section_heading = section.blocks | where: 'type', 'heading' | first
	assign accessibility_alt = 'accessibility.image_description' | t
	assign alt_img = section_heading.settings.heading | default: accessibility_alt

	# Logique Trustpilot Product
	assign trustpilot_product_skus = section.settings.trustpilot_product_skus
	assign show_trustpilot_shop = section.settings.show_trustpilot_shop
	assign show_trustpilot_widget = false

	# Priorité : boutique > SKUs produits > texte dur
	if show_trustpilot_shop
		assign show_trustpilot_widget = true
		assign trustpilot_type = 'shop'
	elsif trustpilot_product_skus != blank
		assign show_trustpilot_widget = true
		assign trustpilot_type = 'product'
	endif
-%}

<div
	class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}"
	role="region"
	aria-label="{% if section.settings.heading != blank %}{{ section.settings.heading }}{% else %}{{ 'sections.ax_testimonial.section_title' | t }}{% endif %}"
>
	{%- unless section.settings.full_width -%}
		<div class="page-width">
	{%- endunless -%}
	<div class="testimonial isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
		<div class="testimonial__grid{% if section.settings.layout == 'text_first' %} testimonial__grid--reverse{% endif %}">
			<div class="testimonial__media-item testimonial__media-item--middle testimonial__grid-item">
				<div
					class="testimonial__media{% if section.settings.overlay %} overlay{% endif %} global-media-settings{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}{% if section.settings.image != blank %} media{% else %} testimonial__media--placeholder placeholder{% endif %}"
					role="img"
					aria-label="{% if section.settings.image.alt != blank %}{{ section.settings.image.alt | escape }}{% else %}{{ alt_img }}{% endif %}"
				>
					{%- if section.settings.image -%}
						{%- capture media_image -%}
								<picture>
									{%- if section.settings.image_mobile -%}
										<source
										media="(max-width: 450px)"
										srcset="{{ section.settings.image_mobile | image_url: width: 450 }} 1x, {{ section.settings.image_mobile | image_url: width: 900 }} 2x"
									>
									{%- if section.settings.image_mobile.width >= 500 -%}
										<source
											media="(max-width: 500px)"
											srcset="{{ section.settings.image_mobile | image_url: width: 500 }} 1x, {{ section.settings.image_mobile | image_url: width: 1000 }} 2x"
										>
									{%- endif -%}
									{%- if section.settings.image_mobile.width >= 600 -%}
										<source
											media="(max-width: 600px)"
											srcset="{{ section.settings.image_mobile | image_url: width: 600 }} 1x, {{ section.settings.image_mobile | image_url: width: 1200 }} 2x"
										>
									{%- endif -%}
									{%- if section.settings.image_mobile.width >= 700 -%}
										<source
											media="(max-width: 989px)"
											srcset="{{ section.settings.image_mobile | image_url: width: 700 }} 1x, {{ section.settings.image_mobile | image_url: width: 1400 }} 2x"
										>
									{%- endif -%}
									
								{%- else -%}
									{%- if section.settings.image.width >= 330 -%}
										<source
											media="(max-width: 330px)"
											srcset="{{ section.settings.image | image_url: width: 330 }} 1x, {{ section.settings.image | image_url: width: 660 }} 2x"
										>
									{%- endif -%}
									{%- if section.settings.image.width >= 375 -%}
										<source
											media="(max-width: 375px)"
											srcset="{{ section.settings.image | image_url: width: 375 }} 1x, {{ section.settings.image | image_url: width: 750 }} 2x"
										>
									{%- endif -%}
									{%- if section.settings.image.width >= 400 -%}
										<source
											media="(max-width: 400px)"
											srcset="{{ section.settings.image | image_url: width: 400 }} 1x, {{ section.settings.image | image_url: width: 800 }} 2x"
										>
									{%- endif -%}
									{%- if section.settings.image.width >= 450 -%}
										<source
											media="(max-width: 450px)"
											srcset="{{ section.settings.image | image_url: width: 450 }} 1x, {{ section.settings.image | image_url: width: 900 }} 2x"
										>
									{%- endif -%}
									{%- if section.settings.image.width >= 550 -%}
										<source
											media="(max-width: 550px)"
											srcset="{{ section.settings.image | image_url: width: 550 }} 1x, {{ section.settings.image | image_url: width: 1100 }} 2x"
										>
									{%- endif -%}
								{%- endif -%}
								{%- if section.settings.image.width >= 768 -%}
									<source
										media="(max-width: 768px)"
										srcset="{{ section.settings.image | image_url: width: 768 }} 1x, {{ section.settings.image | image_url: width: 1536 }} 2x"
									>
								{%- endif -%}
								{%- if section.settings.image.width >= 1280 -%}
									<source
										media="(max-width: 1280px)"
										srcset="{{ section.settings.image | image_url: width: 1280 }} 1x, {{ section.settings.image | image_url: width: 2560 }} 2x"
									>
								{%- endif -%}
								{%- if section.settings.image.width >= 1366 -%}
									<source
										media="(max-width: 1366px)"
										srcset="{{ section.settings.image | image_url: width: 1366 }} 1x, {{ section.settings.image | image_url: width: 2732 }} 2x"
									>
								{%- endif -%}
								{%- if section.settings.image.width >= 1440 -%}
									<source
										media="(max-width: 1440px)"
										srcset="{{ section.settings.image | image_url: width: 1440 }} 1x, {{ section.settings.image | image_url: width: 2880 }} 2x"
									>
								{%- endif -%}
								{%- if section.settings.image.width >= 1600 -%}
									<source
										media="(max-width: 1600px)"
										srcset="{{ section.settings.image | image_url: width: 1600 }} 1x, {{ section.settings.image | image_url: width: 3200 }} 2x"
									>
								{%- endif -%}
								<img
									src="{{ section.settings.image | image_url: width: section.settings.image.width }}"
									srcset="{{ section.settings.image | image_url: width: section.settings.image.width }}"
									alt="{% if section.settings.image.alt != blank %}{{ section.settings.image.alt | escape }}{% else %}{{ alt_img }}{% endif %}"
									width="{{ section.settings.image.width }}"
									height="{{ section.settings.image.width | divided_by: section.settings.image.aspect_ratio | round }}"
									loading="{{ loading }}"
									decoding="async"
								>
							</picture>
						{% endcapture %}
						{% if lazy_load %}
							{{ media_image | replace: 'src=', 'lazy-src=' | replace: 'srcset=', 'lazy-srcset=' }}
						{% else %}
							{{ media_image }}
						{% endif %}
					{%- else -%}
						{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
					{%- endif -%}
				</div>
			</div>
			<div class="testimonial__text-item testimonial__grid-item">
				<div
					id="ImageWithText--{{ section.id }}"
					class="testimonial__content testimonial__content--middle testimonial__content--desktop-center testimonial__content--mobile-center content-container{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}"
				>
					{%- liquid
						assign subheading = section.blocks | where: 'type', 'subheading' | first
						assign heading = section.blocks | where: 'type', 'heading' | first
						assign text = section.blocks | where: 'type', 'text' | first
						assign button = section.blocks | where: 'type', 'button' | first

						# Définir les valeurs pour section-heading selon la présence du widget Trustpilot
						if show_trustpilot_widget
							assign render_heading = blank
							assign render_subheading = blank
						else
							assign render_heading = heading.settings.heading
							assign render_subheading = subheading.settings.subheading
						endif
					-%}

					{%- if show_trustpilot_widget -%}
						{%- if trustpilot_type == 'product' -%}
							<!-- TrustBox widget - Product Reviews MultiSource -->
							<div
								class="trustpilot-widget"
								data-locale="fr-FR"
								data-template-id="577258fb31f02306e4e3aaf9"
								data-businessunit-id="5a5cdcedf3b8320001d06ddf"
								data-style-height="24px"
								data-style-width="100%"
								data-token="06292a35-efe6-4100-80cd-f2dd6efea542"
								data-sku="{{ trustpilot_product_skus }}"
								data-review-languages="fr"
								data-star-color="#218252"
								data-link-color="#191919"
								data-no-reviews="hide"
								data-scroll-to-list="true"
								data-style-alignment="center"
							>
								<a href="https://fr.trustpilot.com/review/www.tediber.com" target="_blank" rel="noopener"></a>
							</div>
							<!-- End TrustBox widget - Product Reviews -->
						{%- elsif trustpilot_type == 'shop' -%}
							<!-- TrustBox widget - Mini -->
							<div
								class="trustpilot-widget"
								data-locale="fr-FR"
								data-template-id="53aa8807dec7e10d38f59f32"
								data-businessunit-id="5a5cdcedf3b8320001d06ddf"
								data-style-height="150px"
								data-style-width="100%"
								data-star-color="#218252"
								data-token="f6e6c570-015f-48cc-9719-cde782a50cc9"
							>
								<a href="https://fr.trustpilot.com/review/www.tediber.com" target="_blank" rel="noopener"></a>
							</div>
							<!-- End TrustBox widget -->
						{%- endif -%}
					{%- endif -%}

					{%- render 'section-heading',
						heading: render_heading,
						subheading: render_subheading,
						text_alignment: 'center',
						heading_size: 'div',
						heading_class: heading.settings.heading_class,
						picto: text.settings.picto,
						picto_size: text.settings.picto_size,
						heading_picto: heading.settings.picto,
						heading_picto_size: heading.settings.picto_size,
						description: text.settings.text
					-%}
					{%- if button.settings.button_text != blank and button.settings.button_link != blank -%}
						{%- render 'link-style',
							link_label: button.settings.button_text,
							link_url: button.settings.button_link,
							link_style: button.settings.link_style,
							link_target: button.settings.link_blank,
							link_attributes: section.shopify_attributes
						-%}
					{%- endif -%}
				</div>
			</div>
		</div>
	</div>
	{%- unless section.settings.full_width -%}
		</div>
	{%- endunless -%}
</div>

{% schema %}
	{
		"name": "Ax Testimonial",
		"class": "section ax-section ax-testimonial",
		"tag": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "checkbox",
				"id": "full_width",
				"label": "Largeur complète",
				"default": false
			},
			{
				"type": "header",
				"content": "Trustpilot"
			},
			{
				"type": "checkbox",
				"id": "show_trustpilot_shop",
				"label": "Afficher les avis boutique",
				"info": "Priorité 1 : Si activé, affiche les avis de la boutique Trustpilot et masque le titre/sous-titre.",
				"default": false
			},
			{
				"type": "text",
				"id": "trustpilot_product_skus",
				"label": "SKUs Produits Trustpilot",
				"info": "Priorité 2 : Séparer les SKUs par une virgule. Si rempli (et boutique désactivée), affiche le widget avis produits et masque le titre/sous-titre."
			},
			{
				"type": "header",
				"content": "Image"
			},
			{
				"type": "image_picker",
				"id": "image",
				"label": "t:sections.image-with-text.settings.image.label"
			},
			{
				"type": "image_picker",
				"id": "image_mobile",
				"label": "Image mobile"
			},
			{
				"type": "select",
				"id": "layout",
				"options": [
					{
						"value": "image_first",
						"label": "t:sections.image-with-text.settings.layout.options__1.label"
					},
					{
						"value": "text_first",
						"label": "t:sections.image-with-text.settings.layout.options__2.label"
					}
				],
				"default": "image_first",
				"label": "t:sections.image-with-text.settings.layout.label"
			},
			{
				"type": "select",
				"id": "mobile_layout",
				"options": [
					{
						"value": "image_first",
						"label": "t:sections.image-with-text.settings.layout.options__1.label"
					},
					{
						"value": "text_first",
						"label": "t:sections.image-with-text.settings.layout.options__2.label"
					}
				],
				"default": "image_first",
				"label": "Layout mobile",
				"info": "Ordre d'affichage sur mobile"
			},
			{
				"type": "header",
				"content": "Overlay"
			},
			{
				"type": "checkbox",
				"id": "overlay",
				"label": "Ajouter un overlay",
				"default": true
			},
			{
				"type": "range",
				"id": "overlay_opacity",
				"min": 0,
				"max": 1,
				"step": 0.1,
				"label": "Image overlay opacity",
				"info": "Increase contrast for legible text.",
				"default": 0.2
			},
			{
				"type": "header",
				"content": "t:sections.image-with-text.settings.header_colors.content"
			},
			{
				"type": "color_scheme",
				"id": "section_color_scheme",
				"label": "t:sections.all.colors.label",
				"default": "scheme-1"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "t:sections.multirow.settings.container_color_scheme.label",
				"default": "scheme-1"
			},
			{
				"type": "header",
				"content": "t:sections.all.padding.section_padding_heading"
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "t:sections.all.padding.padding_top",
				"default": 36
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "t:sections.all.padding.padding_bottom",
				"default": 36
			},
			{
				"type": "range",
				"id": "mobile_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Mobile haut",
				"default": 24
			},
			{
				"type": "range",
				"id": "mobile_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Mobile bas",
				"default": 24
			}
		],
		"blocks": [
			{
				"type": "heading",
				"name": "Titre",
				"limit": 1,
				"settings": [
					{
						"type": "image_picker",
						"id": "picto",
						"label": "Picto"
					},
					{
						"type": "range",
						"id": "picto_size",
						"min": 0,
						"max": 100,
						"step": 2,
						"unit": "px",
						"label": "Taille du picto",
						"default": 24
					},
					{
						"type": "inline_richtext",
						"id": "heading",
						"default": "Titre",
						"label": "Titre"
					},
					{
						"type": "select",
						"id": "heading_class",
						"options": [
							{
								"value": "h3",
								"label": "t:sections.all.heading_size.options__1.label"
							},
							{
								"value": "h2",
								"label": "t:sections.all.heading_size.options__2.label"
							},
							{
								"value": "h1",
								"label": "t:sections.all.heading_size.options__3.label"
							}
						],
						"default": "h1",
						"label": "t:sections.all.heading_size.label"
					}
				]
			},
			{
				"type": "subheading",
				"name": "Sur-titre",
				"limit": 1,
				"settings": [
					{
						"type": "inline_richtext",
						"id": "subheading",
						"label": "Sur-titre"
					}
				]
			},
			{
				"type": "text",
				"name": "Texte",
				"limit": 1,
				"settings": [
					{
						"type": "image_picker",
						"id": "picto",
						"label": "Picto"
					},
					{
						"type": "range",
						"id": "picto_size",
						"min": 0,
						"max": 100,
						"step": 2,
						"unit": "px",
						"label": "Taille du picto",
						"default": 24
					},
					{
						"type": "richtext",
						"id": "text",
						"default": "<p>Texte</p>",
						"label": "Texte"
					}
				]
			},
			{
				"type": "button",
				"name": "Bouton",
				"limit": 1,
				"settings": [
					{
						"type": "text",
						"id": "button_text",
						"label": "Texte du bouton"
					},
					{
						"type": "url",
						"id": "button_link",
						"label": "Lien du bouton"
					},
					{
						"type": "checkbox",
						"id": "link_blank",
						"label": "Lien _blank",
						"info": "Ouvrir ce lien dans une nouvelle fenêtre",
						"default": false
					},
					{
						"type": "select",
						"id": "link_style",
						"options": [
							{
								"value": "button button--primary",
								"label": "Primary"
							},
							{
								"value": "button button--secondary",
								"label": "Secondary"
							},
							{
								"value": "ax-link",
								"label": "Link"
							},
							{
								"value": "ax-link reversed",
								"label": "Link inversé"
							},
							{
								"value": "underlined-link",
								"label": "Underline link"
							}
						],
						"default": "button button--primary",
						"label": "Style du bouton"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Ax Testimonial",
				"blocks": [
					{
						"type": "subheading"
					},
					{
						"type": "heading"
					},
					{
						"type": "text"
					},
					{
						"type": "button"
					}
				]
			}
		]
	}
{% endschema %}
