{%- style -%}
	.section-{{ section.id }}-padding {
		padding-top: {{ section.settings.mob_padding_top }}px;
		padding-bottom: {{ section.settings.mob_padding_bottom }}px;
	}

	@media screen and (min-width: 990px) {
		.section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
{%- endstyle -%}

<div class="section-{{ section.id }}-padding {% if section.settings.include_margins %}page-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  {%- for block in section.blocks -%}
		{%- assign app_id_array = block.id | split: '_' -%}
		{%- if app_id_array contains 'join' or app_id_array contains 'stories' -%}
			<product-join-stories
				data-app-id="{{ block.id }}"
			>
				{%- render block -%}
			</product-join-stories>
		{%- else -%}
			{%- render block -%}
		{%- endif -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "t:sections.apps.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "include_margins",
      "default": true,
      "label": "t:sections.apps.settings.include_margins.label"
    },
		{
			"type": "header",
			"content": "Padding (space)"
		},
		{
			"type": "range",
			"id": "mob_padding_top",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "(Mobile) Padding top",
			"default": 0
		},
		{
			"type": "range",
			"id": "mob_padding_bottom",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "(Mobile) Padding bottom",
			"default": 0
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "Padding top",
			"default": 0
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "Padding bottom",
			"default": 0
		}
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.apps.presets.name"
    }
  ]
}
{% endschema %}
