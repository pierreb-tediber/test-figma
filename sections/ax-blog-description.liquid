{% if settings.cocon_page != blank
	or blog.metafields.custom.lien_entete != blank
	or blog.metafields.custom.description != blank
%}
	{{ 'bundle.blog-description.css' | asset_url | stylesheet_tag }}

	{%- style -%}
		.section-{{ section.id }}-padding {
		  padding-top: {{ section.settings.mob_padding_top }}px;
		  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
		  margin-top: {{ section.settings.mob_margin_top }}px;
		  margin-bottom: {{ section.settings.mob_margin_bottom }}px;
		}

		@media screen and (min-width: 750px) {
		  .section-{{ section.id }}-padding {
		    padding-top: {{ section.settings.padding_top }}px;
		    padding-bottom: {{ section.settings.padding_bottom }}px;
		    margin-top: {{ section.settings.margin_top }}px;
		    margin-bottom: {{ section.settings.margin_bottom }}px;
		  }
		}
	{%- endstyle -%}

	<div
		class="blog-description gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="blogDescription"
	>
		<div class="page-width page-width--restricted-width">
			<div class="blog-description__content">
				{% if settings.cocon_page != blank or blog.metafields.custom.lien_entete != blank %}
					<div class="blog-description__ctas">
						{% if settings.cocon_page != blank %}
							<a href="{{ settings.cocon_page }}" class="ax-link reversed">
								{{ 'general.breadcrumbs.all_our_tips' | t }}
							</a>
						{% endif %}
						{% if blog.metafields.custom.lien_entete != blank %}
							<a href="{{ blog.metafields.custom.lien_entete.value.url}}" class="button button--primary">
								{{ blog.metafields.custom.lien_entete.value.text }}
							</a>
						{% endif %}
					</div>
				{% endif %}

				{% if blog.metafields.custom.description != blank %}
					<div class="blog-description__description">
						{{ blog.metafields.custom.description }}
					</div>
				{% endif %}
			</div>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax blog description",
		"tag": "section",
		"class": "section",
		"enabled_on": {
			"templates": ["blog"]
		},
		"limit": 1,
		"settings": [
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Marges internes"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			},
			{
				"type": "header",
				"content": "Marges externes"
			},
			{
				"type": "range",
				"id": "mob_margin_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Margin top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_margin_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Margin bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "margin_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Margin top",
				"default": 0
			},
			{
				"type": "range",
				"id": "margin_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Margin bottom",
				"default": 0
			}
		],
		"blocks": [],
		"presets": [
			{
				"name": "Ax blog description",
				"blocks": []
			}
		]
	}
{% endschema %}
