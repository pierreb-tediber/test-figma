{% if blog != blank and blog.articles_count > 0 %}
	{{ 'bundle.featured-blog.css' | asset_url | stylesheet_tag }}

	<script>
		window.assetsUrl.js.push({"featuredBlog": "{{ "bundle.featured-blog.js" | asset_url }}"});
	</script>

	{% capture swiper-options %}
    {
    "slideInView": "auto",
    "slidesToMove": 1,
    "loop": {% if section.settings.one_slide %}true{% else %}false{% endif %},
    "autoplay": false,
    "speed": 300,
    "grabCursor": true,
    "effect": "slide",
    "freemode_mobile": true
    }
{% endcapture %}

	{%- style -%}
		.section-{{ section.id }}-padding {
		  padding-top: {{ section.settings.mob_padding_top }}px;
		  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
		}

		@media screen and (min-width: 750px) {
		  .section-{{ section.id }}-padding {
		    padding-top: {{ section.settings.padding_top }}px;
		    padding-bottom: {{ section.settings.padding_bottom }}px;
		  }
		}
	{%- endstyle -%}

	<div data-ax-section="featuredBlog">
		<div class="blog color-{{ section.settings.color_scheme }} gradient{% if section.settings.heading == blank %} no-heading{% endif %}">
			<div class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
				{% if section.settings.heading != blank %}
					{%- render 'section-heading',
						heading: section.settings.heading,
						heading_picto: section.settings.picto,
						heading_picto_size: section.settings.picto_size,
						heading_picto_size_mobile: section.settings.picto_size_mobile,
						text_alignment: 'center'
					-%}
				{% endif %}
				<featured-blog>
					<div
						id="Swiper-{{ section.id }}"
						data-options="{{ swiper-options | escape }}"
						class="swiper blog__posts articles-wrapper"
					>
						<ul class="swiper-wrapper grid grid--1-7-col grid--2-col-tablet grid--3-col-desktop">
							{%- assign articles_count = 0 -%}
							{%- for blog_article in blog.articles -%}
								{%- if blog_article.id != article.id and articles_count < 3 -%}
									{%- assign articles_count = articles_count | plus: 1 -%}
									<li
										id="Swiper-{{ section.id }}-{{ articles_count }}"
										class="swiper-slide blog__post article grid__item"
									>
										{% render 'article-card-horizontal',
											blog: blog,
											article: blog_article
											truncate: 20,
											no_hn: true
										%}
									</li>
								{%- endif -%}
							{%- endfor -%}
						</ul>
					</div>
				</featured-blog>
			</div>
		</div>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax featured Blog",
		"tag": "section",
		"class": "section ax-section featured-blog",
		"enabled_on": {
			"templates": ["article"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Contenu"
			},
			{
				"type": "richtext",
				"id": "heading",
				"label": "Titre",
				"default": "<p>Dans la même thématique</p>"
			},
			{
				"type": "image_picker",
				"id": "picto",
				"label": "Picto"
			},
			{
				"type": "range",
				"id": "picto_size",
				"min": 0,
				"max": 200,
				"step": 2,
				"unit": "px",
				"label": "Taille du picto",
				"default": 24
			},
			{
				"type": "range",
				"id": "picto_size_mobile",
				"min": 0,
				"max": 200,
				"step": 2,
				"unit": "px",
				"label": "Taille du picto mobile",
				"default": 24
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"presets": [
			{
				"name": "Ax featured Blog",
				"category": "Axome",
				"settings": {}
			}
		]
	}
{% endschema %}
