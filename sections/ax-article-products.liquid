{% if section.settings.metaobject != blank %}
	{{ 'bundle.article-products.css' | asset_url | stylesheet_tag }}

	{%- style -%}
		.section-{{ section.id }}-padding {
		  padding-top: {{ section.settings.mob_padding_top }}px;
		  padding-bottom: {{ section.settings.mob_padding_bottom }}px;
		}

		@media screen and (min-width: 750px) {
		  .section-{{ section.id }}-padding {
		    padding-top: {{ section.settings.padding_top }}px;
		    padding-bottom: {{ section.settings.padding_bottom }}px;
		  }
		}
	{%- endstyle -%}

	{%- liquid
		assign product_list = section.settings.metaobject.products_list.value
		assign lazy_load = false

		if section.index > 2
			assign lazy_load = true
		endif
	-%}

	<div
		class="article-products gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
		data-ax-section="articleProducts"
	>
		<ul
			class="grid grid--2-col grid--4-col-desktop list-unstyled"
			role="list"
			aria-live="polite"
		>
			{% for product in product_list limit: 4 %}
				{%- liquid
					assign skip_card_product_styles = false
					assign display_index = forloop.index | plus: 1
					# Vérifie si le produit est masqué via metafield seo.hidden
					if product.metafields.seo.hidden.value == 1
						continue
					endif
				-%}
				<li
					class="swiper-slide grid__item"
					role="group"
					aria-roledescription="slide"
					aria-label="{{ 'accessibility.product.label' | t }}: {{ product.title }}"
					data-index="{{ display_index }}"
				>
					{% render 'card-product',
						card_product: product,
						media_aspect_ratio: 'portrait',
						image_shape: 'default',
						show_secondary_image: true,
						show_vendor: false,
						show_rating: false,
						skip_styles: skip_card_product_styles,
						lazy_load: lazy_load
					%}
				</li>
				{%- assign skip_card_product_styles = true -%}
			{% endfor %}
		</ul>
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax article products",
		"tag": "section",
		"class": "section",
		"enabled_on": {
			"templates": ["article"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Produits"
			},
			{
				"type": "metaobject",
				"id": "metaobject",
				"label": "Produits",
				"metaobject_type": "article_products_list"
			},
			{
				"type": "header",
				"content": "Color"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "Color scheme",
				"default": "background-1"
			},
			{
				"type": "header",
				"content": "Padding (space)"
			},
			{
				"type": "range",
				"id": "mob_padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "mob_padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "(Mobile) Padding bottom",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding top",
				"default": 0
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "Padding bottom",
				"default": 0
			}
		],
		"blocks": [],
		"presets": [
			{
				"name": "Ax article products",
				"blocks": []
			}
		]
	}
{% endschema %}
