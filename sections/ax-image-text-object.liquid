{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}
{{ 'bundle.image-text-object.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
	  padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
	  padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
	}

	@media screen and (min-width: 750px) {
	  .section-{{ section.id }}-padding {
	    padding-top: {{ section.settings.padding_top }}px;
	    padding-bottom: {{ section.settings.padding_bottom }}px;
	  }
	}

	{%- if section.settings.overlay -%}
		#shopify-section-{{ section.id }} .image-with-text__media::before { background: rgba(0, 0, 0,
			{{ section.settings.overlay_opacity }});
		}
	{%- endif -%}

	{%- if section.settings.mobile_layout == 'text_first' -%}
		@media screen and (max-width: 989px) {
			#shopify-section-{{ section.id }} .image-with-text__grid {
				display: flex;
				flex-direction: column;
			}
			#shopify-section-{{ section.id }} .image-with-text__media-item {
				order: 2;
			}
			#shopify-section-{{ section.id }} .image-with-text__text-item {
				order: 1;
			}
		}
	{%- endif -%}
{%- endstyle -%}

{%- liquid
	assign lazy_load = false
	if section.index > 1
		assign lazy_load = true
	endif
	if section.settings.color_scheme == section.settings.section_color_scheme
		assign remove_color_classes = true
	endif

	assign section_heading = section.settings.heading
	assign accessibility_alt = 'accessibility.image_description' | t
	assign alt_img = section_heading | default: accessibility_alt

	assign image_text_object = section.settings.image_text_object | default: blank
	assign heading = image_text_object.heading | default: blank
	assign text = image_text_object.text | default: blank
	assign image = image_text_object.image | default: blank
-%}

{% if image_text_object != blank %}
	<div
		class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}"
		role="region"
		aria-label="{% if heading != blank %}{{ heading }}{% else %}{{ 'sections.ax_image_with_text.section_title' | t }}{% endif %}"
	>
		{%- unless section.settings.full_width -%}
			<div class="page-width">
		{%- endunless -%}
		<div class="image-with-text isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
			<div class="image-with-text__grid{% if section.settings.layout == 'text_first' %} image-with-text__grid--reverse{% endif %}">
				<div class="image-with-text__media-item image-with-text__media-item--middle image-with-text__grid-item{% if section.settings.restrict_width %} image-with-text__media-item--restrict-width{% endif %}">
					<div
						class="image-with-text__media{% if section.settings.contain_image %} media--contain{% if section.settings.layout == 'text_first' %} media--contain--right{% else %} media--contain--left{% endif %}{% endif %}{% if section.settings.overlay %} overlay{% endif %} global-media-settings{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}{% if section.settings.image != blank %} media{% else %} image-with-text__media--placeholder placeholder{% endif %}"
					>
						{%- if image -%}
							{% capture media_image %}
								{{ image | image_url: width: 1000 | image_tag: alt: image.alt }}
							{% endcapture %}
							{% if lazy_load %}
								{{ media_image | replace: 'src=', 'lazy-src=' | replace: 'srcset=', 'lazy-srcset=' }}
							{% else %}
								{{ media_image }}
							{% endif %}
						{%- endif -%}
					</div>
				</div>
				<div class="image-with-text__text-item image-with-text__grid-item">
					<div
						id="ImageWithText--{{ section.id }}"
						class="image-with-text__content image-with-text__content--middle image-with-text__content--desktop-center image-with-text__content--mobile-center content-container{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}"
					>
						{%- render 'section-heading',
							heading: heading,
							text_alignment: section.settings.text_alignment,
							heading_size: 'h2',
							description: text,
							metafield_tag: true
						-%}
					</div>
				</div>
			</div>
		</div>
		{%- unless section.settings.full_width -%}
			</div>
		{%- endunless -%}
	</div>
{% endif %}

{% schema %}
	{
		"name": "Ax Image text objet",
		"class": "section ax-section ax-image-with-text ax-image-text-object",
		"tag": "section",
		"disabled_on": {
			"groups": ["header", "footer"]
		},
		"settings": [
			{
				"type": "header",
				"content": "Metaobjet"
			},
			{
				"type": "metaobject",
				"id": "image_text_object",
				"label": "Image text object",
				"metaobject_type": "section_image_with_text",
				"info": "Sélectionnez le metaobjet à afficher"
			},
			{
				"type": "header",
				"content": "Mise en page"
			},
			{
				"type": "checkbox",
				"id": "full_width",
				"label": "Largeur complète",
				"default": false
			},
			{
				"type": "select",
				"id": "text_alignment",
				"options": [
					{
						"value": "left",
						"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.option_1.label"
					},
					{
						"value": "center",
						"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.option_2.label"
					},
					{
						"value": "right",
						"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.option_3.label"
					}
				],
				"default": "center",
				"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.label"
			},
			{
				"type": "checkbox",
				"id": "restrict_width",
				"label": "Restreindre la largeur de l'image",
				"default": false
			},
			{
				"type": "checkbox",
				"id": "contain_image",
				"label": "Image contenue",
				"default": false
			},
			{
				"type": "select",
				"id": "layout",
				"options": [
					{
						"value": "image_first",
						"label": "t:sections.image-with-text.settings.layout.options__1.label"
					},
					{
						"value": "text_first",
						"label": "t:sections.image-with-text.settings.layout.options__2.label"
					}
				],
				"default": "image_first",
				"label": "t:sections.image-with-text.settings.layout.label"
			},
			{
				"type": "select",
				"id": "mobile_layout",
				"options": [
					{
						"value": "image_first",
						"label": "t:sections.image-with-text.settings.layout.options__1.label"
					},
					{
						"value": "text_first",
						"label": "t:sections.image-with-text.settings.layout.options__2.label"
					}
				],
				"default": "image_first",
				"label": "Placement sur mobile"
			},
			{
				"type": "header",
				"content": "Overlay"
			},
			{
				"type": "checkbox",
				"id": "overlay",
				"label": "Ajouter un overlay",
				"default": true
			},
			{
				"type": "range",
				"id": "overlay_opacity",
				"min": 0,
				"max": 1,
				"step": 0.1,
				"label": "Image overlay opacity",
				"default": 0.2
			},
			{
				"type": "header",
				"content": "t:sections.image-with-text.settings.header_colors.content"
			},
			{
				"type": "color_scheme",
				"id": "section_color_scheme",
				"label": "t:sections.all.colors.label",
				"default": "scheme-1"
			},
			{
				"type": "color_scheme",
				"id": "color_scheme",
				"label": "t:sections.multirow.settings.container_color_scheme.label",
				"default": "scheme-1"
			},
			{
				"type": "header",
				"content": "t:sections.all.padding.section_padding_heading"
			},
			{
				"type": "range",
				"id": "padding_top",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "t:sections.all.padding.padding_top",
				"default": 36
			},
			{
				"type": "range",
				"id": "padding_bottom",
				"min": 0,
				"max": 100,
				"step": 4,
				"unit": "px",
				"label": "t:sections.all.padding.padding_bottom",
				"default": 36
			}
		],

		"presets": [
			{
				"name": "Ax Image text objet"
			}
		]
	}
{% endschema %}
